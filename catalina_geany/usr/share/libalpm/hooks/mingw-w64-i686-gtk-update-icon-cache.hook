[Trigger]
Type = Path
Operation = Install
Operation = Upgrade
Operation = Remove
Target = mingw32/share/icons/*/
Target = !mingw32/share/icons/*/?*

[Action]
Description = Updating icon theme caches...
When = PostTransaction
Exec = /usr/share/libalpm/scripts/mingw-w64-i686-gtk-update-icon-cache.script
NeedsTargets
