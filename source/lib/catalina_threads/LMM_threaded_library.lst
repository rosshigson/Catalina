02260 134 ac60a853  if_z   wrlong  t2, t1          ' yes - make new thread next thread of current thread
02264 135 fc60a654         wrlong  t1, t2          ' make current thread next thread of new thread
02268 136 f606b485         mov     ftemp, #33*4+1  ' update ...
0226c 137 f102b453         add     ftemp, t1       ' ...
02270 138 fac2b75a         rdbyte  ftmp2, ftemp    ' ...
02274 139 fd62b801         cogid   ftmp3           ' ...
02278 13a f526b607         andn    ftmp2, #%111    ' ...
0227c 13b f542b75c         or      ftmp2, ftmp3    ' ...
02280 13c fc42b75a         wrbyte  ftmp2, ftemp    ' ... thread affinity
02284 13d f606b400         mov     ftemp, #0       ' zero ...
02288 13e fc62b451         wrlong  ftemp, req      ' ... request block
0228c 13f fd9fff54         jmp     #LMM_switch     ' now switch to next thread
02290 140          LMM_force                       ' NOTE IF THIS CHANGES, CHANGE threads_misc.e !!
02290 140 fd604224         stalli
02294 141 f587ce01         muxc    flags, #1       ' force context switch - save C ...
02298 142 f5e7ce02         muxnz   flags, #2       ' ... and Z flags
0229c 143 fb00a9e8         rdlong  t2, TP          ' load next thread pointer
022a0 144 fb08a651         rdlong  t1, req wz      ' is there an affinity request oustanding?
022a4 145 5d9fffac  if_nz  jmp     #LMM_affine     ' yes - service it
022a8 146 f208a9e8         cmp     t2, TP wz       ' is there only one thread executing?
022ac 147 5d9fff34  if_nz  jmp     #LMM_switch     ' no - perform context switch
022b0 148 fd9fff8c         jmp     #LMM_unlock     ' yes - unlock, restore C & Z amd resume
                   
