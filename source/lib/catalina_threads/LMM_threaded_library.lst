01fe4 095 5d9fffe8  if_nz jmp    #push_nxt    ' continue till all registers checked
01fe8 096 f1845804        sub    SP,#4         ' save ...
01fec 097 fc60a62c        wrlong t1,SP         ' .... register specification
01ff0 098 fd9fff54        jmp    #LMM_next     ' increment PC, execute next instruction
