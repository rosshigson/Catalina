02148 0ee f664a601         neg     t1,#SVC_FLOAT_ADD
0214c 0ef fd900024         jmp     #fp_service
02150 0f0          flt_sub
02150 0f0 f664a602         neg     t1,#SVC_FLOAT_SUB
02154 0f1 fd90001c         jmp     #fp_service
02158 0f2          flt_mul
02158 0f2 f664a603         neg     t1,#SVC_FLOAT_MUL
0215c 0f3 fd900014         jmp     #fp_service
02160 0f4          flt_div
02160 0f4 f664a604         neg     t1,#SVC_FLOAT_DIV
02164 0f5 fd90000c         jmp     #fp_service
02168 0f6          flt_int
