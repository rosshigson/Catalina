02060 0b4 fc60aa54        wrlong t3,t2         ' write t3 to dst
02064 0b5 f104a604        add    t1,#4         ' increment source
02068 0b6 f104a804        add    t2,#4         ' increment destination
0206c 0b7 f1845e04        sub    BC,#4         ' decrement count ...
02070 0b8 fd9fffe4        jmp    #copy_longs   ' ... and keep copying
