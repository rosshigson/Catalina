02020 0a4          push_b
02020 0a4 fb005e2b        rdlong BC,PC         ' load the byte count
02024 0a5 f1045604        add    PC,#4         ' increment the PC
02028 0a6 f1045e03        add    BC,#3         ' round up BC ...
0202c 0a7 f5245e03        andn   BC,#3         ' ... to be a multiple of 4
02030 0a8 f180582f        sub    SP,BC         ' decrement SP by rounded up size
02034 0a9 f600a633        mov    t1,R0         ' source is in R0
02038 0aa f600a82c        mov    t2,SP         ' destination is SP
0203c 0ab fd900018        jmp    #copy_longs   ' do the copy
                   '
