02174 0f9 f602b635         mov     ftmp2,r2        ' save r2
02178 0fa f602b836         mov     ftmp3,r3        ' save r3
0217c 0fb f6006c53         mov     r3,t1           ' r3 = code of service to request
02180 0fc f6006b59         mov     r2,xfer         ' r2 = data is address of xfer block
02184 0fd f600a759         mov     t1,xfer         ' write ...
02188 0fe fc606653         wrlong  r0,t1           ' ... first argument to xfer block
0218c 0ff f104a604         add     t1,#4           ' write ...
02190 100 fc606853         wrlong  r1,t1           ' ... second argument to xfer block
02194 101 fdb0082c         call    #do_plugin      ' request the service
02198 102 f6006b5b         mov     r2,ftmp2        ' restore r2
0219c 103 f6006d5c         mov     r3,ftmp3        ' restore r3
                   
021a0 104 f25c6600         cmps    r0,#0 wcz       ' set C & Z flags according to result
                   
                   
                   
021a4 105 fd900004         jmp     #LMM_check
                   '
                   '-------------------------- Multi-Threading Support ----------------------------
                   '
                   ' LMM_check - check whether we should context switch (and switch if so)
                   '
021a8 106          LMM_next_chk
021a8 106 f1045604         add     PC,#4
021ac 107          LMM_check
021ac 107 fd604224         stalli
021b0 108 fb6fcd66         djnz    ticks, #LMM_loop ' if ticks not yet zero, don't context switch
021b4 109 f607cc64         mov     ticks, #100     ' in case we cannot get lock, set up ticks to wait before retry
021b8 10a f587ce01         muxc    flags, #1       ' save C ...
021bc 10b f5e7ce02         muxnz   flags, #2       ' ... and Z flags
                   
021c0 10c f43bd5e9         bith    lockbits,lock wcz    ' have we acquired ...
021c4 10d 5d73d206  if_nz  locktry lock wc              ' ... both intra-cog and inter-cog locks?
021c8 10e 1403d5e9  if_nc_and_nz  bitl lockbits,lock    ' true = if_c_and_z, false = if_nc_or_nz
021cc 10f bd900078  if_nc_or_z  jmp #LMM_resume    ' no - cannot switch - restore C & Z and resume
                   
                   
                   
                   
021d0 110 fb00a9e8         rdlong  t2, TP          ' yes - load next thread block pointer
021d4 111 fb08a651         rdlong  t1, req wz      ' is there an affinity request oustanding?
021d8 112 5d900078  if_nz  jmp     #LMM_affine     ' yes - service it
021dc 113 f208a9e8         cmp     t2, TP wz       ' no - is there only one thread executing?
021e0 114 ad90005c  if_z   jmp     #LMM_unlock     ' yes - restore C & Z flags, unlock and resume
021e4 115          LMM_switch
021e4 115 f600aa54         mov     t3, t2          ' no - get ...
021e8 116 f104aa85         add     t3, #33*4+1     ' ... affinity byte
021ec 117 fac0a655         rdbyte  t1, t3          ' ... of proposed next thread
021f0 118 f7cca6e0         test    t1, #%11100000 wz ' affinity stop, or thread terminated or completed?
021f4 119 ad900010   if_z  jmp     #:next          ' no - switch to next thread
021f8 11a f544a680         or      t1, #%10000000  ' yes - make sure ...
021fc 11b fc40a655         wrbyte  t1, t3          ' ... thread terminated bit of next thread is set
02200 11c fb00a854         rdlong  t2, t2          ' remove next thread ...
02204 11d fc60a9e8         wrlong  t2, TP          ' ... from the executing thread list
02208 11e f600a7e8 :next   mov     t1, TP          ' point to ...
0220c 11f f104a604         add     t1, #4          ' ... current thread register save area
                   
02210 120 fd643e28         setq    #32-1           ' save 32 registers ...
02214 121 fc605653         wrlong  PC,t1           ' ... to register save area
02218 122 f104a680         add     t1,#32*4        ' point to flag save area
                   
                   
                   
                   
                   
                   
                   
                   
0221c 123 fc43ce53         wrbyte  flags, t1       ' save C & Z flags
02220 124 f603d054         mov     TP, t2          ' set TP to next thread block
02224 125 f104a804         add     t2, #4          ' point to that thread's register save area
                   
02228 126 fd643e28         setq    #32-1           ' load 32 registers ...
0222c 127 fb005654         rdlong  PC,t2           ' ... from register save area
02230 128 f104a880         add     t2,#32*4        ' point to flag save area
                   
                   
                   
                   
                   
                   
                   
                   
02234 129 fac3ce54         rdbyte  flags, t2       ' load C & Z flags
02238 12a f104a802         add     t2,#2           ' load ...
0223c 12b fae3cc54         rdword  ticks, t2       ' ... tick count assigned to this thread
02240 12c          LMM_unlock
                   
02240 12c fd63d207         lockrel lock                 ' release inter-cog lock
02244 12d f403d5e9         bitl    lockbits,lock        ' release intra-cog lock
02248 12e          LMM_resume
02248 12e f05fce01         shr     flags, #1 wcz   ' restore Z & C flags ...
                   
                   
                   
                   
                   
0224c 12f fd604024         allowi
02250 130 fd9ffcf8         jmp     #LMM_loop       ' ... and resume execution
02254 131          LMM_affine
