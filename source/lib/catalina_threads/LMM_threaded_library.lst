                   '          from the address in R1 to the address in R0
                   '
02040 0ac          copy_b
02040 0ac fb005e2b        rdlong BC,PC         ' load the byte count
02044 0ad f1045604        add    PC,#4         ' increment the PC
02048 0ae f1045e03        add    BC,#3         ' round up BC ...
0204c 0af f5245e03        andn   BC,#3         ' ... to be a multiple of 4
02050 0b0 f600a634        mov    t1,R1         ' source is in R1
02054 0b1 f600a833        mov    t2,R0         ' destination is in R0
                   '
