02124 0e5 fd900080         jmp    #LMM_next_chk ' increment PC, execute next instruction
02128 0e6          bra_a
02128 0e6 1d9fff88  if_a   jmp    #f_jump       ' if condition true, branch is equiv to jump
0212c 0e7 fd900078         jmp    #LMM_next_chk ' increment PC, execute next instruction
02130 0e8          bra_be
02130 0e8 ed9fff80  if_be  jmp    #f_jump       ' if condition true, branch is equiv to jump
02134 0e9 fd900070         jmp    #LMM_next_chk ' increment PC, execute next instruction
02138 0ea          bra_b
02138 0ea cd9fff78  if_b   jmp    #f_jump       ' if condition true, branch is equiv to jump
0213c 0eb fd900068         jmp    #LMM_next_chk ' increment PC, execute next instruction
                   
                   ' plugin - call a plugin
                   ' On entry:
                   '       R3 = code:
                   '            - cog id if >= 128 (i.e. $80 + cog id)
                   '            - plugin type if < 128 (i.e. 0 .. 127)
                   '            - service id if < 0
