                   XMM_CACHE_CMD   = XMM_CACHE_RSP - 4                   ' $7BFF0
                   REGISTRY        = XMM_CACHE_CMD - MAX_COGS*4          ' $7BFB0 CHECK registry.e
                   REQUESTS        = REGISTRY - 2*SVC_MAX - MAX_COGS*4*2 ' $7BE70 CHECK request_status.e
                   ARGV_0          = REQUESTS - ARGV_MAX*4               ' $7BE10 CHECK Catalyst_Arguments.spin2
                   ARGV_ADDR       = ARGV_0 - 4                          ' $7BE0C CHECK Catalyst_Arguments.spin2
                   ARGC_ADDR       = ARGV_ADDR - 4                       ' $7BE08 CHECK Catalyst_Arguments.spin2, blackbox_comms.c, catalina_default.s, catalina_blackcat.s (all targets)
                   DEBUG_FLAG      = ARGC_ADDR - 16                      ' $7BDF8 CHECK blackbox_comms.c, BlackCat_DebugCog.spin2 & catalina_blackcat.s (all targets)
                   DEBUG_IN        = DEBUG_FLAG - 4                      ' $7BDF4 CHECK blackbox_comms.c, BlackCat_DebugCog.spin2 & catalina_blackcat.s (all targets)
                   DEBUG_OUT       = DEBUG_IN - 4                        ' $7BDF0 CHECK blackbox_comms.c, BlackCat_DebugCog.spin2 & catalina_blackcat.s (all targets)
                   DEBUG_ADDR      = DEBUG_OUT - 4                       ' $7BDEC CHECK blackbox_comms.c, BlackCat_DebugCog.spin2 & catalina_blackcat.s (all targets)
                   DEBUG_BREAK     = DEBUG_ADDR - 4                      ' $7BDE8 CHECK blackbox_comms.c, BlackCat_DebugCog.spin2 & catalina_blackcat.s (all targets)
