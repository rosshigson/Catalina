                   '         Result --> Quotient in r0
                   '                    Remainder in r1
                   
020f4 0d9          f_d32s
020f4 0d9 fda00303         call    #\signed_d32     ' perform signed division
020f8 0da fd9000b0         jmp     #LMM_check
                   
                   'f_d32u - unsigned 32 bit division
