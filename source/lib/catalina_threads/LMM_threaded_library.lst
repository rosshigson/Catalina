01f18 04e 0000ffff cviu_m2 long  $0000ffff        '$4e
01f1c 04f ff000000 top8    long  $ff000000        '$4f ' top 8 bits bitmask
01f20 050 00ffffff low24   long  $00ffffff        '$50 ' low 24 bits bitmask
                   
01f24 051 00000000 req     long  0                '$51 request block address
01f28 052 00000000 reg     long  0                '$52 registry address
                   
                   ' NOTE - the initial values below are used only during kernel initialization
                   
01f2c 053 00000000 t1      long  0                '$53
01f30 054 00000000 t2      long  0                '$54
01f34 055 00000000 t3      long  0                '$55
01f38 056 00000000 t4      long  0                '$56
                   
01f3c 057 00000000 ct1     long  0                '$57
01f40 058 00000000 ct2     long  0                '$58
01f44 059 00000000 ct3     long  0                '$59
                   
                   ' lmm_init : initialize VM - note that this code must be at least 17 longs
                   '            to make various offsets match the main kernel, where this
                   '            code may be overlaid by 17 longs of debug code once
                   '            initialization is complete - eventually, the same may be
                   '            true of this kernel as well.
                   
01f48 05a          DEBUG_OVERLAY
01f48 05a          lmm_init
01f48 05a fb04a561         rdlong  reg,PTRA++      '$5a  1 load registry address (used later)
01f4c 05b fd606a01         cogid   r2              '$5b  2 register ...
01f50 05c f0646a02         shl     r2,#2           '$5c  3 ... ourselves ...
01f54 05d f1006a52         add     r2,reg          '$5d  4 ... as ...
01f58 05e fb00a235         rdlong  req,r2          '$5e  5 ... a ...
01f5c 05f f500a250         and     req,low24       '$5f  6 ... new ...
01f60 060 fc60a235         wrlong  req,r2          '$60  7  kernel
01f64 061 fb045761         rdlong  PC,PTRA++       '$61  8 load initial PC
01f68 062 fb045961         rdlong  SP,PTRA++       '$62  9 load initial SP
01f6c 063 fb046761         rdlong  r0,PTRA++       '$63 10 load initial LUT library size (-1)
01f70 064 fb046961         rdlong  r1,PTRA++       '$64 11 load initial LUT library address
01f74 065 fd606629         setq2   r0              '$65 12 copy lut library ...
01f78 066 fb020034         rdlong  $100,r1         '$66 13 ... to LUT RAM, starting at $100
01f7c 067 fdbfff3c         call    #_Thread_init   '$67 14 set up initial thread
01f80 068 fd900018         jmp     #LMM_loop       '$68 15 we can now start executing LMM code
01f84 069 00000000         long    0               '$69 16
01f88 06a 00000000         long    0               '$6a 17
01f8c 06b 00000000         long    0               '$6b 18
01f90 06c 00000000         long    0               '$6c 19
01f94 06d 00000000         long    0               '$6d 20
                   '
                   ' LMM_next - increment the PC then execute the instruction pointed to by the new PC
                   '
01f98 06e          LMM_next
01f98 06e f1045604         add    PC,#4            '$6e
                   '
                   ' LMM_loop - Fetch an instruction from HUB RAM to COG RAM and execute it.
                   ' The basic LMM loop is unrolled 4 times to increase speed.
                   '
01f9c 06f          LMM_loop
01f9c 06f fd604224         stalli                  '$6f
01fa0 070 fb00e62b         rdlong LMM_1,PC         '$70
01fa4 071 f1045604         add    PC,#4            '$71
01fa8 072 00000000         nop                     '$72 1 needs an extra NOP
01fac 073          LMM_1
01fac 073 00000000         nop                     '$73
01fb0 074 fd604024         allowi
01fb4 075 fd900244         jmp    #LMM_check   ' check if context switch is due yet
                   '
                   'load_l - load the long stored at the PC into RI, incrementing the PC
                   '
01fb8 076          load_l
01fb8 076 fb005c2b        rdlong RI,PC         ' load the address
01fbc 077 fd900238        jmp    #LMM_next_chk ' increment PC, execute next instruction
                   '
                   'load_i - load the long at the address stored at the PC into RI,
                   '         incrementing the PC (i.e. load indirect)
                   '
01fc0 078          load_i
01fc0 078 fb005c2b        rdlong RI,PC         ' load the address
01fc4 079 fb005c2e        rdlong RI,RI         ' load the long at that address
01fc8 07a fd90022c        jmp    #LMM_next_chk ' increment PC, execute next instruction
                   '
                   ' fp_ind - load the FP into RI, then add the long at the PC to result, incrementing the PC
                   '
01fcc 07b          fp_ind
01fcc 07b fb005c2b        rdlong RI,PC         ' load the long value
01fd0 07c f1405c2d        adds   RI,FP         ' add the frame pointer
01fd4 07d fd900220        jmp    #LMM_next_chk ' increment PC, execute next instruction
                   '
                   ' push_l - push a long value in RI onto the stack, decrementing the SP
                   '
01fd8 07e          push_l
01fd8 07e f1845804        sub    SP,#4         ' decrement SP
01fdc 07f fc605c2c        wrlong RI,SP         ' save value on stack
01fe0 080 fd900218        jmp    #LMM_check    ' increment PC, execute next instruction
                   '
                   ' push_a - push a value whose address is specified indirectly in a global
                   '          variable onto the stack
                   '
01fe4 081          push_a
01fe4 081 fb005c2b        rdlong RI,PC         ' load the address
01fe8 082 fd900008        jmp    #push_x       ' use the result as an address of the value to push
                   '
                   ' push_i - push a value whose address is specified indirectly in a frame variable
                   '          onto the stack
                   '
01fec 083          push_i
01fec 083 fb005c2b        rdlong RI,PC         ' load the long value
01ff0 084 f1405c2d        adds   RI,FP         ' add the frame pointer
01ff4 085          push_x
01ff4 085 fb005c2e        rdlong RI,RI         ' read the value at that address
01ff8 086 f1845804        sub    SP,#4         ' decrement SP
01ffc 087 fc605c2c        wrlong RI,SP         ' save value on stack
02000 088 fd9001f4        jmp    #LMM_next_chk ' increment PC, execute next instruction
                   '
                   ' push_m - push many registers (specified by long at PC) onto the stack,
                   ' decrementing the SP before each one
                   '
02004 089          push_m
02004 089 fb005c2b        rdlong RI,PC         ' load the long value specifying the registers to push
02008 08a f600a62e        mov    t1,RI         ' save register specification for later
0200c 08b f604a839        mov    t2, #r6       ' start with ...
02010 08c f0445c06        shr    RI,#6         ' ... r6 ...
02014 08d f7cc5dff        test   RI,#$1FF wz   ' ... or ...
02018 08e a0445c09   if_z shr    RI,#9         ' ... with ...
0201c 08f a604a842   if_z mov    t2,#r15       ' ... r15 if r6 - r15 not used
02020 090          push_nxt
02020 090 f05c5c01        shr    RI,#1 wcz     ' save rX?
02024 091 c1845804  if_c  sub    SP,#4         ' yes - save ...
02028 092 c98ca800  if_c  altd   t2
0202c 093 cc60002c  if_c  wrlong 0-0,SP        ' ... register
02030 094 f104a801        add    t2,#1         ' point to next register
02034 095 5d9fffe8  if_nz jmp    #push_nxt    ' continue till all registers checked
02038 096 f1845804        sub    SP,#4         ' save ...
0203c 097 fc60a62c        wrlong t1,SP         ' .... register specification
02040 098 fd9fff54        jmp    #LMM_next     ' increment PC, execute next instruction
                   '
                   ' pop_m - pop many registers (specified by the long on top of stack)
                   ' from the stack, incremening the SP after each one
                   '
02044 099          pop_m
02044 099 fb005c2c        rdlong RI,SP         ' load ...
02048 09a f1045804        add    SP,#4         ' ... register specification to pop
0204c 09b f604a84a        mov    t2, #r23      ' start with ...
02050 09c f0645c08        shl    RI,#(32-24)   ' ... r23
02054 09d          pop_nxt
02054 09d f07c5c01        shl    RI,#1 wcz     ' load rX?
02058 09e c98ca800  if_c  altd   t2
0205c 09f cb00002c  if_c  rdlong 0-0,SP        ' ... load ...
02060 0a0 c1045804  if_c  add    SP,#4         ' ... the register
02064 0a1 ad9fff34  if_z  jmp    #LMM_loop     ' execute next instruction if all done
02068 0a2 f184a801        sub    t2,#1         ' point to previous register
0206c 0a3 fd9fffe4        jmp    #pop_nxt      ' continue till all registers popped
                   '
                   ' push_b - push a structure (size in bytes at the PC) pointed to by R0
                   '          onto the stack, decrementing the SP. Note that the source
                   '          and destination data MUST be long aligned - but this is true
                   '          for all normal structures.
                   '
02070 0a4          push_b
02070 0a4 fb005e2b        rdlong BC,PC         ' load the byte count
02074 0a5 f1045604        add    PC,#4         ' increment the PC
02078 0a6 f1045e03        add    BC,#3         ' round up BC ...
0207c 0a7 f5245e03        andn   BC,#3         ' ... to be a multiple of 4
02080 0a8 f180582f        sub    SP,BC         ' decrement SP by rounded up size
02084 0a9 f600a633        mov    t1,R0         ' source is in R0
02088 0aa f600a82c        mov    t2,SP         ' destination is SP
0208c 0ab fd900018        jmp    #copy_longs   ' do the copy
                   '
                   ' copy_b - copy a structure (size in bytes at the PC)
                   '          from the address in R1 to the address in R0
                   '
02090 0ac          copy_b
02090 0ac fb005e2b        rdlong BC,PC         ' load the byte count
02094 0ad f1045604        add    PC,#4         ' increment the PC
02098 0ae f1045e03        add    BC,#3         ' round up BC ...
0209c 0af f5245e03        andn   BC,#3         ' ... to be a multiple of 4
020a0 0b0 f600a634        mov    t1,R1         ' source is in R1
020a4 0b1 f600a833        mov    t2,R0         ' destination is in R0
                   '
020a8 0b2          copy_longs
020a8 0b2 fb945e54        tjz    BC,#LMM_check ' no more to copy
020ac 0b3 fb00aa53        rdlong t3,t1         ' read from src to t3
020b0 0b4 fc60aa54        wrlong t3,t2         ' write t3 to dst
020b4 0b5 f104a604        add    t1,#4         ' increment source
020b8 0b6 f104a804        add    t2,#4         ' increment destination
020bc 0b7 f1845e04        sub    BC,#4         ' decrement count ...
020c0 0b8 fd9fffe4        jmp    #copy_longs   ' ... and keep copying
                   '
                   ' new_fp - save current frame pointer and set up a new frame pointer
                   ' also calculate what SP was before data was pushed and save it in BC
                   '
020c4 0b9          new_fp
020c4 0b9 f1845804        sub    SP,#4         ' decrement the stack pointer
020c8 0ba fc605a2c        wrlong FP,SP         ' save FP to stack
020cc 0bb f6005a2c        mov    FP,SP         ' set up new FP
020d0 0bc f1045e08        add    BC,#8         ' calculate what SP was ...
020d4 0bd f1005e2d        add    BC,FP         ' ... before arguments were pushed
020d8 0be fd900120        jmp    #LMM_check    ' execute the next instruction
                   '
                   ' fp_ret - pop current frame, restore previous frame and stack pointers,
                   '          then restore the previous program counter
                   '
                   ' f_ret -  just restore the previous program counter
                   '
020dc 0bf          fp_ret
020dc 0bf fb005a2c        rdlong FP,SP         ' restore previous FP
020e0 0c0 f1045804        add    SP,#4         ' increment the SP
020e4 0c1          f_ret
020e4 0c1 fb00562c        rdlong PC,SP         ' read the PC
020e8 0c2 f1045808        add    SP,#8         ' increment the SP
020ec 0c3 fd90010c        jmp    #LMM_check    ' execute the next instruction
                   '
                   ' f_call - call the routine at the address pointed to by the PC (increment the PC)
                   ' f_cali - call the routine whose address is in RI
                   '
020f0 0c4          f_call
020f0 0c4 fb005c2b        rdlong RI,PC         ' get the address to call
020f4 0c5 f1045604        add    PC,#4         ' increment the PC (this is the return address)
020f8 0c6          f_cali
020f8 0c6 f1845808        sub    SP,#8         ' decrement the SP
020fc 0c7 fc60562c        wrlong PC,SP         ' save current PC to stack
02100 0c8 fd900008        jmp    #f_jmpi       ' jump to location in RI
                   '
                   ' f_jump - jump to the location at the address pointed to by PC (increment the PC)
                   '
02104 0c9          f_jump
02104 0c9 fb00562b        rdlong PC,PC         ' get the address to jump to
02108 0ca fd9000f0        jmp    #LMM_check    ' execute next instruction
                   '
                   ' f_jmpi - jump to the location whose address in RI
                   '
0210c 0cb          f_jmpi
0210c 0cb f600562e        mov    PC,RI         ' get the address to jump to
02110 0cc fd9000e8        jmp    #LMM_check    ' execute next instruction
                   '
                   ' rd_long/rd_word/rd_byte : Read long/word/byte from HUB memory at address in RI into BC.
                   '
                   ' On entry:
                   '    RI : address to read
                   ' On exit:
                   '    BC : long/word/byte read
                   '
02114 0cd          rd_long
02114 0cd fb005e2e         rdlong  BC,RI
02118 0ce fd9000dc         jmp     #LMM_next_chk
0211c 0cf          rd_word
0211c 0cf fae05e2e         rdword  BC,RI
02120 0d0 fd9000d4         jmp     #LMM_next_chk
02124 0d1          rd_byte
02124 0d1 fac05e2e         rdbyte  BC,RI
02128 0d2 fd9000cc         jmp     #LMM_next_chk
                   '
                   ' wr_long/wr_word/wr_byte : Write long/word/byte to HUB memory at address in RI into BC.
                   '
                   ' On entry:
                   '    RI : address to write
                   '    BC : long/word/byte to write
                   ' On exit:
                   '    (none)
                   '
0212c 0d3          wr_long
0212c 0d3 fc605e2e         wrlong  BC,RI
02130 0d4 fd9000c4         jmp     #LMM_next_chk
02134 0d5          wr_word
02134 0d5 fc505e2e         wrword  BC,RI
02138 0d6 fd9000bc         jmp     #LMM_next_chk
0213c 0d7          wr_byte
0213c 0d7 fc405e2e         wrbyte  BC,RI
02140 0d8 fd9000b4         jmp     #LMM_next_chk
                   
                   'fd_32s - Signed 32 bit division
                   '         Divisor --> r1
                   '         Dividend--> r0
                   '         Result --> Quotient in r0
                   '                    Remainder in r1
                   
02144 0d9          f_d32s
02144 0d9 fda00303         call    #\signed_d32     ' perform signed division
02148 0da fd9000b0         jmp     #LMM_check
                   
                   'f_d32u - unsigned 32 bit division
                   '         Divisor : r1
                   '         Dividend : r0
                   '         Result:
                   '             Quotient in r0
                   '             Remainder in r1
                   
0214c 0db          f_d32u
0214c 0db fda00300         call    #\unsigned_d32   ' perform signed division
02150 0dc fd9000a8         jmp     #LMM_check
                   
                   
                   'f_m32 - multiplication
                   '        r0 : 1st operand (32 bit)
                   '        r1 : 2nd operand (32 bit)
                   '        Result:
                   '           Product in r0 (<= 32 bit)
                   
02154 0dd          f_m32
02154 0dd fd006634         qmul   r0,r1
02158 0de fd606618         getqx  r0
0215c 0df fd90009c         jmp    #LMM_check
                   
                   ' bra_xx - branch if condition is true to the address at the PC,
                   '          otherwise, just increment the PC by 4
                   
02160 0e0          bra_z
02160 0e0 ad9fffa0   if_z  jmp    #f_jump       ' if condition true, branch is equiv to jump
02164 0e1 fd900090         jmp    #LMM_next_chk ' increment PC, execute next instruction
02168 0e2          bra_nz
02168 0e2 5d9fff98  if_nz  jmp    #f_jump       ' if condition true, branch is equiv to jump
0216c 0e3 fd900088         jmp    #LMM_next_chk ' increment PC, execute next instruction
02170 0e4          bra_ae
02170 0e4 3d9fff90  if_ae  jmp    #f_jump       ' if condition true, branch is equiv to jump
02174 0e5 fd900080         jmp    #LMM_next_chk ' increment PC, execute next instruction
02178 0e6          bra_a
02178 0e6 1d9fff88  if_a   jmp    #f_jump       ' if condition true, branch is equiv to jump
0217c 0e7 fd900078         jmp    #LMM_next_chk ' increment PC, execute next instruction
02180 0e8          bra_be
02180 0e8 ed9fff80  if_be  jmp    #f_jump       ' if condition true, branch is equiv to jump
02184 0e9 fd900070         jmp    #LMM_next_chk ' increment PC, execute next instruction
02188 0ea          bra_b
02188 0ea cd9fff78  if_b   jmp    #f_jump       ' if condition true, branch is equiv to jump
0218c 0eb fd900068         jmp    #LMM_next_chk ' increment PC, execute next instruction
                   
                   ' plugin - call a plugin
                   ' On entry:
                   '       R3 = code:
                   '            - cog id if >= 128 (i.e. $80 + cog id)
                   '            - plugin type if < 128 (i.e. 0 .. 127)
                   '            - service id if < 0
                   '       R2 = data (optional pointer)
                   '
                   ' NOTES: Locks are currently only supported when invoking via a service id.
                   '        When using service id, the data should only use the lower 24 bits.
                   '
                   ' On exit:
                   '       R0 = result
                   
02190 0ec          plugin
02190 0ec fda0030d         call    #\do_plugin     ' do_plugin does all the work
02194 0ed fd900064         jmp     #LMM_check
                   
02198 0ee          flt_add
02198 0ee f664a601         neg     t1,#SVC_FLOAT_ADD
0219c 0ef fd900024         jmp     #fp_service
021a0 0f0          flt_sub
021a0 0f0 f664a602         neg     t1,#SVC_FLOAT_SUB
021a4 0f1 fd90001c         jmp     #fp_service
021a8 0f2          flt_mul
021a8 0f2 f664a603         neg     t1,#SVC_FLOAT_MUL
021ac 0f3 fd900014         jmp     #fp_service
021b0 0f4          flt_div
021b0 0f4 f664a604         neg     t1,#SVC_FLOAT_DIV
021b4 0f5 fd90000c         jmp     #fp_service
021b8 0f6          flt_int
021b8 0f6 f664a605         neg     t1,#SVC_FLOAT_FLOAT
021bc 0f7 fd900004         jmp     #fp_service
021c0 0f8          int_flt
021c0 0f8 f664a606         neg     t1,#SVC_FLOAT_TRUNC
                           ' fall through to
                   '
                   '------------------------------------------------------------------------------
                   ' fp_service - request a floating point service
                   ' input:   t2          service to request
                   '          r0          32-bit floating point value
                   '          r1          32-bit floating point value
                   ' output:  r0          32-bit floating point result
                   '------------------------------------------------------------------------------
                   '
021c4 0f9          fp_service
021c4 0f9 f602b635         mov     ftmp2,r2        ' save r2
021c8 0fa f602b836         mov     ftmp3,r3        ' save r3
021cc 0fb f6006c53         mov     r3,t1           ' r3 = code of service to request
021d0 0fc f6006b59         mov     r2,xfer         ' r2 = data is address of xfer block
021d4 0fd f600a759         mov     t1,xfer         ' write ...
021d8 0fe fc606653         wrlong  r0,t1           ' ... first argument to xfer block
021dc 0ff f104a604         add     t1,#4           ' write ...
021e0 100 fc606853         wrlong  r1,t1           ' ... second argument to xfer block
021e4 101 fdb0082c         call    #do_plugin      ' request the service
021e8 102 f6006b5b         mov     r2,ftmp2        ' restore r2
021ec 103 f6006d5c         mov     r3,ftmp3        ' restore r3
                   
021f0 104 f25c6600         cmps    r0,#0 wcz       ' set C & Z flags according to result
                   
                   
                   
021f4 105 fd900004         jmp     #LMM_check
                   '
                   '-------------------------- Multi-Threading Support ----------------------------
                   '
                   ' LMM_check - check whether we should context switch (and switch if so)
                   '
021f8 106          LMM_next_chk
021f8 106 f1045604         add     PC,#4
021fc 107          LMM_check
021fc 107 fd604224         stalli
02200 108 fb6fcd66         djnz    ticks, #LMM_loop ' if ticks not yet zero, don't context switch
02204 109 f607cc64         mov     ticks, #100     ' in case we cannot get lock, set up ticks to wait before retry
02208 10a f587ce01         muxc    flags, #1       ' save C ...
0220c 10b f5e7ce02         muxnz   flags, #2       ' ... and Z flags
                   
02210 10c f43bd5e9         bith    lockbits,lock wcz    ' have we acquired ...
02214 10d 5d73d206  if_nz  locktry lock wc              ' ... both intra-cog and inter-cog locks?
02218 10e 1403d5e9  if_nc_and_nz  bitl lockbits,lock    ' true = if_c_and_z, false = if_nc_or_nz
0221c 10f bd900078  if_nc_or_z  jmp #LMM_resume    ' no - cannot switch - restore C & Z and resume
                   
                   
                   
                   
02220 110 fb00a9e8         rdlong  t2, TP          ' yes - load next thread block pointer
02224 111 fb08a651         rdlong  t1, req wz      ' is there an affinity request oustanding?
02228 112 5d900078  if_nz  jmp     #LMM_affine     ' yes - service it
0222c 113 f208a9e8         cmp     t2, TP wz       ' no - is there only one thread executing?
02230 114 ad90005c  if_z   jmp     #LMM_unlock     ' yes - restore C & Z flags, unlock and resume
02234 115          LMM_switch
02234 115 f600aa54         mov     t3, t2          ' no - get ...
02238 116 f104aa85         add     t3, #33*4+1     ' ... affinity byte
0223c 117 fac0a655         rdbyte  t1, t3          ' ... of proposed next thread
02240 118 f7cca6e0         test    t1, #%11100000 wz ' affinity stop, or thread terminated or completed?
02244 119 ad900010   if_z  jmp     #:next          ' no - switch to next thread
02248 11a f544a680         or      t1, #%10000000  ' yes - make sure ...
0224c 11b fc40a655         wrbyte  t1, t3          ' ... thread terminated bit of next thread is set
02250 11c fb00a854         rdlong  t2, t2          ' remove next thread ...
02254 11d fc60a9e8         wrlong  t2, TP          ' ... from the executing thread list
02258 11e f600a7e8 :next   mov     t1, TP          ' point to ...
0225c 11f f104a604         add     t1, #4          ' ... current thread register save area
                   
02260 120 fd643e28         setq    #32-1           ' save 32 registers ...
02264 121 fc605653         wrlong  PC,t1           ' ... to register save area
02268 122 f104a680         add     t1,#32*4        ' point to flag save area
                   
                   
                   
                   
                   
                   
                   
                   
0226c 123 fc43ce53         wrbyte  flags, t1       ' save C & Z flags
02270 124 f603d054         mov     TP, t2          ' set TP to next thread block
02274 125 f104a804         add     t2, #4          ' point to that thread's register save area
                   
02278 126 fd643e28         setq    #32-1           ' load 32 registers ...
0227c 127 fb005654         rdlong  PC,t2           ' ... from register save area
02280 128 f104a880         add     t2,#32*4        ' point to flag save area
                   
                   
                   
                   
                   
                   
                   
                   
02284 129 fac3ce54         rdbyte  flags, t2       ' load C & Z flags
02288 12a f104a802         add     t2,#2           ' load ...
0228c 12b fae3cc54         rdword  ticks, t2       ' ... tick count assigned to this thread
02290 12c          LMM_unlock
                   
02290 12c fd63d207         lockrel lock                 ' release inter-cog lock
02294 12d f403d5e9         bitl    lockbits,lock        ' release intra-cog lock
02298 12e          LMM_resume
02298 12e f05fce01         shr     flags, #1 wcz   ' restore Z & C flags ...
                   
                   
                   
                   
                   
0229c 12f fd604024         allowi
022a0 130 fd9ffcf8         jmp     #LMM_loop       ' ... and resume execution
022a4 131          LMM_affine
022a4 131 f208a9e8         cmp     t2, TP wz       ' is there only one thread executing?
022a8 132 5b00aa54  if_nz  rdlong  t3, t2          ' no - get next thread of next thread ...
022ac 133 5c60aa53  if_nz  wrlong  t3, t1          ' no - ... and make it next thread of new thread
