020e8 0d6 fd9000bc         jmp     #LMM_next_chk
020ec 0d7          wr_byte
020ec 0d7 fc405e2e         wrbyte  BC,RI
020f0 0d8 fd9000b4         jmp     #LMM_next_chk
                   
                   'fd_32s - Signed 32 bit division
