                   '------------------------------------------------------------------------------
                   ' Float32 Assembly language routines
                   '------------------------------------------------------------------------------
                   ' flt_add   r0 = r0 + r1
                   ' flt_sub   r0 = r0 - r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1
                   '------------------------------------------------------------------------------
                   
0218c 0fb f5602e32 flt_sub                 xor     r1, Bit31               ' negate B
02190 0fc fd604224 flt_add                 stalli
02194 0fd fdb00184                         call    #_Unpack2               ' unpack two variables
02198 0fe ed9ffda0           if_c_or_z     jmp     #returni                ' check for NaN or B = 0
                   
0219c 0ff f7cf4e01                         test    flagA, #SignFlag wz     ' negate A mantissa if negative
021a0 100 566353a9           if_nz         neg     manA, manA
021a4 101 f7cf5401                         test    flagB, #SignFlag wz     ' negate B mantissa if negative
021a8 102 566359ac           if_nz         neg     manB, manB
                   
021ac 103 f60075a8                         mov     t1, expA                ' align mantissas
021b0 104 f18075ab                         sub     t1, expB
021b4 105 f640743a                         abs     t1, t1
021b8 106 f324741f                         fle     t1, #31
021bc 107 f25b51ab                         cmps    expA, expB wcz
021c0 108 10c3583a           if_nz_and_nc  sar     manB, t1
021c4 109 40c3523a           if_nz_and_c   sar     manA, t1
021c8 10a 460351ab           if_nz_and_c   mov     expA, expB
                   
021cc 10b f10353ac                         add     manA, manB              ' add the two mantissas
021d0 10c f2575200                         cmps    manA, #0 wc             ' set sign of result
021d4 10d c5474e01           if_c          or      flagA, #SignFlag
021d8 10e 35274e01           if_nc         andn    flagA, #SignFlag
021dc 10f f64353a9                         abs     manA, manA              ' pack result and exit
021e0 110 fdb001e0 pack_rtni               call    #_Pack
021e4 111 fd9ffd54                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' flt_mul  r0 = r0 * r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
021e8 112 fd604224 flt_mul                 stalli
021ec 113 fdb0012c                         call    #_Unpack2               ' unpack two variables
021f0 114 3d900024           if_nc         jmp     #flt_mul2               ' multiply if neither is NaN
021f4 115 f20f50ff                         cmp     expA, #255 wz           ' NaN, so check for r0 = Inf
021f8 116 ad900008           if_z          jmp     #flt_mul1               ' yes - return Inf
021fc 117 f20f56ff                         cmp     expB, #255 wz           ' no - check for r1 = Inf
02200 118 5d9ffd38           if_nz         jmp     #returni                ' no - return NaN
02204 119 f6002da3 flt_mul1                mov     r0, Inf                 ' yes, r0 or r1 is Inf, so return Inf
02208 11a f5634faa                         xor     flagA, flagB            '
0220c 11b f7cf4e01                         test    flagA, #SignFlag wz
02210 11c 55402c32           if_nz         or      r0, Bit31
02214 11d fd9ffd24                         jmp     #returni
02218 11e f5634faa flt_mul2                xor     flagA, flagB            ' get sign of result
0221c 11f f10351ab                         add     expA, expB              ' add exponents
02220 120 fd0353ac                         qmul    manA, manB
02224 121 fd607419                         getqy   t1
02228 122 f0647403                         shl     t1, #3                  ' justify result and exit
0222c 123 f603523a                         mov     manA, t1
02230 124 fd9fffac                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' flt_div  r0 = r0 / r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
02234 125 fd604224 flt_div                 stalli
02238 126 fdb000e0                         call    #_Unpack2               ' unpack two variables
0223c 127 e6002da2           if_c_or_z     mov     r0, NaN                 ' check for NaN or divide by 0
02240 128 ed9ffcf8           if_c_or_z     jmp     #returni
                   
02244 129 f5634faa                         xor     flagA, flagB            ' get sign of result
02248 12a f18351ab                         sub     expA, expB              ' subtract exponents
                   
0224c 12b f0475201                         shr     manA, #1
02250 12c fd635228                         setq    manA
02254 12d fd1801ac                         qdiv    #0, manB
02258 12e fd635218                         getqx   manA
0225c 12f f0475202                         shr     manA, #2
02260 130 fd9fff7c                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' flt_int  r0 = float(r0)
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
02264 131 fd604224 flt_int                 stalli
02268 132 f6034e16                         mov     flagA, r0               ' get integer value
0226c 133 f6042c00                         mov     r0, #0                  ' set initial result to zero
02270 134 f64b53a7                         abs     manA, flagA wz          ' get absolute value of integer
02274 135 ad9ffcc4           if_z          jmp     #returni                ' if zero, exit
02278 136 f0474e1f                         shr     flagA, #31              ' set sign flag
0227c 137 f607501f                         mov     expA, #31               ' set initial value for exponent
02280 138 f0775201 normalize_1             shl     manA, #1 wc             ' normalize the mantissa
02284 139 31875001           if_nc         sub     expA, #1                ' adjust exponent
02288 13a 3d9ffff4           if_nc         jmp     #normalize_1
0228c 13b f0875201                         rcr     manA, #1                ' justify mantissa
02290 13c f0475202                         shr     manA, #2
02294 13d fd9fff48                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' int_flt  r0 = fix(r0)
                   ' changes: r0, flagA, expA, manA, t1
                   '------------------------------------------------------------------------------
                   
02298 13e fd604224 int_flt                 stalli
0229c 13f f6047400                         mov     t1, #0                  ' set for no rounding
                   '                        jmp     #fix
                   
                   'rnd_flt                 mov     t1, #1                  ' set for rounding
                   
022a0 140 fdb000a8 fix                     call    #_Unpack                ' unpack floating point value
022a4 141 cd9ffc94           if_c          jmp     #returni                ' check for NaN
022a8 142 f0675202                         shl     manA, #2                ' left justify mantissa
022ac 143 f6042c00                         mov     r0, #0                  ' initialize result to zero
022b0 144 f66351a8                         neg     expA, expA              ' adjust for exponent value
022b4 145 f10f501e                         add     expA, #30 wz
022b8 146 f2575020                         cmps    expA, #32 wc
022bc 147 bd9ffc7c           if_nc_or_z    jmp     #returni
022c0 148 f04353a8                         shr     manA, expA
                   
022c4 149 f103523a                         add     manA, t1                ' round up 1/2 lsb
022c8 14a f0475201                         shr     manA, #1
                   
022cc 14b f7cf4e01                         test    flagA, #signFlag wz     ' check sign and exit
022d0 14c f3e02da9                         sumnz   r0, manA
022d4 14d fd9ffc64                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' flt_cmp   set Z and C flags for r0 - r1
                   ' changes: status, t1
                   '------------------------------------------------------------------------------
                   
022d8 14e fd604224 flt_cmp                 stalli
022dc 14f f6007416                         mov     t1, r0               ' compare signs
022e0 150 f5607417                         xor     t1, r1
022e4 151 f5087432                         and     t1, Bit31 wz
022e8 152 ad900018           if_z          jmp     #cmp1                  ' same, then compare magnitude
                   
022ec 153 f6007416                         mov     t1, r0               ' check for +0 or -0
022f0 154 f5407417                         or      t1, r1
022f4 155 f5387432                         andn    t1, Bit31 wcz
022f8 156 ad9ffc40           if_z          jmp     #returni
                   
022fc 157 f7d02c32                         test    r0, Bit31 wc         ' compare signs
02300 158 fd9ffc38                         jmp     #returni
                   
02304 159 f7c82c32 cmp1                    test    r0, Bit31 wz         ' check signs
02308 15a 5d900008           if_nz         jmp     #cmp2
0230c 15b f2182c17                         cmp     r0, r1 wcz
02310 15c fd9ffc28                         jmp     #returni
02314 15d f2182e16 cmp2                    cmp     r1, r0 wcz           ' reverse test if negative
02318 15e fd9ffc20                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' input:   r0        32-bit floating point value
                   '          r1        32-bit floating point value
                   ' output:  flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
