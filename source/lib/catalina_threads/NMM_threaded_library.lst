01f20 060 fd604224        stalli               ' disable interrupts
01f24 061 fb0029f6        rdlong RI,PA         ' load the long value
01f28 062 f14029f9        adds   RI,PTRB       ' add the frame pointer
01f2c 063          push_x
01f2c 063 fd604224        stalli               ' disable interrupts
01f30 064 fb002814        rdlong RI,RI         ' read the value at that address
01f34 065 fc64295f        wrlong RI,--PTRA     ' save value on stack
01f38 066 f107ec04        add    PA,#4         ' increment PC ...
01f3c 067          returni
01f3c 067 fd604024        allowi               ' ... enable interrupts ...
01f40 068 fd63ec2c        jmp    PA            ' ... and return
                   
                   '
                   ' push_m - push many registers (specified by long at PC) onto the stack,
                   ' decrementing the SP (PTRA) before each one
                   '
01f44 069          push_m
01f44 069 fd604224        stalli               ' disable interrupts
                   
                   
                   
                   
                   
                   
01f48 06a fb0029f6        rdlong RI,PA         ' load the long value specifying registers to push
01f4c 06b f6007414        mov    t1,RI         ' save register specification for later
01f50 06c f0442806        shr    RI,#6         ' ignore registers r0 - r5 (never saved)
01f54 06d f604781c        mov    t3,#r6        ' start with r6
01f58 06e          push_nxt
01f58 06e f05c2801        shr    RI,#1 wcz     ' save rX?
01f5c 06f c98c7800  if_c  altd   t3            ' yes - decrement SP ...
01f60 070 cc64015f  if_c  wrlong 0-0,--PTRA    ' ... and save the register
01f64 071 f1047801        add    t3,#1         ' point to next register
01f68 072 5d9fffec  if_nz jmp    #push_nxt     ' continue till all registers saved
01f6c 073 fc64755f        wrlong t1,--PTRA     ' save register specification
                   
01f70 074 f107ec04        add    PA,#4         ' increment PC ...
01f74 075 fd9fffc4        jmp    #returni      ' ... and return
                   
01f78 076 0003ffff Bits18 long   %0000_0000_0000_0011_1111_1111_1111_1111
                   
                   '
                   ' pop_m - pop many registers (specified by the long on top of stack)
                   ' from the stack, incremening the SP after each one
                   '
01f7c 077          pop_m
01f7c 077 fd604224        stalli               ' disable interrupts
                   
                   
                   
                   
                   
                   
01f80 078 fb042961        rdlong RI,PTRA++     ' pop the long value specifying registers to pop
01f84 079 f604762d        mov    t2,#r23       ' start with ...
01f88 07a f0642808        shl    RI,#(32-24)   ' ... r23
01f8c 07b          pop_nxt
01f8c 07b f07c2801        shl    RI,#1 wcz     ' load rX?
01f90 07c c98c7600  if_c  altd   t2            ' yes - load the register ...
01f94 07d cb040161  if_c  rdlong 0-0,PTRA++    ' ... and increment the stack pointer
01f98 07e 51847601  if_nz sub    t2,#1         ' if more to do, point to previous register ...
01f9c 07f 5d9fffec  if_nz jmp    #pop_nxt      ' ... and continue till all registers popped
                   
01fa0 080 fd9fff98        jmp    #returni
                   
                   '
                   ' push_b - push a structure (size in bytes at the PC) pointed to by R0
                   '          onto the stack, decrementing the SP (PTRA). Note that the source
                   '          and destination data MUST be long aligned - but this is true
                   '          for all normal structures.
                   '
01fa4 081          push_b
01fa4 081 fd604224        stalli               ' disable interrupts
01fa8 082 fb002bf6        rdlong BC,PA         ' load the byte count
01fac 083 f107ec04        add    PA,#4         ' increment the PC
01fb0 084 f1042a03        add    BC,#3         ' round up BC ...
01fb4 085 f5242a03        andn   BC,#3         ' ... to be a multiple of 4
01fb8 086 f183f015        sub    PTRA,BC       ' decrement SP (PTRA) by rounded up size
01fbc 087 f6007416        mov    t1,R0         ' source is in R0
01fc0 088 f60077f8        mov    t2,PTRA       ' destination is SP (PTRA)
01fc4 089 fd90001c        jmp    #copy_longs   ' do the copy
                   '
                   ' copy_b - copy a structure (size in bytes at the PC)
                   '          from the address in R1 to the address in R0
                   '
01fc8 08a          copy_b
01fc8 08a fd604224        stalli               ' disable interrupts
01fcc 08b fb002bf6        rdlong BC,PA         ' load the byte count
01fd0 08c f107ec04        add    PA,#4         ' increment the PC
01fd4 08d f1042a03        add    BC,#3         ' round up BC ...
01fd8 08e f5242a03        andn   BC,#3         ' ... to be a multiple of 4
01fdc 08f f6007417        mov    t1,R1         ' source is in R1
01fe0 090 f6007616        mov    t2,R0         ' destination is in R0
                   '
01fe4 091          copy_longs
01fe4 091 f0442a02        shr    BC,#2         ' number of times to repeat
01fe8 092 fcd80815        rep    #4,BC         ' repeat the next 4 instructions BC times
01fec 093 fb00783a        rdlong t3,t1         ' read from src to t3
01ff0 094 fc60783b        wrlong t3,t2         ' write t3 to dst
01ff4 095 f1047404        add    t1,#4         ' increment source
01ff8 096 f1047604        add    t2,#4         ' increment destination
01ffc 097 fd9fff3c        jmp    #returni
                   '
                   ' new_fp - save current frame pointer and set up a new frame pointer
                   ' also calculate what SP (PTRA) was before data was pushed and save it in BC
                   '
02000 098          new_fp
02000 098 fd604224        stalli
02004 099 fc67f35f        wrlong PTRB,--PTRA   ' save FP (PTRB) to stack
02008 09a f603f3f8        mov    PTRB,PTRA     ' set up new FP (PTRB)
0200c 09b f1042a08        add    BC,#8         ' calculate what SP (PTRA) was ...
02010 09c f1002bf9        add    BC,PTRB       ' ... before arguments were pushed
02014 09d fd9fff24        jmp    #returni
                   '
                   ' fp_ret - pop current frame, restore previous frame and stack pointers,
                   '          then restore the previous program counter
                   '
                   ' f_ret -  just restore the previous program counter
                   '
02018 09e          fp_ret
02018 09e fd604224        stalli               ' disable interrupts
0201c 09f fb07f361        rdlong PTRB,PTRA++   ' restore previous FP (PTRB)
02020 0a0          f_ret
02020 0a0 fd604224        stalli               ' disable interrupts
02024 0a1 fb07ed00        rdlong PA,PTRA       ' read the PC
02028 0a2 f107f008        add    PTRA,#8       ' increment the SP (PTRA)
0202c 0a3 fd9fff0c        jmp    #returni
                   '
                   ' f_call - call the routine at the address pointed to by the PC
                   ' f_cali - call the routine whose address is in RI
                   '
02030 0a4          f_call
02030 0a4 fd604224        stalli               ' disable interrupts
02034 0a5 fb0029f6        rdlong RI,PA         ' get the address to call
02038 0a6 f107ec04        add    PA,#4         ' increment the PC (this is the return address)
0203c 0a7          f_cali
0203c 0a7 fd604224        stalli               ' disable interrupts
02040 0a8 f187f008        sub    PTRA,#8       ' decrement the SP (PTRA)
02044 0a9 fc67ed00        wrlong PA,PTRA       ' save current PC to stack
02048 0aa fd604024        allowi               ' enable interrupts
0204c 0ab fd60282c        jmp    RI            ' execute next instruction
                   
                   'fd_32s - Signed 32 bit division
                   '         Divisor --> r1
                   '         Dividend--> r0
                   '         Result --> Quotient in r0
                   '                    Remainder in r1
                   
02050 0ac          f_d32s
02050 0ac fd604224        stalli               ' disable interrupts
02054 0ad fda00303        call   #\signed_d32  ' perform signed division
02058 0ae fd9ffee0        jmp    #returni
                   
                   ' plugin - call a plugin
                   ' On entry:
                   '       R3 = code:
                   '            - cog id if >= 128 (i.e. $80 + cog id)
                   '            - plugin type if < 128 (i.e. 0 .. 127)
                   '            - service id if < 0
                   '       R2 = data (optional pointer)
                   '
                   ' NOTES: Locks are currently only supported when invoking via a service id.
                   '        When using service id, the data should only use the lower 24 bits.
                   '
                   ' On exit:
                   '       R0 = result
                   
0205c 0af          plugin
0205c 0af fd604224        stalli               ' disable interrupts
02060 0b0 fda0030d        call   #\do_plugin   ' do_plugin does all the work
02064 0b1 fd9ffed4        jmp    #returni
                   
                   '-------------------------- Multi-Threading Support ----------------------------
                   
02068 0b2          NMM_isr
02068 0b2 fd604224         stalli
0206c 0b3 f43bd5e9         bith    lockbits,lock wcz    ' have we acquired ...
02070 0b4 5d73d206  if_nz  locktry lock wc              ' ... both intra-cog and inter-cog locks?
02074 0b5 1403d5e9  if_nc_and_nz  bitl lockbits,lock    ' true = if_c_and_nz, false = if_nc_or_z
02078 0b6 bd9000a0  if_nc_or_z  jmp #NMM_resume    ' no - cannot switch - restore C & Z and resume
0207c 0b7 fb0877e8         rdlong  t2, TP wz       ' yes - is there a next thread block pointer?
02080 0b8 ad900090  if_z   jmp     #NMM_unlock     ' no - unlock and resume
02084 0b9 fb087438         rdlong  t1, req wz      ' yes - is there an affinity request oustanding?
02088 0ba 5d9000a0  if_nz  jmp     #NMM_affine     ' yes - service it
0208c 0bb f20877e8         cmp     t2, TP wz       ' no - is there only one thread executing?
02090 0bc ad900080  if_z   jmp     #NMM_unlock     ' yes - unlock and resume
02094 0bd          NMM_switch
02094 0bd f600783b         mov     t3, t2          ' no - get ...
02098 0be f1047885         add     t3, #33*4+1     ' ... affinity byte
0209c 0bf fac0743c         rdbyte  t1, t3          ' ... of proposed next thread
020a0 0c0 f7cc74e0         test    t1, #%11100000 wz ' affinity stop, or thread terminated or completed?
020a4 0c1 ad900010   if_z  jmp     #:next          ' no - switch to next thread
020a8 0c2 f5447480         or      t1, #%10000000  ' yes - make sure ...
020ac 0c3 fc40743c         wrbyte  t1, t3          ' ... thread terminated bit of next thread is set
020b0 0c4 fb00763b         rdlong  t2, t2          ' remove next thread ...
020b4 0c5 fc6077e8         wrlong  t2, TP          ' ... from the executing thread list
020b8 0c6 f60075e8 :next   mov     t1, TP          ' point to ...
020bc 0c7 f1047404         add     t1, #4          ' ... current thread register save area
020c0 0c8 f6005df1         mov     Save_PC,iret3   ' Save PC and flags
020c4 0c9 f60063f6         mov     Save_PA,PA      ' Save PA
020c8 0ca f6005ff9         mov     Save_FP,FP      ' Save FP
020cc 0cb f60061f8         mov     Save_SP,SP      ' Save SP
020d0 0cc fd643a28         setq    #30-1           ' save 30 registers ...
020d4 0cd fc60283a         wrlong  RI,t1           ' ... to register save area
020d8 0ce f603d03b         mov     TP, t2          ' set TP to next thread block
020dc 0cf f1047604         add     t2, #4          ' point to that thread's register save area
020e0 0d0 fd643a28         setq    #30-1           ' load 30 registers ...
020e4 0d1 fb00283b         rdlong  RI,t2           ' ... from register save area
020e8 0d2 f603f030         mov     SP,Save_SP      ' restore SP
020ec 0d3 f603f22f         mov     FP,Save_FP      ' restore FP
020f0 0d4 f603ec31         mov     PA,Save_PA      ' restore PA
020f4 0d5 f603e22e         mov     iret3,Save_PC   ' restore PC and flags
020f8 0d6 f60075e8         mov     t1,TP           ' up date ticks ...
020fc 0d7 f1047486         add     t1,#33*4+2      ' ... with ticks ...
02100 0d8 fae3ce3a         rdword  ticks,t1        ' ... for current thread ...
02104 0d9 ff00001f         and     t1,##%11111111111111
02108 0da f50475ff 
0210c 0db f107ce01         add     ticks,#1
02110 0dc f067ce0e         shl     ticks,#14       ' ... corrected for faster 1 !
02114 0dd          NMM_unlock
02114 0dd fd63d207         lockrel lock                 ' release inter-cog lock
02118 0de f403d5e9         bitl    lockbits,lock        ' release intra-cog lock
0211c 0df          NMM_resume
0211c 0df f20fce00         cmp     ticks, #0 wz
02120 0e0 5a7081e7   if_nz addct3  ct3,ticks       ' update ct3 target for next interrupt
02124 0e1 fd604024         allowi
02128 0e2 fb3bfff1         reti3                   ' resume execution
0212c 0e3          NMM_affine
0212c 0e3 f20877e8         cmp     t2, TP wz       ' is there only one thread executing?
02130 0e4 5b00783b  if_nz  rdlong  t3, t2          ' no - get next thread of next thread ...
02134 0e5 5c60783a  if_nz  wrlong  t3, t1          ' no - ... and make it next thread of new thread
02138 0e6 ac60763a  if_z   wrlong  t2, t1          ' yes - make new thread next thread of current thread
0213c 0e7 fc60743b         wrlong  t1, t2          ' make current thread next thread of new thread
02140 0e8 f6047885         mov     t3, #33*4+1     ' update ...
02144 0e9 f100783a         add     t3, t1          ' ...
02148 0ea fac07a3c         rdbyte  t4, t3          ' ...
0214c 0eb fd607401         cogid   t1              ' ...
02150 0ec f5247a07         andn    t4, #%111       ' ...
02154 0ed f5407a3a         or      t4, t1          ' ...
02158 0ee fc407a3c         wrbyte  t4, t3          ' ... thread affinity
0215c 0ef f6047800         mov     t3, #0          ' zero ...
02160 0f0 fc607838         wrlong  t3, req         ' ... request block
02164 0f1 fd9fff2c         jmp     #NMM_switch     ' now switch to next thread
02168 0f2          NMM_force
02168 0f2 fd604224         stalli
0216c 0f3 f607ce00         mov     ticks, #0
02170 0f4 f603e3f6         mov     iret3,PA        ' set up return address as if from interrupt
02174 0f5 fb0077e8         rdlong  t2, TP          ' load next thread pointer
02178 0f6 fb087438         rdlong  t1, req wz      ' is there an affinity request oustanding?
0217c 0f7 5d9fffac  if_nz  jmp     #NMM_affine     ' yes - service it
02180 0f8 f20877e8         cmp     t2, TP wz       ' is there only one thread executing?
02184 0f9 5d9fff0c  if_nz  jmp     #NMM_switch     ' no - perform context switch
02188 0fa fd9fff88         jmp     #NMM_unlock     ' yes - unlock, restore C & Z amd resume
                   
