02224 0f2 f1043004          add    PC,#4           ' point to next long
02228 0f3 00000000 	 nop                    ' 1 requires this!!!
0222c 0f4 00000000 exec1a   long   0-0
02230 0f5 fd800074          jmp    #\EXEC_STOP      ' done
