                   DAT
                   
                   '------------------------------------------------------------------------------
                   ' Float32 Assembly language routines
                   '------------------------------------------------------------------------------
                   ' flt_add   r0 = r0 + r1
                   ' flt_sub   r0 = r0 - r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1
                   '------------------------------------------------------------------------------
                   
003bc 0ef f560684b flt_sub                 xor     r1, Bit31               ' negate B
003c0 0f0 fdb00170 flt_add                 call    #_Unpack2               ' unpack two variables
003c4 0f1 ed9ffdf4           if_c_or_z     jmp     #LMM_loop               ' check for NaN or B = 0
                   
003c8 0f2 f7cf2a01                         test    flagA, #SignFlag wz     ' negate A mantissa if negative
003cc 0f3 56632f97           if_nz         neg     manA, manA
003d0 0f4 f7cf3001                         test    flagB, #SignFlag wz     ' negate B mantissa if negative
003d4 0f5 5663359a           if_nz         neg     manB, manB
                   
003d8 0f6 f600a796                         mov     t1, expA                ' align mantissas
003dc 0f7 f180a799                         sub     t1, expB
003e0 0f8 f640a653                         abs     t1, t1
003e4 0f9 f324a61f                         fle     t1, #31
003e8 0fa f25b2d99                         cmps    expA, expB wcz
003ec 0fb 10c33453           if_nz_and_nc  sar     manB, t1
003f0 0fc 40c32e53           if_nz_and_c   sar     manA, t1
003f4 0fd 46032d99           if_nz_and_c   mov     expA, expB
                   
003f8 0fe f1032f9a                         add     manA, manB              ' add the two mantissas
                   
003fc 0ff f2572e00                         cmps    manA, #0 wc             ' set sign of result
00400 100 c5472a01           if_c          or      flagA, #SignFlag
00404 101 35272a01           if_nc         andn    flagA, #SignFlag
00408 102 f6432f97                         abs     manA, manA              ' pack result and exit
0040c 103 fdb001cc pack_loop               call    #_Pack
00410 104 fd9ffda8                         jmp     #LMM_loop
                   
                   '------------------------------------------------------------------------------
                   ' flt_mul  r0 = r0 * r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
00414 105 fdb0011c flt_mul                 call    #_Unpack2               ' unpack two variables
00418 106 3d900024           if_nc         jmp     #flt_mul2               ' multiply if neither is NaN
0041c 107 f20f2cff                         cmp     expA, #255 wz           ' NaN, so check for r0 = Inf
00420 108 ad900008           if_z          jmp     #flt_mul1               ' yes - return Inf
00424 109 f20f32ff                         cmp     expB, #255 wz           ' no - check for r1 = Inf
00428 10a 5d9ffd90           if_nz         jmp     #LMM_loop               ' no - return NaN
0042c 10b f6006791 flt_mul1                mov     r0, Inf                 ' yes, r0 or r1 is Inf, so return Inf
00430 10c f5632b98                         xor     flagA, flagB            '
00434 10d f7cf2a01                         test    flagA, #SignFlag wz
00438 10e 5540664b           if_nz         or      r0, Bit31
0043c 10f fd9ffd7c                         jmp     #LMM_loop
00440 110 f5632b98 flt_mul2                xor     flagA, flagB            ' get sign of result
00444 111 f1032d99                         add     expA, expB              ' add exponents
00448 112 fd032f9a                         qmul    manA, manB
0044c 113 fd60a619                         getqy   t1
00450 114 f064a603                         shl     t1, #3                  ' justify result and exit
00454 115 f6032e53                         mov     manA, t1
