                   SVC_SD_BYTEIO    = 42 ' LMM_FIL 4
                   SVC_SD_STOPIO    = 43 ' LMM_FIL 5
                   SVC_RTC_DEBUG    = 44 ' LMM_RTC 10 or RTC_FIL 10
                   SVC_RTC_SETFREQ  = 45 ' LMM_RTC 6 or RTC_FIL 6
                   SVC_RTC_GETCLOCK = 46 ' LMM_RTC 7 or RTC_FIL 7
                   SVC_RTC_SETTIME  = 47 ' LMM_RTC 8 or RTC_FIL 8
                   SVC_RTC_GETTIME  = 48 ' LMM_RTC 9 or RTC_FIL 9
                   SVC_FLOAT_SIN    = 49 ' LMM_FLA 10
