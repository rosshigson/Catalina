00084 021 fd90019c PSHM    jmp #push_m            '$21
00088 022 fd9001d8 POPM    jmp #pop_m             '$22
0008c 023 fd90017c PSHF    jmp #push_i            '$23
00090 024 fd9002a0 RLNG    jmp #rd_long           '$24
00094 025 fd9002a4 RWRD    jmp #rd_word           '$25
00098 026 fd9002a8 RBYT    jmp #rd_byte           '$26
0009c 027 fd9002ac WLNG    jmp #wr_long           '$27
000a0 028 fd9002b0 WWRD    jmp #wr_word           '$28
000a4 029 fd9002b4 WBYT    jmp #wr_byte           '$29
                   
000a8 02a 00000000         long 0                 '$2a spare
                   
000ac 02b 00000000 PC      long 0                 '$2b ' set up during initialization
000b0 02c 00000000 SP      long 0                 '$2c ' set up during initialization
000b4 02d 00000000 FP      long 0                 '$2d
000b8 02e 00000000 RI      long 0                 '$2e
000bc 02f 00000000 BC      long 0                 '$2f
000c0 030 00000000 Save_PC long 0                 '$30
000c4 031 00000000 DBG1    long 0                 '$31 debug opAddr
000c8 032 00000000 DBG2    long 0                 '$32 debug temp
                   
000cc 033 00000000 r0      long 0                 '$33
000d0 034 00000000 r1      long 0                 '$34
000d4 035 00000000 r2      long 0                 '$35
000d8 036 00000000 r3      long 0                 '$36
000dc 037 00000000 r4      long 0                 '$37
000e0 038 00000000 r5      long 0                 '$38
000e4 039 00000000 r6      long 0                 '$39
000e8 03a 00000000 r7      long 0                 '$3a
000ec 03b 00000000 r8      long 0                 '$3b
000f0 03c 00000000 r9      long 0                 '$3c
000f4 03d 00000000 r10     long 0                 '$3d
000f8 03e 00000000 r11     long 0                 '$3e
000fc 03f 00000000 r12     long 0                 '$3f
00100 040 00000000 r13     long 0                 '$40
00104 041 00000000 r14     long 0                 '$41
00108 042 00000000 r15     long 0                 '$42
0010c 043 00000000 r16     long 0                 '$43
00110 044 00000000 r17     long 0                 '$44
00114 045 00000000 r18     long 0                 '$45
00118 046 00000000 r19     long 0                 '$46
0011c 047 00000000 r20     long 0                 '$47
00120 048 00000000 r21     long 0                 '$48
00124 049 00000000 r22     long 0                 '$49
00128 04a 00000000 r23     long 0                 '$4a
                   
0012c 04b 80000000 Bit31   long  $80000000        '$4b
00130 04c ffffffff all_1s  long  $ffffffff        '$4c
00134 04d 000000ff cviu_m1 long  $000000ff        '$4d
00138 04e 0000ffff cviu_m2 long  $0000ffff        '$4e
0013c 04f ff000000 top8    long  $ff000000        '$4f ' top 8 bits bitmask
00140 050 00ffffff low24   long  $00ffffff        '$50 ' low 24 bits bitmask
                   
00144 051 00000000         long  0                '$51 ' spare, but left to keep offsets correct
00148 052 00000000 reg     long  0                '$52 ' registry address
                   
0014c 053 00000000 t1      long  0                '$53
00150 054 00000000 t2      long  0                '$54
00154 055 00000000 t3      long  0                '$55
00158 056 00000000 t4      long  0                '$56
                   
0015c 057 00000000 ct1     long  0                '$57
00160 058 00000000 ct2     long  0                '$58
00164 059 00000000 ct3     long  0                '$59
                   
                   ' lmm_init : initialize VM - note that this code is kept 17 longs long
                   '            to make various offsets match the main kernel, where this
                   '            code may be overlaid by 17 longs of debug code once
                   '            initialization is complete - eventually, the same may be
                   '            true of this kernel as well.
                   
00168 05a          DEBUG_OVERLAY
00168 05a          lmm_init
00168 05a fb04a561         rdlong  reg,PTRA++      '$5a  1 load registry address (used later)
0016c 05b fd606a01         cogid   r2              '$5b  2 register ...
00170 05c f0646a02         shl     r2,#2           '$5c  3 ... ourselves ...
00174 05d f1006a52         add     r2,reg          '$5d  4 ... as ...
00178 05e fb006835         rdlong  r1,r2           '$5e  5 ... a ...
0017c 05f f5006850         and     r1,low24        '$5f  6 ... new ...
00180 060 fc606835         wrlong  r1,r2           '$60  7  kernel
00184 061 fb045761         rdlong  PC,PTRA++       '$61  8 load initial PC
00188 062 fb045961         rdlong  SP,PTRA++       '$62  9 load initial SP
0018c 063 fb046761         rdlong  r0,PTRA++       '$63 10 load initial LUT library size (-1)
00190 064 fb046961         rdlong  r1,PTRA++       '$64 11 load initial LUT library address
00194 065 fb046b61         rdlong  r2,PTRA++       '$65 12 load initial arg
00198 066 fd606629         setq2   r0              '$66 13 copy lut library ...
0019c 067 fb020034         rdlong  $100,r1         '$67 14 ... to LUT RAM, starting at $100
001a0 068 fd900018         jmp     #LMM_loop       '$68 15 we can now start executing LMM code
001a4 069 00000000         long    0               '$69 16
001a8 06a 00000000         long    0               '$6a 17
001ac 06b 00000000         long    0               '$6b 18
001b0 06c 00000000         long    0               '$6c 19
001b4 06d 00000000         long    0               '$6d 20
                   '
                   ' LMM_next - increment the PC then execute the instruction pointed to by the new PC
                   '
001b8 06e          LMM_next
001b8 06e f1045604         add    PC,#4            '$6e
                   '
                   ' LMM_loop - Fetch an instruction from HUB RAM to COG RAM and execute it.
                   ' The basic LMM loop is unrolled 4 times to increase speed.
                   '
001bc 06f          LMM_loop
001bc 06f fd604224         stalli                  '$6f
001c0 070 fb00e62b         rdlong LMM_1,PC         '$70
001c4 071 f1045604         add    PC,#4            '$71
001c8 072 00000000         nop                     '$72 1 needs an extra NOP
001cc 073          LMM_1
001cc 073 00000000         nop                     '$73
001d0 074 fd604024         allowi
001d4 075 fd9fffe4         jmp    #LMM_loop
                   '
                   'load_l - load the long stored at the PC into RI, incrementing the PC
                   '
001d8 076          load_l
001d8 076 fb005c2b        rdlong RI,PC         ' load the address
001dc 077 fd9fffd8        jmp    #LMM_next     ' increment PC, execute next instruction
                   '
                   'load_i - load the long at the address stored at the PC into RI,
                   '         incrementing the PC (i.e. load indirect)
                   '
001e0 078          load_i
001e0 078 fb005c2b        rdlong RI,PC         ' load the address
001e4 079 fb005c2e        rdlong RI,RI         ' load the long at that address
001e8 07a fd9fffcc        jmp    #LMM_next     ' execute next instruction
                   '
                   ' fp_ind - load the FP into RI, then add the long at the PC to result, incrementing the PC
                   '
001ec 07b          fp_ind
001ec 07b fb005c2b        rdlong RI,PC         ' load the long value
001f0 07c f1405c2d        adds   RI,FP         ' add the frame pointer
001f4 07d fd9fffc0        jmp    #LMM_next     ' increment PC, execute next instruction
                   '
                   ' push_l - push a long value in RI onto the stack, decrementing the SP
                   '
001f8 07e          push_l
001f8 07e f1845804        sub    SP,#4         ' decrement SP
001fc 07f fc605c2c        wrlong RI,SP         ' save value on stack
00200 080 fd9fffb8        jmp    #LMM_loop     ' increment PC, execute next instruction
                   '
                   ' push_a - push a value whose address is specified indirectly in a global
                   '          variable onto the stack
                   '
00204 081          push_a
00204 081 fb005c2b        rdlong RI,PC         ' load the address
00208 082 fd900008        jmp    #push_x       ' use the result as an address of the value to push
                   '
                   ' push_i - push a value whose address is specified indirectly in a frame variable
                   '          onto the stack
                   '
0020c 083          push_i
0020c 083 fb005c2b        rdlong RI,PC         ' load the long value
00210 084 f1405c2d        adds   RI,FP         ' add the frame pointer
00214 085          push_x
00214 085 fb005c2e        rdlong RI,RI         ' read the value at that address
00218 086 f1845804        sub    SP,#4         ' decrement SP
0021c 087 fc605c2c        wrlong RI,SP         ' save value on stack
00220 088 fd9fff94        jmp    #LMM_next     ' increment PC, execute next instruction
                   '
                   ' push_m - push many registers (specified by long at PC) onto the stack,
                   ' decrementing the SP before each one
                   '
00224 089          push_m
00224 089 fb005c2b        rdlong RI,PC         ' load the long value specifying the registers to push
00228 08a f600a62e        mov    t1,RI         ' save register specification for later
0022c 08b f604a839        mov    t2, #r6       ' start with ...
00230 08c f0445c06        shr    RI,#6         ' ... r6 ...
00234 08d f7cc5dff        test   RI,#$1FF wz   ' ... or ...
00238 08e a0445c09   if_z shr    RI,#9         ' ... with ...
0023c 08f a604a842   if_z mov    t2,#r15       ' ... r15 if r6 - r15 not used
00240 090          push_nxt
00240 090 f05c5c01        shr    RI,#1 wcz     ' save rX?
00244 091 c1845804  if_c  sub    SP,#4         ' yes - save ...
00248 092 c98ca800  if_c  altd   t2
0024c 093 cc60002c  if_c  wrlong 0-0,SP        ' ... register
00250 094 f104a801        add    t2,#1         ' point to next register
00254 095 5d9fffe8  if_nz jmp    #push_nxt    ' continue till all registers checked
00258 096 f1845804        sub    SP,#4         ' save ...
0025c 097 fc60a62c        wrlong t1,SP         ' .... register specification
00260 098 fd9fff54        jmp    #LMM_next     ' increment PC, execute next instruction
                   '
                   ' pop_m - pop many registers (specified by the long on top of stack)
                   ' from the stack, incremening the SP after each one
                   '
00264 099          pop_m
00264 099 fb005c2c        rdlong RI,SP         ' load ...
00268 09a f1045804        add    SP,#4         ' ... register specification to pop
0026c 09b f604a84a        mov    t2, #r23      ' start with ...
00270 09c f0645c08        shl    RI,#(32-24)   ' ... r23
00274 09d          pop_nxt
00274 09d f07c5c01        shl    RI,#1 wcz     ' load rX?
00278 09e c98ca800  if_c  altd   t2
0027c 09f cb00002c  if_c  rdlong 0-0,SP        ' ... load ...
00280 0a0 c1045804  if_c  add    SP,#4         ' ... the register
00284 0a1 ad9fff34  if_z  jmp    #LMM_loop     ' execute next instruction if all done
00288 0a2 f184a801        sub    t2,#1         ' point to previous register
0028c 0a3 fd9fffe4        jmp    #pop_nxt     ' continue till all registers popped
                   '
                   ' push_b - push a structure (size in bytes at the PC) pointed to by R0
                   '          onto the stack, decrementing the SP. Note that the source
                   '          and destination data MUST be long aligned - but this is true
                   '          for all normal structures.
                   '
00290 0a4          push_b
00290 0a4 fb005e2b        rdlong BC,PC         ' load the byte count
00294 0a5 f1045604        add    PC,#4         ' increment the PC
00298 0a6 f1045e03        add    BC,#3         ' round up BC ...
0029c 0a7 f5245e03        andn   BC,#3         ' ... to be a multiple of 4
002a0 0a8 f180582f        sub    SP,BC         ' decrement SP by rounded up size
002a4 0a9 f600a633        mov    t1,R0         ' source is in R0
002a8 0aa f600a82c        mov    t2,SP         ' destination is SP
002ac 0ab fd900018        jmp    #copy_longs   ' do the copy
                   '
                   ' copy_b - copy a structure (size in bytes at the PC)
                   '          from the address in R1 to the address in R0
                   '
002b0 0ac          copy_b
002b0 0ac fb005e2b        rdlong BC,PC         ' load the byte count
002b4 0ad f1045604        add    PC,#4         ' increment the PC
002b8 0ae f1045e03        add    BC,#3         ' round up BC ...
002bc 0af f5245e03        andn   BC,#3         ' ... to be a multiple of 4
002c0 0b0 f600a634        mov    t1,R1         ' source is in R1
002c4 0b1 f600a833        mov    t2,R0         ' destination is in R0
                   '
002c8 0b2          copy_longs
002c8 0b2 fb945fbc        tjz    BC,#LMM_loop  ' no more to copy
002cc 0b3 fb00aa53        rdlong t3,t1         ' read from src to t3
002d0 0b4 fc60aa54        wrlong t3,t2         ' write t3 to dst
002d4 0b5 f104a604        add    t1,#4         ' increment source
002d8 0b6 f104a804        add    t2,#4         ' increment destination
002dc 0b7 f1845e04        sub    BC,#4         ' decrement count ...
002e0 0b8 fd9fffe4        jmp    #copy_longs   ' ... and keep copying
                   '
                   ' new_fp - save current frame pointer and set up a new frame pointer
                   ' also calculate what SP was before data was pushed and save it in BC
                   '
002e4 0b9          new_fp
002e4 0b9 f1845804        sub    SP,#4         ' decrement the stack pointer
002e8 0ba fc605a2c        wrlong FP,SP         ' save FP to stack
002ec 0bb f6005a2c        mov    FP,SP         ' set up new FP
002f0 0bc f1045e08        add    BC,#8         ' calculate what SP was ...
002f4 0bd f1005e2d        add    BC,FP         ' ... before arguments were pushed
002f8 0be fd9ffec0        jmp    #LMM_loop     ' execute the next instruction
                   '
                   ' fp_ret - pop current frame, restore previous frame and stack pointers,
                   '          then restore the previous program counter
                   '
                   ' f_ret -  just restore the previous program counter
                   '
002fc 0bf          fp_ret
002fc 0bf fb005a2c        rdlong FP,SP         ' restore previous FP
00300 0c0 f1045804        add    SP,#4         ' increment the SP
00304 0c1          f_ret
00304 0c1 fb00562c        rdlong PC,SP         ' read the PC
00308 0c2 f1045808        add    SP,#8         ' increment the SP
0030c 0c3 fd9ffeac        jmp    #LMM_loop     ' execute the next instruction
                   '
                   ' f_call - call the routine at the address pointed to by the PC (increment the PC)
                   ' f_cali - call the routine whose address is in RI
                   '
00310 0c4          f_call
00310 0c4 fb005c2b        rdlong RI,PC         ' get the address to call
00314 0c5 f1045604        add    PC,#4         ' increment the PC (this is the return address)
00318 0c6          f_cali
00318 0c6 f1845808        sub    SP,#8         ' decrement the SP
0031c 0c7 fc60562c        wrlong PC,SP         ' save current PC to stack
00320 0c8 fd900008        jmp    #f_jmpi       ' jump to location in RI
                   '
                   ' f_jump - jump to the location at the address pointed to by PC (increment the PC)
                   '
00324 0c9          f_jump
00324 0c9 fb00562b        rdlong PC,PC         ' get the address to jump to
00328 0ca fd9ffe90        jmp    #LMM_loop     ' execute next instruction
                   '
                   ' f_jmpi - jump to the location whose address in RI
                   '
0032c 0cb          f_jmpi
0032c 0cb f600562e        mov    PC,RI         ' get the address to jump to
00330 0cc fd9ffe88        jmp    #LMM_loop     ' execute next instruction
                   '
                   ' rd_long/rd_word/rd_byte : Read long/word/byte from HUB memory at address in RI into BC.
                   '
                   ' On entry:
                   '    RI : address to read
                   ' On exit:
                   '    BC : long/word/byte read
                   '
00334 0cd          rd_long
00334 0cd fb005e2e         rdlong  BC,RI
00338 0ce fd9ffe7c         jmp     #LMM_Next
0033c 0cf          rd_word
0033c 0cf fae05e2e         rdword  BC,RI
00340 0d0 fd9ffe74         jmp     #LMM_Next
00344 0d1          rd_byte
00344 0d1 fac05e2e         rdbyte  BC,RI
00348 0d2 fd9ffe6c         jmp     #LMM_Next
                   '
                   ' wr_long/wr_word/wr_byte : Write long/word/byte to HUB memory at address in RI into BC.
                   '
                   ' On entry:
                   '    RI : address to write
                   '    BC : long/word/byte to write
                   ' On exit:
                   '    (none)
                   
0034c 0d3          wr_long
0034c 0d3 fc605e2e         wrlong  BC,RI
00350 0d4 fd9ffe64         jmp     #LMM_Next
00354 0d5          wr_word
00354 0d5 fc505e2e         wrword  BC,RI
00358 0d6 fd9ffe5c         jmp     #LMM_Next
0035c 0d7          wr_byte
0035c 0d7 fc405e2e         wrbyte  BC,RI
00360 0d8 fd9ffe54         jmp     #LMM_Next
                   
                   'fd_32s - Signed 32 bit division
                   '         Divisor --> r1
                   '         Dividend--> r0
                   '         Result --> Quotient in r0
                   '                    Remainder in r1
                   
00364 0d9          f_d32s
00364 0d9 fda00303         call    #\signed_d32     ' perform signed division
00368 0da fd9ffe50         jmp     #LMM_loop
                   
                   'f_d32u - unsigned 32 bit division
                   '         Divisor : r1
                   '         Dividend : r0
                   '         Result:
                   '             Quotient in r0
                   '             Remainder in r1
                   
0036c 0db          f_d32u
0036c 0db fda00300         call    #\unsigned_d32   ' perform signed division
00370 0dc fd9ffe48         jmp     #LMM_loop
                   
                   
                   'f_m32 - multiplication
                   '        r0 : 1st operand (32 bit)
                   '        r1 : 2nd operand (32 bit)
                   '        Result:
                   '           Product in r0 (<= 32 bit)
                   
00374 0dd          f_m32
00374 0dd fd006634         qmul   r0,r1
00378 0de fd606618         getqx  r0
0037c 0df fd9ffe3c         jmp #LMM_loop
                   
                   ' bra_xx - branch if condition is true to the address at the PC,
                   '          otherwise, just increment the PC by 4
                   '
00380 0e0          bra_z
00380 0e0 ad9fffa0   if_z  jmp    #f_jump       ' if condition true, branch is equiv to jump
00384 0e1 fd9ffe30         jmp    #LMM_next     ' increment PC, execute next instruction
00388 0e2          bra_nz
00388 0e2 5d9fff98  if_nz  jmp    #f_jump       ' if condition true, branch is equiv to jump
0038c 0e3 fd9ffe28         jmp    #LMM_next     ' increment PC, execute next instruction
00390 0e4          bra_ae
00390 0e4 3d9fff90  if_ae  jmp    #f_jump       ' if condition true, branch is equiv to jump
00394 0e5 fd9ffe20         jmp    #LMM_next     ' increment PC, execute next instruction
00398 0e6          bra_a
00398 0e6 1d9fff88  if_a   jmp    #f_jump       ' if condition true, branch is equiv to jump
0039c 0e7 fd9ffe18         jmp    #LMM_next     ' increment PC, execute next instruction
003a0 0e8          bra_be
003a0 0e8 ed9fff80  if_be  jmp    #f_jump       ' if condition true, branch is equiv to jump
003a4 0e9 fd9ffe10         jmp    #LMM_next     ' increment PC, execute next instruction
003a8 0ea          bra_b
003a8 0ea cd9fff78  if_b   jmp    #f_jump       ' if condition true, branch is equiv to jump
003ac 0eb fd9ffe08         jmp    #LMM_next     ' increment PC, execute next instruction
                   
                   ' plugin - call a plugin
                   ' On entry:
                   '       R3 = code:
                   '            - cog id if >= 128 (i.e. $80 + cog id)
                   '            - plugin type if < 128 (i.e. 0 .. 127)
                   '            - service id if < 0
                   '       R2 = data (optional pointer)
                   '
                   ' NOTES: Locks are currently only supported when invoking via a service id.
                   '        When using service id, the data should only use the lower 24 bits.
                   '
                   ' On exit:
                   '       R0 = result
                   
003b0 0ec          plugin
003b0 0ec fda0030d         call    #\do_plugin     ' do_plugin does all the work
003b4 0ed fd9ffe04         jmp     #LMM_loop
                   
                   '---------------------------- local constants ---------------------------------
                   
003b8 0ee 00000200 dlsb          long   1<<9
                   
