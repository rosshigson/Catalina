                   DEBUG_IN        = DEBUG_FLAG - 4                      ' $7BDF4 CHECK blackbox_comms.c, BlackCat_DebugCog.spin2 & catalina_blackcat.s (all targets)
                   DEBUG_OUT       = DEBUG_IN - 4                        ' $7BDF0 CHECK blackbox_comms.c, BlackCat_DebugCog.spin2 & catalina_blackcat.s (all targets)
                   DEBUG_ADDR      = DEBUG_OUT - 4                       ' $7BDEC CHECK blackbox_comms.c, BlackCat_DebugCog.spin2 & catalina_blackcat.s (all targets)
