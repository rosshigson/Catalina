01f3c 07f 5d9fffec  if_nz jmp    #pop_nxt      ' ... and continue till all registers popped
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
01f40 080 fd9fff98        jmp    #returni
                   
                   '
                   ' push_b - push a structure (size in bytes at the PC) pointed to by R0
                   '          onto the stack, decrementing the SP (PTRA). Note that the source
                   '          and destination data MUST be long aligned - but this is true
                   '          for all normal structures.
                   '
01f44 081          push_b
01f44 081 fd604224        stalli               ' disable interrupts
01f48 082 fb002bf6        rdlong BC,PA         ' load the byte count
01f4c 083 f107ec04        add    PA,#4         ' increment the PC
01f50 084 f1042a03        add    BC,#3         ' round up BC ...
01f54 085 f5242a03        andn   BC,#3         ' ... to be a multiple of 4
01f58 086 f183f015        sub    PTRA,BC       ' decrement SP (PTRA) by rounded up size
01f5c 087 f6007416        mov    t1,R0         ' source is in R0
01f60 088 f60077f8        mov    t2,PTRA       ' destination is SP (PTRA)
01f64 089 fd90001c        jmp    #copy_longs   ' do the copy
                   '
                   ' copy_b - copy a structure (size in bytes at the PC)
                   '          from the address in R1 to the address in R0
                   '
01f68 08a          copy_b
01f68 08a fd604224        stalli               ' disable interrupts
01f6c 08b fb002bf6        rdlong BC,PA         ' load the byte count
01f70 08c f107ec04        add    PA,#4         ' increment the PC
01f74 08d f1042a03        add    BC,#3         ' round up BC ...
01f78 08e f5242a03        andn   BC,#3         ' ... to be a multiple of 4
01f7c 08f f6007417        mov    t1,R1         ' source is in R1
01f80 090 f6007616        mov    t2,R0         ' destination is in R0
                   '
01f84 091          copy_longs
01f84 091 f0442a02        shr    BC,#2         ' number of times to repeat
01f88 092 fcd80815        rep    #4,BC         ' repeat the next 4 instructions BC times
01f8c 093 fb00783a        rdlong t3,t1         ' read from src to t3
01f90 094 fc60783b        wrlong t3,t2         ' write t3 to dst
01f94 095 f1047404        add    t1,#4         ' increment source
01f98 096 f1047604        add    t2,#4         ' increment destination
01f9c 097 fd9fff3c        jmp    #returni
                   '
                   ' new_fp - save current frame pointer and set up a new frame pointer
                   ' also calculate what SP (PTRA) was before data was pushed and save it in BC
                   '
01fa0 098          new_fp
01fa0 098 fd604224        stalli               ' disable interrupts
01fa4 099 fc67f35f        wrlong PTRB,--PTRA   ' save FP (PTRB) to stack
01fa8 09a f603f3f8        mov    PTRB,PTRA     ' set up new FP (PTRB)
01fac 09b f1042a08        add    BC,#8         ' calculate what SP (PTRA) was ...
01fb0 09c f1002bf9        add    BC,PTRB       ' ... before arguments were pushed
01fb4 09d fd9fff24        jmp    #returni
                   '
                   ' fp_ret - pop current frame, restore previous frame and stack pointers,
                   '          then restore the previous program counter
                   '
                   ' f_ret -  just restore the previous program counter
                   '
01fb8 09e          fp_ret
01fb8 09e fd604224        stalli               ' disable interrupts
01fbc 09f fb07f361        rdlong PTRB,PTRA++   ' restore previous FP (PTRB)
01fc0 0a0          f_ret
01fc0 0a0 fd604224        stalli               ' disable interrupts
01fc4 0a1 fb07ed00        rdlong PA,PTRA       ' read the PC
01fc8 0a2 f107f008        add    PTRA,#8       ' increment the SP (PTRA)
01fcc 0a3 fd9fff0c        jmp    #returni
                   '
                   ' f_call - call the routine at the address pointed to by the PC
                   ' f_cali - call the routine whose address is in RI
                   '
01fd0 0a4          f_call
01fd0 0a4 fd604224        stalli               ' disable interrupts
01fd4 0a5 fb0029f6        rdlong RI,PA         ' get the address to call
01fd8 0a6 f107ec04        add    PA,#4         ' increment the PC (this is the return address)
01fdc 0a7          f_cali
01fdc 0a7 fd604224        stalli               ' disable interrupts
01fe0 0a8 f187f008        sub    PTRA,#8       ' decrement the SP (PTRA)
01fe4 0a9 fc67ed00        wrlong PA,PTRA       ' save current PC to stack
01fe8 0aa fd604024        allowi               ' enable interrupts
01fec 0ab fd60282c        jmp    RI            ' execute next instruction
                   
                   'fd_32s - Signed 32 bit division
                   '         Divisor --> r1
                   '         Dividend--> r0
                   '         Result --> Quotient in r0
                   '                    Remainder in r1
                   
01ff0 0ac          f_d32s
01ff0 0ac fd604224        stalli               ' disable interrupts
01ff4 0ad fda00303        call   #\signed_d32  ' perform signed division
01ff8 0ae fd9ffee0        jmp    #returni
                   
                   ' plugin - call a plugin
                   ' On entry:
                   '       R3 = code:
                   '            - cog id if >= 128 (i.e. $80 + cog id)
                   '            - plugin type if < 128 (i.e. 0 .. 127)
                   '            - service id if < 0
                   '       R2 = data (optional pointer)
                   '
                   ' NOTES: Locks are currently only supported when invoking via a service id.
                   '        When using service id, the data should only use the lower 24 bits.
                   '
                   ' On exit:
                   '       R0 = result
                   
01ffc 0af          plugin
01ffc 0af fd604224        stalli               ' disable interrupts
02000 0b0 fda0030d        call   #\do_plugin   ' do_plugin does all the work
02004 0b1 fd9ffed4        jmp    #returni
                   
