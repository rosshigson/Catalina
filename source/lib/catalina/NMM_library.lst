                   '------------------------------------------------------------------------------
                   ' Float32 Assembly language routines
                   '------------------------------------------------------------------------------
                   ' flt_add   r0 = r0 + r1
                   ' flt_sub   r0 = r0 - r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1
                   '------------------------------------------------------------------------------
                   
02008 0b2 f5602e32 flt_sub                 xor     r1, Bit31               ' negate B
0200c 0b3 fd604224 flt_add                 stalli
02010 0b4 fdb00184                         call    #_Unpack2               ' unpack two variables
02014 0b5 ed9ffec4           if_c_or_z     jmp     #returni                ' check for NaN or B = 0
                   
02018 0b6 f7cebc01                         test    flagA, #SignFlag wz     ' negate A mantissa if negative
0201c 0b7 5662c160           if_nz         neg     manA, manA
02020 0b8 f7cec201                         test    flagB, #SignFlag wz     ' negate B mantissa if negative
02024 0b9 5662c763           if_nz         neg     manB, manB
                   
02028 0ba f600755f                         mov     t1, expA                ' align mantissas
0202c 0bb f1807562                         sub     t1, expB
02030 0bc f640743a                         abs     t1, t1
02034 0bd f324741f                         fle     t1, #31
02038 0be f25abf62                         cmps    expA, expB wcz
0203c 0bf 10c2c63a           if_nz_and_nc  sar     manB, t1
02040 0c0 40c2c03a           if_nz_and_c   sar     manA, t1
02044 0c1 4602bf62           if_nz_and_c   mov     expA, expB
                   
02048 0c2 f102c163                         add     manA, manB              ' add the two mantissas
0204c 0c3 f256c000                         cmps    manA, #0 wc             ' set sign of result
02050 0c4 c546bc01           if_c          or      flagA, #SignFlag
02054 0c5 3526bc01           if_nc         andn    flagA, #SignFlag
02058 0c6 f642c160                         abs     manA, manA              ' pack result and exit
0205c 0c7 fdb001e0 pack_rtni               call    #_Pack
02060 0c8 fd9ffe78                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' flt_mul  r0 = r0 * r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
02064 0c9 fd604224 flt_mul                 stalli
02068 0ca fdb0012c                         call    #_Unpack2               ' unpack two variables
0206c 0cb 3d900024           if_nc         jmp     #flt_mul2               ' multiply if neither is NaN
02070 0cc f20ebeff                         cmp     expA, #255 wz           ' NaN, so check for r0 = Inf
02074 0cd ad900008           if_z          jmp     #flt_mul1               ' yes - return Inf
02078 0ce f20ec4ff                         cmp     expB, #255 wz           ' no - check for r1 = Inf
0207c 0cf 5d9ffe5c           if_nz         jmp     #returni                ' no - return NaN
02080 0d0 f6002d5a flt_mul1                mov     r0, Inf                 ' yes, r0 or r1 is Inf, so return Inf
02084 0d1 f562bd61                         xor     flagA, flagB            '
02088 0d2 f7cebc01                         test    flagA, #SignFlag wz
0208c 0d3 55402c32           if_nz         or      r0, Bit31
02090 0d4 fd9ffe48                         jmp     #returni
02094 0d5 f562bd61 flt_mul2                xor     flagA, flagB            ' get sign of result
02098 0d6 f102bf62                         add     expA, expB              ' add exponents
0209c 0d7 fd02c163                         qmul    manA, manB
020a0 0d8 fd607419                         getqy   t1
020a4 0d9 f0647403                         shl     t1, #3                  ' justify result and exit
020a8 0da f602c03a                         mov     manA, t1
020ac 0db fd9fffac                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' flt_div  r0 = r0 / r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
020b0 0dc fd604224 flt_div                 stalli
020b4 0dd fdb000e0                         call    #_Unpack2               ' unpack two variables
020b8 0de e6002d59           if_c_or_z     mov     r0, NaN                 ' check for NaN or divide by 0
020bc 0df ed9ffe1c           if_c_or_z     jmp     #returni
                   
020c0 0e0 f562bd61                         xor     flagA, flagB            ' get sign of result
020c4 0e1 f182bf62                         sub     expA, expB              ' subtract exponents
                   
020c8 0e2 f046c001                         shr     manA, #1
020cc 0e3 fd62c028                         setq    manA
020d0 0e4 fd180163                         qdiv    #0, manB
020d4 0e5 fd62c018                         getqx   manA
020d8 0e6 f046c002                         shr     manA, #2
020dc 0e7 fd9fff7c                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' flt_int  r0 = float(r0)
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
020e0 0e8 fd604224 flt_int                 stalli
020e4 0e9 f602bc16                         mov     flagA, r0               ' get integer value
020e8 0ea f6042c00                         mov     r0, #0                  ' set initial result to zero
020ec 0eb f64ac15e                         abs     manA, flagA wz          ' get absolute value of integer
020f0 0ec ad9ffde8           if_z          jmp     #returni                ' if zero, exit
020f4 0ed f046bc1f                         shr     flagA, #31              ' set sign flag
020f8 0ee f606be1f                         mov     expA, #31               ' set initial value for exponent
020fc 0ef f076c001 normalize_1             shl     manA, #1 wc             ' normalize the mantissa
02100 0f0 3186be01           if_nc         sub     expA, #1                ' adjust exponent
02104 0f1 3d9ffff4           if_nc         jmp     #normalize_1
02108 0f2 f086c001                         rcr     manA, #1                ' justify mantissa
0210c 0f3 f046c002                         shr     manA, #2
02110 0f4 fd9fff48                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' int_flt  r0 = fix(r0)
                   ' changes: r0, flagA, expA, manA, t1
                   '------------------------------------------------------------------------------
                   
02114 0f5 fd604224 int_flt                 stalli
02118 0f6 f6047400                         mov     t1, #0                  ' set for no rounding
                   '                        jmp     #fix
                   
                   'rnd_flt                 mov     t1, #1                  ' set for rounding
                   
0211c 0f7 fdb000a8 fix                     call    #_Unpack                ' unpack floating point value
02120 0f8 cd9ffdb8           if_c          jmp     #returni                ' check for NaN
02124 0f9 f066c002                         shl     manA, #2                ' left justify mantissa
02128 0fa f6042c00                         mov     r0, #0                  ' initialize result to zero
0212c 0fb f662bf5f                         neg     expA, expA              ' adjust for exponent value
02130 0fc f10ebe1e                         add     expA, #30 wz
02134 0fd f256be20                         cmps    expA, #32 wc
02138 0fe bd9ffda0           if_nc_or_z    jmp     #returni
0213c 0ff f042c15f                         shr     manA, expA
                   
02140 100 f102c03a                         add     manA, t1                ' round up 1/2 lsb
02144 101 f046c001                         shr     manA, #1
                   
02148 102 f7cebc01                         test    flagA, #signFlag wz     ' check sign and exit
0214c 103 f3e02d60                         sumnz   r0, manA
02150 104 fd9ffd88                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' flt_cmp   set Z and C flags for r0 - r1
                   ' changes: status, t1
                   '------------------------------------------------------------------------------
                   
02154 105 fd604224 flt_cmp                 stalli
02158 106 f6007416                         mov     t1, r0               ' compare signs
0215c 107 f5607417                         xor     t1, r1
02160 108 f5087432                         and     t1, Bit31 wz
02164 109 ad900018           if_z          jmp     #cmp1                  ' same, then compare magnitude
                   
02168 10a f6007416                         mov     t1, r0               ' check for +0 or -0
0216c 10b f5407417                         or      t1, r1
02170 10c f5387432                         andn    t1, Bit31 wcz
02174 10d ad9ffd64           if_z          jmp     #returni
                   
02178 10e f7d02c32                         test    r0, Bit31 wc         ' compare signs
0217c 10f fd9ffd5c                         jmp     #returni
                   
02180 110 f7c82c32 cmp1                    test    r0, Bit31 wz         ' check signs
02184 111 5d900008           if_nz         jmp     #cmp2
02188 112 f2182c17                         cmp     r0, r1 wcz
0218c 113 fd9ffd4c                         jmp     #returni
02190 114 f2182e16 cmp2                    cmp     r1, r0 wcz           ' reverse test if negative
02194 115 fd9ffd44                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' input:   r0        32-bit floating point value
                   '          r1        32-bit floating point value
                   ' output:  flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   '          flagB        r1 flag bits (Nan, Infinity, Zero, Sign)
                   '          expB         r1 exponent (no bias)
                   '          manB         r1 mantissa (aligned to bit 29)
                   '          C flag       set if r0 or r1 is NaN
                   '          Z flag       set if r1 is zero
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1
                   '------------------------------------------------------------------------------
                   
02198 116 f6007416 _Unpack2                mov     t1, r0               ' save A
0219c 117 f6002c17                         mov     r0, r1               ' unpack B to A
021a0 118 fdb00024                         call    #_Unpack
                   
021a4 119 f6002e16                         mov     r1, r0               ' save B variables
021a8 11a f602c35e                         mov     flagB, flagA
021ac 11b f602c55f                         mov     expB, expA
021b0 11c f602c760                         mov     manB, manA
                   
021b4 11d f6002c3a                         mov     r0, t1               ' unpack A
021b8 11e fdb0000c                         call    #_Unpack
021bc 11f 37cec208           if_nc         test    flagB, #NanFlag wz
021c0 120 1d75e06f           if_nc_and_nz  modc    _set wc
021c4 121 020ec600           _ret_         cmp     manB, #0 wz          ' set Z flag
                   
                   '------------------------------------------------------------------------------
                   ' input:   r0        32-bit floating point value
                   ' output:  flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   '          C flag       set if r0 is NaN
                   '          Z flag       set if r0 is zero
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
021c8 122 f602bc16 _Unpack                 mov     flagA, r0            ' get sign
021cc 123 f046bc1f                         shr     flagA, #31
021d0 124 f602c016                         mov     manA, r0             ' get mantissa
021d4 125 f502c15c                         and     manA, Mask23
021d8 126 f602be16                         mov     expA, r0             ' get exponent
021dc 127 f066be01                         shl     expA, #1
021e0 128 f04ebe18                         shr     expA, #24 wz
021e4 129 ad900014           if_z          jmp     #zeroSubnormal         ' check for zero or subnormal
021e8 12a f20ebeff                         cmp     expA, #255 wz           ' check if finite
021ec 12b 5d90003c           if_nz         jmp     #finite
021f0 12c f6002d59                         mov     r0, NaN              ' no, then return NaN
021f4 12d f546bc08                         or      flagA, #NaNFlag
021f8 12e fd90003c                         jmp     #U_exit2
                   
021fc 12f f6007b60 zeroSubnormal           mov     t4, manA
02200 130 f5487b5f                         or      t4, expA wz             ' check for zero
02204 131 5d90000c           if_nz         jmp     #subnorm
02208 132 f546bc02                         or      flagA, #ZeroFlag        ' yes, then set zero flag
0220c 133 f666be96                         neg     expA, #150              ' set exponent and exit
02210 134 fd900024                         jmp     #U_exit2
                   
02214 135 f066c007 subnorm                 shl     manA, #7                ' fix justification for subnormals
02218 136 f7cac15d subnorm2                test    manA, Bit29 wz
0221c 137 5d900014           if_nz         jmp     #U_exit1
02220 138 f066c001                         shl     manA, #1
02224 139 f186be01                         sub     expA, #1
02228 13a fd9fffec                         jmp     #subnorm2
                   
0222c 13b f066c006 finite                  shl     manA, #6                ' justify mantissa to bit 29
02230 13c f542c15d                         or      manA, Bit29             ' add leading one bit
                   
02234 13d f186be7f U_exit1                 sub     expA, #127              ' remove bias from exponent
02238 13e f7d6bc08 U_exit2                 test    flagA, #NaNFlag wc      ' set C flag
0223c 13f 020ec000           _ret_         cmp     manA, #0 wz             ' set Z flag
                   
                   '------------------------------------------------------------------------------
                   ' input:   flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   ' output:  r0        32-bit floating point value
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
02240 140 f20ec000 _Pack                   cmp     manA, #0 wz             ' check for zero
02244 141 a606be00           if_z          mov     expA, #0
02248 142 ad900040           if_z          jmp     #P_exit3
                   
0224c 143 f076c001 normalize_2             shl     manA, #1 wc             ' normalize the mantissa
02250 144 3186be01           if_nc         sub     expA, #1                ' adjust exponent
02254 145 3d9ffff4           if_nc         jmp     #normalize_2
                   
02258 146 f106be02                         add     expA, #2                ' adjust exponent
0225c 147 f116c100                         add     manA, #$100 wc          ' round up by 1/2 lsb
02260 148 c106be01           if_c          add     expA, #1
                   
02264 149 f106be7f                         add     expA, #127              ' add bias to exponent
02268 14a f342bf5b                         fges    expA, Minus23
0226c 14b f366beff                         fles    expA, #255
                   
02270 14c f256be01                         cmps    expA, #1 wc             ' check for subnormals
02274 14d 3d900014           if_nc         jmp     #P_exit3
                   
02278 14e f546c001 subnormal               or      manA, #1                ' adjust mantissa
0227c 14f f006c001                         ror     manA, #1
                   
02280 150 f662bf5f                         neg     expA, expA
02284 151 f042c15f                         shr     manA, expA
02288 152 f606be00                         mov     expA, #0                ' biased exponent = 0
                   
0228c 153 f6002d60 P_exit3                 mov     r0, manA             ' bits 22:0 mantissa
02290 154 f0442c09                         shr     r0, #9
02294 155 f066be17                         shl     expA, #23
02298 156 f5402d5f                         or      r0, expA
0229c 157 f066bc1f                         shl     flagA, #31
022a0 158 05402d5e           _ret_          or      r0, flagA            ' bit 31 sign
                   
022a4 159 7fffffff NaN                     long    $7FFF_FFFF
022a8 15a 7f800000 Inf                     long    $7F80_0000
022ac 15b ffffffe9 Minus23                 long    -23
022b0 15c 007fffff Mask23                  long    $007F_FFFF
022b4 15d 20000000 Bit29                   long    $2000_0000
                   
022b8 15e 00000000 flagA                   long    0
022bc 15f 00000000 expA                    long    0
022c0 160 00000000 manA                    long    0
                   
022c4 161 00000000 flagB                   long    0
022c8 162 00000000 expB                    long    0
022cc 163 00000000 manB                    long    0
                   
