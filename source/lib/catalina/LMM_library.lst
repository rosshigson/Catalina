01ff8 0b2 fb945fbc        tjz    BC,#LMM_loop  ' no more to copy
01ffc 0b3 fb00aa53        rdlong t3,t1         ' read from src to t3
02000 0b4 fc60aa54        wrlong t3,t2         ' write t3 to dst
02004 0b5 f104a604        add    t1,#4         ' increment source
02008 0b6 f104a804        add    t2,#4         ' increment destination
0200c 0b7 f1845e04        sub    BC,#4         ' decrement count ...
02010 0b8 fd9fffe4        jmp    #copy_longs   ' ... and keep copying
                   '
                   ' new_fp - save current frame pointer and set up a new frame pointer
                   ' also calculate what SP was before data was pushed and save it in BC
                   '
02014 0b9          new_fp
02014 0b9 f1845804        sub    SP,#4         ' decrement the stack pointer
02018 0ba fc605a2c        wrlong FP,SP         ' save FP to stack
0201c 0bb f6005a2c        mov    FP,SP         ' set up new FP
02020 0bc f1045e08        add    BC,#8         ' calculate what SP was ...
02024 0bd f1005e2d        add    BC,FP         ' ... before arguments were pushed
02028 0be fd9ffec0        jmp    #LMM_loop     ' execute the next instruction
                   '
                   ' fp_ret - pop current frame, restore previous frame and stack pointers,
                   '          then restore the previous program counter
                   '
                   ' f_ret -  just restore the previous program counter
                   '
0202c 0bf          fp_ret
0202c 0bf fb005a2c        rdlong FP,SP         ' restore previous FP
02030 0c0 f1045804        add    SP,#4         ' increment the SP
02034 0c1          f_ret
02034 0c1 fb00562c        rdlong PC,SP         ' read the PC
02038 0c2 f1045808        add    SP,#8         ' increment the SP
0203c 0c3 fd9ffeac        jmp    #LMM_loop     ' execute the next instruction
                   '
                   ' f_call - call the routine at the address pointed to by the PC (increment the PC)
                   ' f_cali - call the routine whose address is in RI
                   '
02040 0c4          f_call
02040 0c4 fb005c2b        rdlong RI,PC         ' get the address to call
02044 0c5 f1045604        add    PC,#4         ' increment the PC (this is the return address)
02048 0c6          f_cali
02048 0c6 f1845808        sub    SP,#8         ' decrement the SP
0204c 0c7 fc60562c        wrlong PC,SP         ' save current PC to stack
02050 0c8 fd900008        jmp    #f_jmpi       ' jump to location in RI
                   '
                   ' f_jump - jump to the location at the address pointed to by PC (increment the PC)
                   '
02054 0c9          f_jump
02054 0c9 fb00562b        rdlong PC,PC         ' get the address to jump to
02058 0ca fd9ffe90        jmp    #LMM_loop     ' execute next instruction
                   '
                   ' f_jmpi - jump to the location whose address in RI
                   '
0205c 0cb          f_jmpi
0205c 0cb f600562e        mov    PC,RI         ' get the address to jump to
02060 0cc fd9ffe88        jmp    #LMM_loop     ' execute next instruction
                   '
                   ' rd_long/rd_word/rd_byte : Read long/word/byte from HUB memory at address in RI into BC.
                   '
                   ' On entry:
                   '    RI : address to read
                   ' On exit:
                   '    BC : long/word/byte read
                   '
02064 0cd          rd_long
02064 0cd fb005e2e         rdlong  BC,RI
02068 0ce fd9ffe7c         jmp     #LMM_Next
0206c 0cf          rd_word
0206c 0cf fae05e2e         rdword  BC,RI
02070 0d0 fd9ffe74         jmp     #LMM_Next
02074 0d1          rd_byte
02074 0d1 fac05e2e         rdbyte  BC,RI
02078 0d2 fd9ffe6c         jmp     #LMM_Next
                   '
                   ' wr_long/wr_word/wr_byte : Write long/word/byte to HUB memory at address in RI into BC.
                   '
                   ' On entry:
                   '    RI : address to write
                   '    BC : long/word/byte to write
                   ' On exit:
                   '    (none)
                   
0207c 0d3          wr_long
0207c 0d3 fc605e2e         wrlong  BC,RI
02080 0d4 fd9ffe64         jmp     #LMM_Next
02084 0d5          wr_word
02084 0d5 fc505e2e         wrword  BC,RI
02088 0d6 fd9ffe5c         jmp     #LMM_Next
0208c 0d7          wr_byte
0208c 0d7 fc405e2e         wrbyte  BC,RI
02090 0d8 fd9ffe54         jmp     #LMM_Next
                   
                   'fd_32s - Signed 32 bit division
                   '         Divisor --> r1
                   '         Dividend--> r0
                   '         Result --> Quotient in r0
                   '                    Remainder in r1
                   
02094 0d9          f_d32s
02094 0d9 fda00303         call    #\signed_d32     ' perform signed division
02098 0da fd9ffe50         jmp     #LMM_loop
                   
                   'f_d32u - unsigned 32 bit division
                   '         Divisor : r1
                   '         Dividend : r0
                   '         Result:
                   '             Quotient in r0
                   '             Remainder in r1
                   
0209c 0db          f_d32u
0209c 0db fda00300         call    #\unsigned_d32   ' perform signed division
020a0 0dc fd9ffe48         jmp     #LMM_loop
                   
                   
                   'f_m32 - multiplication
                   '        r0 : 1st operand (32 bit)
                   '        r1 : 2nd operand (32 bit)
                   '        Result:
                   '           Product in r0 (<= 32 bit)
                   
020a4 0dd          f_m32
020a4 0dd fd006634         qmul   r0,r1
020a8 0de fd606618         getqx  r0
020ac 0df fd9ffe3c         jmp #LMM_loop
                   
                   ' bra_xx - branch if condition is true to the address at the PC,
                   '          otherwise, just increment the PC by 4
                   '
020b0 0e0          bra_z
020b0 0e0 ad9fffa0   if_z  jmp    #f_jump       ' if condition true, branch is equiv to jump
020b4 0e1 fd9ffe30         jmp    #LMM_next     ' increment PC, execute next instruction
020b8 0e2          bra_nz
020b8 0e2 5d9fff98  if_nz  jmp    #f_jump       ' if condition true, branch is equiv to jump
020bc 0e3 fd9ffe28         jmp    #LMM_next     ' increment PC, execute next instruction
020c0 0e4          bra_ae
020c0 0e4 3d9fff90  if_ae  jmp    #f_jump       ' if condition true, branch is equiv to jump
020c4 0e5 fd9ffe20         jmp    #LMM_next     ' increment PC, execute next instruction
020c8 0e6          bra_a
020c8 0e6 1d9fff88  if_a   jmp    #f_jump       ' if condition true, branch is equiv to jump
020cc 0e7 fd9ffe18         jmp    #LMM_next     ' increment PC, execute next instruction
020d0 0e8          bra_be
020d0 0e8 ed9fff80  if_be  jmp    #f_jump       ' if condition true, branch is equiv to jump
020d4 0e9 fd9ffe10         jmp    #LMM_next     ' increment PC, execute next instruction
020d8 0ea          bra_b
020d8 0ea cd9fff78  if_b   jmp    #f_jump       ' if condition true, branch is equiv to jump
020dc 0eb fd9ffe08         jmp    #LMM_next     ' increment PC, execute next instruction
                   
                   ' plugin - call a plugin
                   ' On entry:
                   '       R3 = code:
                   '            - cog id if >= 128 (i.e. $80 + cog id)
                   '            - plugin type if < 128 (i.e. 0 .. 127)
                   '            - service id if < 0
                   '       R2 = data (optional pointer)
                   '
                   ' NOTES: Locks are currently only supported when invoking via a service id.
                   '        When using service id, the data should only use the lower 24 bits.
                   '
                   ' On exit:
                   '       R0 = result
                   
020e0 0ec          plugin
020e0 0ec fda0030d         call    #\do_plugin     ' do_plugin does all the work
020e4 0ed fd9ffe04         jmp     #LMM_loop
                   
                   '---------------------------- local constants ---------------------------------
                   
020e8 0ee 00000200 dlsb          long   1<<9
                   
