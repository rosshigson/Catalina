                   DAT
                   
                   '------------------------------------------------------------------------------
                   ' Float32 Assembly language routines
                   '------------------------------------------------------------------------------
                   ' flt_add   r0 = r0 + r1
                   ' flt_sub   r0 = r0 - r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1
                   '------------------------------------------------------------------------------
                   
020ec 0ef f560684b flt_sub                 xor     r1, Bit31               ' negate B
020f0 0f0 fdb00170 flt_add                 call    #_Unpack2               ' unpack two variables
020f4 0f1 ed9ffdf4           if_c_or_z     jmp     #LMM_loop               ' check for NaN or B = 0
                   
020f8 0f2 f7cf2a01                         test    flagA, #SignFlag wz     ' negate A mantissa if negative
020fc 0f3 56632f97           if_nz         neg     manA, manA
02100 0f4 f7cf3001                         test    flagB, #SignFlag wz     ' negate B mantissa if negative
02104 0f5 5663359a           if_nz         neg     manB, manB
                   
02108 0f6 f600a796                         mov     t1, expA                ' align mantissas
0210c 0f7 f180a799                         sub     t1, expB
02110 0f8 f640a653                         abs     t1, t1
02114 0f9 f324a61f                         fle     t1, #31
02118 0fa f25b2d99                         cmps    expA, expB wcz
0211c 0fb 10c33453           if_nz_and_nc  sar     manB, t1
02120 0fc 40c32e53           if_nz_and_c   sar     manA, t1
02124 0fd 46032d99           if_nz_and_c   mov     expA, expB
                   
02128 0fe f1032f9a                         add     manA, manB              ' add the two mantissas
                   
0212c 0ff f2572e00                         cmps    manA, #0 wc             ' set sign of result
02130 100 c5472a01           if_c          or      flagA, #SignFlag
02134 101 35272a01           if_nc         andn    flagA, #SignFlag
02138 102 f6432f97                         abs     manA, manA              ' pack result and exit
0213c 103 fdb001cc pack_loop               call    #_Pack
02140 104 fd9ffda8                         jmp     #LMM_loop
                   
                   '------------------------------------------------------------------------------
                   ' flt_mul  r0 = r0 * r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
02144 105 fdb0011c flt_mul                 call    #_Unpack2               ' unpack two variables
02148 106 3d900024           if_nc         jmp     #flt_mul2               ' multiply if neither is NaN
0214c 107 f20f2cff                         cmp     expA, #255 wz           ' NaN, so check for r0 = Inf
02150 108 ad900008           if_z          jmp     #flt_mul1               ' yes - return Inf
02154 109 f20f32ff                         cmp     expB, #255 wz           ' no - check for r1 = Inf
02158 10a 5d9ffd90           if_nz         jmp     #LMM_loop               ' no - return NaN
0215c 10b f6006791 flt_mul1                mov     r0, Inf                 ' yes, r0 or r1 is Inf, so return Inf
02160 10c f5632b98                         xor     flagA, flagB            '
02164 10d f7cf2a01                         test    flagA, #SignFlag wz
02168 10e 5540664b           if_nz         or      r0, Bit31
0216c 10f fd9ffd7c                         jmp     #LMM_loop
02170 110 f5632b98 flt_mul2                xor     flagA, flagB            ' get sign of result
02174 111 f1032d99                         add     expA, expB              ' add exponents
02178 112 fd032f9a                         qmul    manA, manB
0217c 113 fd60a619                         getqy   t1
02180 114 f064a603                         shl     t1, #3                  ' justify result and exit
02184 115 f6032e53                         mov     manA, t1
02188 116 fd9fffb0                         jmp     #pack_loop
                   
                   '------------------------------------------------------------------------------
                   ' flt_div  r0 = r0 / r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
0218c 117 fdb000d4 flt_div                 call    #_Unpack2               ' unpack two variables
02190 118 e6006790           if_c_or_z     mov     r0, NaN                 ' check for NaN or divide by 0
02194 119 ed9ffd54           if_c_or_z     jmp     #LMM_loop
                   
02198 11a f5632b98                         xor     flagA, flagB            ' get sign of result
0219c 11b f1832d99                         sub     expA, expB              ' subtract exponents
021a0 11c f0472e01                         shr     manA, #1
021a4 11d fd632e28                         setq    manA
021a8 11e fd18019a                         qdiv    #0, manB
021ac 11f fd632e18                         getqx   manA
021b0 120 f0472e02                         shr     manA, #2
021b4 121 fd9fff84                         jmp     #pack_loop
                   
                   '------------------------------------------------------------------------------
                   ' flt_int  r0 = float(r0)
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
021b8 122 f6032a33 flt_int                 mov     flagA, r0               ' get integer value
021bc 123 f6046600                         mov     r0, #0                  ' set initial result to zero
021c0 124 f64b2f95                         abs     manA, flagA wz          ' get absolute value of integer
021c4 125 ad9ffd24           if_z          jmp     #LMM_loop               ' if zero, exit
021c8 126 f0472a1f                         shr     flagA, #31              ' set sign flag
021cc 127 f6072c1f                         mov     expA, #31               ' set initial value for exponent
021d0 128 f0772e01 normalize_1             shl     manA, #1 wc             ' normalize the mantissa
021d4 129 31872c01           if_nc         sub     expA, #1                ' adjust exponent
021d8 12a 3d9ffff4           if_nc         jmp     #normalize_1
021dc 12b f0872e01                         rcr     manA, #1                ' justify mantissa
021e0 12c f0472e02                         shr     manA, #2
021e4 12d fd9fff54                         jmp     #pack_loop
                   
                   '------------------------------------------------------------------------------
                   ' int_flt  r0 = fix(r0)
                   ' changes: r0, flagA, expA, manA, t1
                   '------------------------------------------------------------------------------
                   
021e8 12e f604a600 int_flt                  mov     t1, #0                  ' set for no rounding
                   '                        jmp     #fix
                   
                   'rnd_flt                 mov     t1, #1                  ' set for rounding
                   
021ec 12f fdb000a4 fix                     call    #_Unpack                ' unpack floating point value
021f0 130 cd9ffcf8           if_c          jmp     #LMM_loop               ' check for NaN
021f4 131 f0672e02                         shl     manA, #2                ' left justify mantissa
021f8 132 f6046600                         mov     r0, #0                  ' initialize result to zero
021fc 133 f6632d96                         neg     expA, expA              ' adjust for exponent value
02200 134 f10f2c1e                         add     expA, #30 wz
02204 135 f2572c20                         cmps    expA, #32 wc
02208 136 bd9ffce0           if_nc_or_z    jmp     #LMM_loop
0220c 137 f0432f96                         shr     manA, expA
                   
02210 138 f1032e53                         add     manA, t1                ' round up 1/2 lsb
02214 139 f0472e01                         shr     manA, #1
                   
02218 13a f7cf2a01                         test    flagA, #signFlag wz     ' check sign and exit
0221c 13b f3e06797                         sumnz   r0, manA
02220 13c fd9ffcc8                         jmp     #LMM_loop
                   
                   '------------------------------------------------------------------------------
                   ' flt_cmp   set Z and C flags for r0 - r1
                   ' changes: status, t1
                   '------------------------------------------------------------------------------
                   
02224 13d f600a633 flt_cmp                 mov     t1, r0               ' compare signs
02228 13e f560a634                         xor     t1, r1
0222c 13f f508a64b                         and     t1, Bit31 wz
02230 140 ad900018           if_z          jmp     #cmp1                  ' same, then compare magnitude
                   
02234 141 f600a633                         mov     t1, r0               ' check for +0 or -0
02238 142 f540a634                         or      t1, r1
0223c 143 f538a64b                         andn    t1, Bit31 wcz
02240 144 ad9ffca8           if_z          jmp     #LMM_loop
                   
02244 145 f7d0664b                         test    r0, Bit31 wc         ' compare signs
02248 146 fd9ffca0                         jmp     #LMM_loop
                   
0224c 147 f7c8664b cmp1                    test    r0, Bit31 wz         ' check signs
02250 148 5d900008           if_nz         jmp     #cmp2
02254 149 f2186634                         cmp     r0, r1 wcz
02258 14a fd9ffc90                         jmp     #LMM_loop
0225c 14b f2186833 cmp2                    cmp     r1, r0 wcz           ' reverse test if negative
02260 14c fd9ffc88                         jmp     #LMM_loop
                   
                   '------------------------------------------------------------------------------
                   ' input:   r0        32-bit floating point value
                   '          r1        32-bit floating point value
                   ' output:  flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   '          flagB        r1 flag bits (Nan, Infinity, Zero, Sign)
                   '          expB         r1 exponent (no bias)
                   '          manB         r1 mantissa (aligned to bit 29)
                   '          C flag       set if r0 or r1 is NaN
                   '          Z flag       set if r1 is zero
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1
                   '------------------------------------------------------------------------------
                   
02264 14d f600a633 _Unpack2                mov     t1, r0               ' save A
02268 14e f6006634                         mov     r0, r1               ' unpack B to A
0226c 14f fdb00024                         call    #_Unpack
02270 150 f6006833                         mov     r1, r0               ' save B variables
02274 151 f6033195                         mov     flagB, flagA
02278 152 f6033396                         mov     expB, expA
0227c 153 f6033597                         mov     manB, manA
02280 154 f6006653                         mov     r0, t1               ' unpack A
02284 155 fdb0000c                         call    #_Unpack
02288 156 37cf3008           if_nc         test    flagB, #NanFlag wz
0228c 157 1d75e06f           if_nc_and_nz  modc    _set wc
02290 158 020f3400           _ret_         cmp     manB, #0 wz          ' set Z flag
                   
                   '------------------------------------------------------------------------------
                   ' input:   r0        32-bit floating point value
                   ' output:  flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   '          C flag       set if r0 is NaN
                   '          Z flag       set if r0 is zero
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
02294 159 f6032a33 _Unpack                 mov     flagA, r0            ' get sign
02298 15a f0472a1f                         shr     flagA, #31
0229c 15b f6032e33                         mov     manA, r0             ' get mantissa
022a0 15c f5032f93                         and     manA, Mask23
022a4 15d f6032c33                         mov     expA, r0             ' get exponent
022a8 15e f0672c01                         shl     expA, #1
022ac 15f f04f2c18                         shr     expA, #24 wz
022b0 160 ad900014           if_z          jmp     #zeroSubnormal         ' check for zero or subnormal
022b4 161 f20f2cff                         cmp     expA, #255 wz           ' check if finite
022b8 162 5d90003c           if_nz         jmp     #finite
022bc 163 f6006790                         mov     r0, NaN              ' no, then return NaN
022c0 164 f5472a08                         or      flagA, #NaNFlag
022c4 165 fd90003c                         jmp     #U_exit2
                   
022c8 166 f600ad97 zeroSubnormal          mov     t4, manA
022cc 167 f548ad96                         or      t4, expA wz             ' check for zero
022d0 168 5d90000c           if_nz         jmp     #subnorm
022d4 169 f5472a02                         or      flagA, #ZeroFlag        ' yes, then set zero flag
022d8 16a f6672c96                         neg     expA, #150              ' set exponent and exit
022dc 16b fd900024                         jmp     #U_exit2
                   
022e0 16c f0672e07 subnorm                 shl     manA, #7                ' fix justification for subnormals
022e4 16d f7cb2f94 subnorm2                test    manA, Bit29 wz
022e8 16e 5d900014           if_nz         jmp     #U_exit1
022ec 16f f0672e01                         shl     manA, #1
022f0 170 f1872c01                         sub     expA, #1
022f4 171 fd9fffec                         jmp     #subnorm2
                   
022f8 172 f0672e06 finite                  shl     manA, #6                ' justify mantissa to bit 29
022fc 173 f5432f94                         or      manA, Bit29             ' add leading one bit
                   
02300 174 f1872c7f U_exit1                 sub     expA, #127              ' remove bias from exponent
02304 175 f7d72a08 U_exit2                 test    flagA, #NaNFlag wc      ' set C flag
02308 176 020f2e00           _ret_         cmp     manA, #0 wz             ' set Z flag
                   
                   '------------------------------------------------------------------------------
                   ' input:   flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   ' output:  r0        32-bit floating point value
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
0230c 177 f20f2e00 _Pack                   cmp     manA, #0 wz             ' check for zero
02310 178 a6072c00           if_z          mov     expA, #0
02314 179 ad900040           if_z          jmp     #P_exit3
                   
02318 17a f0772e01 normalize_2             shl     manA, #1 wc             ' normalize the mantissa
0231c 17b 31872c01           if_nc         sub     expA, #1                ' adjust exponent
02320 17c 3d9ffff4           if_nc         jmp     #normalize_2
                   
02324 17d f1072c02                         add     expA, #2                ' adjust exponent
02328 17e f1172f00                         add     manA, #$100 wc          ' round up by 1/2 lsb
0232c 17f c1072c01           if_c          add     expA, #1
                   
02330 180 f1072c7f                         add     expA, #127              ' add bias to exponent
02334 181 f3432d92                         fges    expA, Minus23
02338 182 f3672cff                         fles    expA, #255
                   
0233c 183 f2572c01                         cmps    expA, #1 wc             ' check for subnormals
02340 184 3d900014           if_nc         jmp     #P_exit3
                   
02344 185 f5472e01 subnormal               or      manA, #1                ' adjust mantissa
02348 186 f0072e01                         ror     manA, #1
                   
0234c 187 f6632d96                         neg     expA, expA
02350 188 f0432f96                         shr     manA, expA
02354 189 f6072c00                         mov     expA, #0                ' biased exponent = 0
                   
02358 18a f6006797 P_exit3                 mov     r0, manA             ' bits 22:0 mantissa
0235c 18b f0446609                         shr     r0, #9
02360 18c f0672c17                         shl     expA, #23
02364 18d f5406796                         or      r0, expA
02368 18e f0672a1f                         shl     flagA, #31
0236c 18f 05406795          _ret_          or      r0, flagA            ' bit 31 sign
                   
02370 190 7fffffff NaN                     long    $7FFF_FFFF
02374 191 7f800000 Inf                     long    $7F80_0000
02378 192 ffffffe9 Minus23                 long    -23
0237c 193 007fffff Mask23                  long    $007F_FFFF
02380 194 20000000 Bit29                   long    $2000_0000
                   
02384 195 00000000 flagA                   long    0
02388 196 00000000 expA                    long    0
0238c 197 00000000 manA                    long    0
                   
02390 198 00000000 flagB                   long    0
02394 199 00000000 expB                    long    0
02398 19a 00000000 manB                    long    0
                   
                   '-------------------- End of Float32 Components -------------------------------
                   
                   '---------------------------- local variables ---------------------------------
                   
                   ' temporary storage used in mul & div calculations
                   
0239c 19b 00000000 ftemp    long    0
023a0 19c 00000000 ftmp2    long    0
                   
                   ' lockbits must be in the same place in all LMM kernels
                   
023a4 19d                   fit    $1ea
024d8 1ea                   orgf   $1ea
                   
024d8 1ea 00000000 lockbits long   0               ' lockbits used to simulate P1-style locks
                   
                   ' last 5 longs are reserved for debug overlay vectors (or debug LED)
                   
024dc 1eb                   fit    $1eb
024dc 1eb                   orgf   $1eb
                   
024dc 1eb          DEBUG_VECTORS
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
024dc 1eb 0007bde8          long   DEBUG_BREAK
024e0 1ec 0007bdec          long   DEBUG_ADDR
