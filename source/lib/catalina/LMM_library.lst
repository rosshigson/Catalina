                   _SD_CK     = 61         'pin SD Card clock
                   _SD_CS     = 60         'pin SD Card select
                   _SD_DI     = 59         'pin SD Card MOSI
                   _SD_DO     = 58         'pin SD Card MISO
                   
                   ' 2 Port Serial constants
                   
