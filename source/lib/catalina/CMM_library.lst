01c78 31e fd900040         jmp     #pcog           ' invoke plugin (via the cog id)
01c7c 31f          psvc
01c7c 31f f0640001         shl     r0,#1           ' read entry ...
01c80 320 f1000055         add     r0,reg          ' ... from ...
01c84 321 fae00000         rdword  r0,r0           ' ... the service registry
01c88 322 f6004e00         mov     t1,r0           ' save in t1 and extract ...
01c8c 323 f044000c         shr     r0,#12          ' ... cog number to r0
