01c64 319 ad90000c  if_z   jmp     #plgt2          ' yes - invoke plugin at this cog id
01c68 31a 51045001  if_nz  add     t2,#1           ' no - try ...
01c6c 31b 51044e04  if_nz  add     t1,#4           ' ... next ...
01c70 31c 5d9fffdc  if_nz  jmp     #plgt1          ' ... cog id
01c74 31d          plgt2
