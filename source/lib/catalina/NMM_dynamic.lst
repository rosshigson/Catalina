                   ' nmm_init : initialize VM - note that this code is kept 20 longs long
                   '            to make various offsets match the main kernel, where this
                   '            code may be overlaid by 19 longs of debug code once
                   '            initialization is complete - eventually, the same may be
                   '            true of this kernel as well.
                   
0010c 043          DEBUG_OVERLAY
0010c 043          nmm_init
0010c 043 fb047361         rdlong  reg,PTRA++     '$43  1 load registry address (used later)
00110 044 fd603001         cogid   r2             '$44  2 register ...
00114 045 f0643002         shl     r2,#2          '$45  3 ... ourselves ...
00118 046 f1003039         add     r2,reg         '$46  4 ... as ...
0011c 047 fb007018         rdlong  req,r2         '$47  5 ... a ...
00120 048 f5007037         and     req,low24      '$48  6 ... new ...
00124 049 fc607018         wrlong  req,r2         '$49  7  kernel
00128 04a fb043361         rdlong  r3,PTRA++      '$4a  8 load initial PC (to r3 temporarily)
0012c 04b fb043561         rdlong  r4,PTRA++      '$4b  9 load initial SP (to r4 temporarily)
00130 04c fb042d61         rdlong  r0,PTRA++      '$4c 10 load initial LUT library size (-1)
00134 04d fb042f61         rdlong  r1,PTRA++      '$4d 11 load initial LUT library address
00138 04e fb043161         rdlong  r2,PTRA++      '$4e 12 load initial arg
0013c 04f fd602c29         setq2   r0             '$4f 13 copy lut library ...
00140 050 fb020017         rdlong  $100,r1        '$50 14 ... to LUT RAM, starting at $100
00144 051 f603f01a         mov     PTRA,r4        '$51 15 set up correct SP
00148 052 fd60322c         jmp     r3             '$52 16 we can now start executing Native code
0014c 053 00000000         long    0              '$53 17
00150 054 00000000         long    0              '$54 18
00154 055 00000000         long    0              '$55 19
00158 056 00000000         long    0              '$56 20
0015c 057 00000000         long    0              '$57 21
00160 058 00000000         long    0              '$58 22
00164 059 00000000         long    0              '$59 23
00168 05a 00000000         long    0              '$5a 24
0016c 05b 00000000         long    0              '$5a 25
00170 05c 00000000         long    0              '$5b 26
00174 05d 00000000         long    0              '$5c 27
00178 05e 00000000         long    0              '$5d 28
0017c 05f 00000000         long    0              '$5e 29
                   '
                   ' push_i - push a value whose address is specified indirectly in a
                   '          frame variable onto the stack
                   '
00180 060          push_i
00180 060 fd604224        stalli               ' disable interrupts
00184 061 fb0029f6        rdlong RI,PA         ' load the long value
00188 062 f14029f9        adds   RI,PTRB       ' add the frame pointer
0018c 063          push_x
0018c 063 fd604224        stalli               ' disable interrupts
00190 064 fb002814        rdlong RI,RI         ' read the value at that address
00194 065 fc64295f        wrlong RI,--PTRA     ' save value on stack
00198 066 f107ec04        add    PA,#4         ' increment PC ...
0019c 067          returni
0019c 067 fd604024        allowi               ' ... enable interrupts ...
001a0 068 fd63ec2c        jmp    PA            ' ... and return
                   
                   '
                   ' push_m - push many registers (specified by long at PC) onto the stack,
                   ' decrementing the SP (PTRA) before each one
                   '
001a4 069          push_m
                   
001a4 069 fd604224        stalli               ' disable interrupts
                   
                   
                   
                   
                   
                   
                   
001a8 06a fb0029f6        rdlong RI,PA         ' load the long value specifying registers to push
                   
001ac 06b f6007414        mov    t1,RI         ' save register specification for later
001b0 06c f0442806        shr    RI,#6         ' ignore registers r0 - r5 (never saved)
001b4 06d f604781c        mov    t3,#r6        ' start with r6
001b8 06e          push_nxt
001b8 06e f05c2801        shr    RI,#1 wcz     ' save rX?
001bc 06f c98c7800  if_c  altd   t3            ' yes - decrement SP ...
001c0 070 cc64015f  if_c  wrlong 0-0,--PTRA    ' ... and save the register
001c4 071 f1047801        add    t3,#1         ' point to next register
001c8 072 5d9fffec  if_nz jmp    #push_nxt     ' continue till all registers saved
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
001cc 073 fc64755f        wrlong t1,--PTRA     ' save register specification
                   
001d0 074 f107ec04        add    PA,#4         ' increment PC ...
001d4 075 fd9fffc4        jmp    #returni      ' ... and return
                   
001d8 076 0003ffff Bits18 long   %0000_0000_0000_0011_1111_1111_1111_1111
                   
                   '
                   ' pop_m - pop many registers (specified by the long on top of stack)
                   ' from the stack, incremening the SP after each one
                   '
001dc 077          pop_m
                   
001dc 077 fd604224        stalli               ' disable interrupts
                   
                   
                   
                   
                   
                   
                   
001e0 078 fb042961        rdlong RI,PTRA++     ' pop the long value specifying registers to pop
                   
001e4 079 f604762d        mov    t2,#r23       ' start with ...
001e8 07a f0642808        shl    RI,#(32-24)   ' ... r23
001ec 07b          pop_nxt
001ec 07b f07c2801        shl    RI,#1 wcz     ' load rX?
001f0 07c c98c7600  if_c  altd   t2            ' yes - load the register ...
001f4 07d cb040161  if_c  rdlong 0-0,PTRA++    ' ... and increment the stack pointer
001f8 07e 51847601  if_nz sub    t2,#1         ' if more to do, point to previous register ...
001fc 07f 5d9fffec  if_nz jmp    #pop_nxt      ' ... and continue till all registers popped
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
00200 080 fd9fff98        jmp    #returni
                   
                   '
                   ' push_b - push a structure (size in bytes at the PC) pointed to by R0
                   '          onto the stack, decrementing the SP (PTRA). Note that the source
                   '          and destination data MUST be long aligned - but this is true
                   '          for all normal structures.
                   '
00204 081          push_b
00204 081 fd604224        stalli               ' disable interrupts
00208 082 fb002bf6        rdlong BC,PA         ' load the byte count
0020c 083 f107ec04        add    PA,#4         ' increment the PC
00210 084 f1042a03        add    BC,#3         ' round up BC ...
00214 085 f5242a03        andn   BC,#3         ' ... to be a multiple of 4
00218 086 f183f015        sub    PTRA,BC       ' decrement SP (PTRA) by rounded up size
0021c 087 f6007416        mov    t1,R0         ' source is in R0
00220 088 f60077f8        mov    t2,PTRA       ' destination is SP (PTRA)
00224 089 fd90001c        jmp    #copy_longs   ' do the copy
                   '
                   ' copy_b - copy a structure (size in bytes at the PC)
                   '          from the address in R1 to the address in R0
                   '
00228 08a          copy_b
00228 08a fd604224        stalli               ' disable interrupts
0022c 08b fb002bf6        rdlong BC,PA         ' load the byte count
00230 08c f107ec04        add    PA,#4         ' increment the PC
00234 08d f1042a03        add    BC,#3         ' round up BC ...
00238 08e f5242a03        andn   BC,#3         ' ... to be a multiple of 4
0023c 08f f6007417        mov    t1,R1         ' source is in R1
00240 090 f6007616        mov    t2,R0         ' destination is in R0
                   '
00244 091          copy_longs
00244 091 f0442a02        shr    BC,#2         ' number of times to repeat
00248 092 fcd80815        rep    #4,BC         ' repeat the next 4 instructions BC times
0024c 093 fb00783a        rdlong t3,t1         ' read from src to t3
00250 094 fc60783b        wrlong t3,t2         ' write t3 to dst
00254 095 f1047404        add    t1,#4         ' increment source
00258 096 f1047604        add    t2,#4         ' increment destination
0025c 097 fd9fff3c        jmp    #returni
                   '
                   ' new_fp - save current frame pointer and set up a new frame pointer
                   ' also calculate what SP (PTRA) was before data was pushed and save it in BC
                   '
00260 098          new_fp
00260 098 fd604224        stalli               ' disable interrupts
00264 099 fc67f35f        wrlong PTRB,--PTRA   ' save FP (PTRB) to stack
00268 09a f603f3f8        mov    PTRB,PTRA     ' set up new FP (PTRB)
0026c 09b f1042a08        add    BC,#8         ' calculate what SP (PTRA) was ...
00270 09c f1002bf9        add    BC,PTRB       ' ... before arguments were pushed
00274 09d fd9fff24        jmp    #returni
                   '
                   ' fp_ret - pop current frame, restore previous frame and stack pointers,
                   '          then restore the previous program counter
                   '
                   ' f_ret -  just restore the previous program counter
                   '
00278 09e          fp_ret
00278 09e fd604224        stalli               ' disable interrupts
0027c 09f fb07f361        rdlong PTRB,PTRA++   ' restore previous FP (PTRB)
00280 0a0          f_ret
00280 0a0 fd604224        stalli               ' disable interrupts
00284 0a1 fb07ed00        rdlong PA,PTRA       ' read the PC
00288 0a2 f107f008        add    PTRA,#8       ' increment the SP (PTRA)
0028c 0a3 fd9fff0c        jmp    #returni
                   '
                   ' f_call - call the routine at the address pointed to by the PC
                   ' f_cali - call the routine whose address is in RI
                   '
00290 0a4          f_call
00290 0a4 fd604224        stalli               ' disable interrupts
00294 0a5 fb0029f6        rdlong RI,PA         ' get the address to call
00298 0a6 f107ec04        add    PA,#4         ' increment the PC (this is the return address)
0029c 0a7          f_cali
0029c 0a7 fd604224        stalli               ' disable interrupts
002a0 0a8 f187f008        sub    PTRA,#8       ' decrement the SP (PTRA)
002a4 0a9 fc67ed00        wrlong PA,PTRA       ' save current PC to stack
002a8 0aa fd604024        allowi               ' enable interrupts
002ac 0ab fd60282c        jmp    RI            ' execute next instruction
                   
                   'fd_32s - Signed 32 bit division
                   '         Divisor --> r1
                   '         Dividend--> r0
                   '         Result --> Quotient in r0
                   '                    Remainder in r1
                   
002b0 0ac          f_d32s
002b0 0ac fd604224        stalli               ' disable interrupts
002b4 0ad fda00303        call   #\signed_d32  ' perform signed division
002b8 0ae fd9ffee0        jmp    #returni
                   
                   ' plugin - call a plugin
                   ' On entry:
                   '       R3 = code:
                   '            - cog id if >= 128 (i.e. $80 + cog id)
                   '            - plugin type if < 128 (i.e. 0 .. 127)
                   '            - service id if < 0
                   '       R2 = data (optional pointer)
                   '
                   ' NOTES: Locks are currently only supported when invoking via a service id.
                   '        When using service id, the data should only use the lower 24 bits.
                   '
                   ' On exit:
                   '       R0 = result
                   
002bc 0af          plugin
002bc 0af fd604224        stalli               ' disable interrupts
002c0 0b0 fda0030d        call   #\do_plugin   ' do_plugin does all the work
002c4 0b1 fd9ffed4        jmp    #returni
                   
