                   '------------------------------------------------------------------------------
                   ' Float32 Assembly language routines
                   '------------------------------------------------------------------------------
                   ' flt_add   r0 = r0 + r1
                   ' flt_sub   r0 = r0 - r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1
                   '------------------------------------------------------------------------------
                   
002c8 0b2 f5602e32 flt_sub                 xor     r1, Bit31               ' negate B
002cc 0b3 fd604224 flt_add                 stalli
002d0 0b4 fdb00184                         call    #_Unpack2               ' unpack two variables
002d4 0b5 ed9ffec4           if_c_or_z     jmp     #returni                ' check for NaN or B = 0
                   
002d8 0b6 f7cebc01                         test    flagA, #SignFlag wz     ' negate A mantissa if negative
002dc 0b7 5662c160           if_nz         neg     manA, manA
002e0 0b8 f7cec201                         test    flagB, #SignFlag wz     ' negate B mantissa if negative
002e4 0b9 5662c763           if_nz         neg     manB, manB
                   
002e8 0ba f600755f                         mov     t1, expA                ' align mantissas
002ec 0bb f1807562                         sub     t1, expB
002f0 0bc f640743a                         abs     t1, t1
002f4 0bd f324741f                         fle     t1, #31
002f8 0be f25abf62                         cmps    expA, expB wcz
002fc 0bf 10c2c63a           if_nz_and_nc  sar     manB, t1
00300 0c0 40c2c03a           if_nz_and_c   sar     manA, t1
00304 0c1 4602bf62           if_nz_and_c   mov     expA, expB
                   
00308 0c2 f102c163                         add     manA, manB              ' add the two mantissas
0030c 0c3 f256c000                         cmps    manA, #0 wc             ' set sign of result
00310 0c4 c546bc01           if_c          or      flagA, #SignFlag
00314 0c5 3526bc01           if_nc         andn    flagA, #SignFlag
00318 0c6 f642c160                         abs     manA, manA              ' pack result and exit
0031c 0c7 fdb001e0 pack_rtni               call    #_Pack
00320 0c8 fd9ffe78                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' flt_mul  r0 = r0 * r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
00324 0c9 fd604224 flt_mul                 stalli
00328 0ca fdb0012c                         call    #_Unpack2               ' unpack two variables
0032c 0cb 3d900024           if_nc         jmp     #flt_mul2               ' multiply if neither is NaN
00330 0cc f20ebeff                         cmp     expA, #255 wz           ' NaN, so check for r0 = Inf
00334 0cd ad900008           if_z          jmp     #flt_mul1               ' yes - return Inf
00338 0ce f20ec4ff                         cmp     expB, #255 wz           ' no - check for r1 = Inf
0033c 0cf 5d9ffe5c           if_nz         jmp     #returni                ' no - return NaN
00340 0d0 f6002d5a flt_mul1                mov     r0, Inf                 ' yes, r0 or r1 is Inf, so return Inf
00344 0d1 f562bd61                         xor     flagA, flagB            '
00348 0d2 f7cebc01                         test    flagA, #SignFlag wz
0034c 0d3 55402c32           if_nz         or      r0, Bit31
00350 0d4 fd9ffe48                         jmp     #returni
00354 0d5 f562bd61 flt_mul2                xor     flagA, flagB            ' get sign of result
00358 0d6 f102bf62                         add     expA, expB              ' add exponents
0035c 0d7 fd02c163                         qmul    manA, manB
00360 0d8 fd607419                         getqy   t1
00364 0d9 f0647403                         shl     t1, #3                  ' justify result and exit
00368 0da f602c03a                         mov     manA, t1
0036c 0db fd9fffac                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' flt_div  r0 = r0 / r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
00370 0dc fd604224 flt_div                 stalli
00374 0dd fdb000e0                         call    #_Unpack2               ' unpack two variables
00378 0de e6002d59           if_c_or_z     mov     r0, NaN                 ' check for NaN or divide by 0
0037c 0df ed9ffe1c           if_c_or_z     jmp     #returni
                   
00380 0e0 f562bd61                         xor     flagA, flagB            ' get sign of result
00384 0e1 f182bf62                         sub     expA, expB              ' subtract exponents
                   
00388 0e2 f046c001                         shr     manA, #1
0038c 0e3 fd62c028                         setq    manA
00390 0e4 fd180163                         qdiv    #0, manB
00394 0e5 fd62c018                         getqx   manA
00398 0e6 f046c002                         shr     manA, #2
0039c 0e7 fd9fff7c                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' flt_int  r0 = float(r0)
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
003a0 0e8 fd604224 flt_int                 stalli
003a4 0e9 f602bc16                         mov     flagA, r0               ' get integer value
003a8 0ea f6042c00                         mov     r0, #0                  ' set initial result to zero
003ac 0eb f64ac15e                         abs     manA, flagA wz          ' get absolute value of integer
003b0 0ec ad9ffde8           if_z          jmp     #returni                ' if zero, exit
003b4 0ed f046bc1f                         shr     flagA, #31              ' set sign flag
003b8 0ee f606be1f                         mov     expA, #31               ' set initial value for exponent
003bc 0ef f076c001 normalize_1             shl     manA, #1 wc             ' normalize the mantissa
003c0 0f0 3186be01           if_nc         sub     expA, #1                ' adjust exponent
003c4 0f1 3d9ffff4           if_nc         jmp     #normalize_1
003c8 0f2 f086c001                         rcr     manA, #1                ' justify mantissa
003cc 0f3 f046c002                         shr     manA, #2
003d0 0f4 fd9fff48                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' int_flt  r0 = fix(r0)
                   ' changes: r0, flagA, expA, manA, t1
                   '------------------------------------------------------------------------------
                   
003d4 0f5 fd604224 int_flt                 stalli
003d8 0f6 f6047400                         mov     t1, #0                  ' set for no rounding
                   '                        jmp     #fix
                   
                   'rnd_flt                 mov     t1, #1                  ' set for rounding
                   
003dc 0f7 fdb000a8 fix                     call    #_Unpack                ' unpack floating point value
003e0 0f8 cd9ffdb8           if_c          jmp     #returni                ' check for NaN
003e4 0f9 f066c002                         shl     manA, #2                ' left justify mantissa
003e8 0fa f6042c00                         mov     r0, #0                  ' initialize result to zero
003ec 0fb f662bf5f                         neg     expA, expA              ' adjust for exponent value
003f0 0fc f10ebe1e                         add     expA, #30 wz
003f4 0fd f256be20                         cmps    expA, #32 wc
003f8 0fe bd9ffda0           if_nc_or_z    jmp     #returni
003fc 0ff f042c15f                         shr     manA, expA
                   
00400 100 f102c03a                         add     manA, t1                ' round up 1/2 lsb
00404 101 f046c001                         shr     manA, #1
                   
00408 102 f7cebc01                         test    flagA, #signFlag wz     ' check sign and exit
0040c 103 f3e02d60                         sumnz   r0, manA
00410 104 fd9ffd88                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' flt_cmp   set Z and C flags for r0 - r1
                   ' changes: status, t1
                   '------------------------------------------------------------------------------
                   
00414 105 fd604224 flt_cmp                 stalli
00418 106 f6007416                         mov     t1, r0               ' compare signs
0041c 107 f5607417                         xor     t1, r1
00420 108 f5087432                         and     t1, Bit31 wz
00424 109 ad900018           if_z          jmp     #cmp1                  ' same, then compare magnitude
                   
00428 10a f6007416                         mov     t1, r0               ' check for +0 or -0
0042c 10b f5407417                         or      t1, r1
00430 10c f5387432                         andn    t1, Bit31 wcz
00434 10d ad9ffd64           if_z          jmp     #returni
                   
00438 10e f7d02c32                         test    r0, Bit31 wc         ' compare signs
0043c 10f fd9ffd5c                         jmp     #returni
                   
00440 110 f7c82c32 cmp1                    test    r0, Bit31 wz         ' check signs
00444 111 5d900008           if_nz         jmp     #cmp2
00448 112 f2182c17                         cmp     r0, r1 wcz
0044c 113 fd9ffd4c                         jmp     #returni
00450 114 f2182e16 cmp2                    cmp     r1, r0 wcz           ' reverse test if negative
00454 115 fd9ffd44                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' input:   r0        32-bit floating point value
                   '          r1        32-bit floating point value
                   ' output:  flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   '          flagB        r1 flag bits (Nan, Infinity, Zero, Sign)
                   '          expB         r1 exponent (no bias)
                   '          manB         r1 mantissa (aligned to bit 29)
                   '          C flag       set if r0 or r1 is NaN
                   '          Z flag       set if r1 is zero
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1
                   '------------------------------------------------------------------------------
                   
00458 116 f6007416 _Unpack2                mov     t1, r0               ' save A
0045c 117 f6002c17                         mov     r0, r1               ' unpack B to A
00460 118 fdb00024                         call    #_Unpack
                   
00464 119 f6002e16                         mov     r1, r0               ' save B variables
00468 11a f602c35e                         mov     flagB, flagA
0046c 11b f602c55f                         mov     expB, expA
00470 11c f602c760                         mov     manB, manA
                   
00474 11d f6002c3a                         mov     r0, t1               ' unpack A
00478 11e fdb0000c                         call    #_Unpack
0047c 11f 37cec208           if_nc         test    flagB, #NanFlag wz
00480 120 1d75e06f           if_nc_and_nz  modc    _set wc
00484 121 020ec600           _ret_         cmp     manB, #0 wz          ' set Z flag
                   
                   '------------------------------------------------------------------------------
                   ' input:   r0        32-bit floating point value
                   ' output:  flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   '          C flag       set if r0 is NaN
                   '          Z flag       set if r0 is zero
