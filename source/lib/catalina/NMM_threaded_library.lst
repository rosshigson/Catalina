                   DAT
                   
                   '------------------------------------------------------------------------------
                   ' Float32 Assembly language routines
                   '------------------------------------------------------------------------------
                   ' flt_add   r0 = r0 + r1
                   ' flt_sub   r0 = r0 - r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1
                   '------------------------------------------------------------------------------
                   
02150 0fc f5602e32 flt_sub                 xor     r1, Bit31               ' negate B
02154 0fd fd604224 flt_add                 stalli
02158 0fe fdb00184                         call    #_Unpack2               ' unpack two variables
0215c 0ff ed9ffd9c           if_c_or_z     jmp     #returni                ' check for NaN or B = 0
                   
02160 100 f7cf5001                         test    flagA, #SignFlag wz     ' negate A mantissa if negative
02164 101 566355aa           if_nz         neg     manA, manA
02168 102 f7cf5601                         test    flagB, #SignFlag wz     ' negate B mantissa if negative
0216c 103 56635bad           if_nz         neg     manB, manB
                   
02170 104 f60075a9                         mov     t1, expA                ' align mantissas
02174 105 f18075ac                         sub     t1, expB
02178 106 f640743a                         abs     t1, t1
0217c 107 f324741f                         fle     t1, #31
02180 108 f25b53ac                         cmps    expA, expB wcz
02184 109 10c35a3a           if_nz_and_nc  sar     manB, t1
02188 10a 40c3543a           if_nz_and_c   sar     manA, t1
0218c 10b 460353ac           if_nz_and_c   mov     expA, expB
                   
02190 10c f10355ad                         add     manA, manB              ' add the two mantissas
02194 10d f2575400                         cmps    manA, #0 wc             ' set sign of result
02198 10e c5475001           if_c          or      flagA, #SignFlag
0219c 10f 35275001           if_nc         andn    flagA, #SignFlag
021a0 110 f64355aa                         abs     manA, manA              ' pack result and exit
021a4 111 fdb001e0 pack_rtni               call    #_Pack
021a8 112 fd9ffd50                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' flt_mul  r0 = r0 * r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
021ac 113 fd604224 flt_mul                 stalli
021b0 114 fdb0012c                         call    #_Unpack2               ' unpack two variables
021b4 115 3d900024           if_nc         jmp     #flt_mul2               ' multiply if neither is NaN
021b8 116 f20f52ff                         cmp     expA, #255 wz           ' NaN, so check for r0 = Inf
021bc 117 ad900008           if_z          jmp     #flt_mul1               ' yes - return Inf
021c0 118 f20f58ff                         cmp     expB, #255 wz           ' no - check for r1 = Inf
021c4 119 5d9ffd34           if_nz         jmp     #returni                ' no - return NaN
021c8 11a f6002da4 flt_mul1                mov     r0, Inf                 ' yes, r0 or r1 is Inf, so return Inf
021cc 11b f56351ab                         xor     flagA, flagB            '
021d0 11c f7cf5001                         test    flagA, #SignFlag wz
021d4 11d 55402c32           if_nz         or      r0, Bit31
021d8 11e fd9ffd20                         jmp     #returni
021dc 11f f56351ab flt_mul2                xor     flagA, flagB            ' get sign of result
021e0 120 f10353ac                         add     expA, expB              ' add exponents
021e4 121 fd0355ad                         qmul    manA, manB
021e8 122 fd607419                         getqy   t1
021ec 123 f0647403                         shl     t1, #3                  ' justify result and exit
021f0 124 f603543a                         mov     manA, t1
021f4 125 fd9fffac                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' flt_div  r0 = r0 / r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
021f8 126 fd604224 flt_div                 stalli
021fc 127 fdb000e0                         call    #_Unpack2               ' unpack two variables
02200 128 e6002da3           if_c_or_z     mov     r0, NaN                 ' check for NaN or divide by 0
02204 129 ed9ffcf4           if_c_or_z     jmp     #returni
                   
02208 12a f56351ab                         xor     flagA, flagB            ' get sign of result
0220c 12b f18353ac                         sub     expA, expB              ' subtract exponents
                   
02210 12c f0475401                         shr     manA, #1
02214 12d fd635428                         setq    manA
02218 12e fd1801ad                         qdiv    #0, manB
0221c 12f fd635418                         getqx   manA
02220 130 f0475402                         shr     manA, #2
02224 131 fd9fff7c                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' flt_int  r0 = float(r0)
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
02228 132 fd604224 flt_int                 stalli
0222c 133 f6035016                         mov     flagA, r0               ' get integer value
02230 134 f6042c00                         mov     r0, #0                  ' set initial result to zero
02234 135 f64b55a8                         abs     manA, flagA wz          ' get absolute value of integer
02238 136 ad9ffcc0           if_z          jmp     #returni                ' if zero, exit
0223c 137 f047501f                         shr     flagA, #31              ' set sign flag
02240 138 f607521f                         mov     expA, #31               ' set initial value for exponent
02244 139 f0775401 normalize_1             shl     manA, #1 wc             ' normalize the mantissa
02248 13a 31875201           if_nc         sub     expA, #1                ' adjust exponent
0224c 13b 3d9ffff4           if_nc         jmp     #normalize_1
02250 13c f0875401                         rcr     manA, #1                ' justify mantissa
02254 13d f0475402                         shr     manA, #2
02258 13e fd9fff48                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' int_flt  r0 = fix(r0)
                   ' changes: r0, flagA, expA, manA, t1
                   '------------------------------------------------------------------------------
                   
0225c 13f fd604224 int_flt                 stalli
02260 140 f6047400                         mov     t1, #0                  ' set for no rounding
                   '                        jmp     #fix
                   
                   'rnd_flt                 mov     t1, #1                  ' set for rounding
                   
02264 141 fdb000a8 fix                     call    #_Unpack                ' unpack floating point value
02268 142 cd9ffc90           if_c          jmp     #returni                ' check for NaN
0226c 143 f0675402                         shl     manA, #2                ' left justify mantissa
02270 144 f6042c00                         mov     r0, #0                  ' initialize result to zero
02274 145 f66353a9                         neg     expA, expA              ' adjust for exponent value
02278 146 f10f521e                         add     expA, #30 wz
0227c 147 f2575220                         cmps    expA, #32 wc
02280 148 bd9ffc78           if_nc_or_z    jmp     #returni
02284 149 f04355a9                         shr     manA, expA
                   
02288 14a f103543a                         add     manA, t1                ' round up 1/2 lsb
0228c 14b f0475401                         shr     manA, #1
                   
02290 14c f7cf5001                         test    flagA, #signFlag wz     ' check sign and exit
02294 14d f3e02daa                         sumnz   r0, manA
02298 14e fd9ffc60                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' flt_cmp   set Z and C flags for r0 - r1
                   ' changes: status, t1
                   '------------------------------------------------------------------------------
                   
0229c 14f fd604224 flt_cmp                 stalli
022a0 150 f6007416                         mov     t1, r0               ' compare signs
022a4 151 f5607417                         xor     t1, r1
022a8 152 f5087432                         and     t1, Bit31 wz
022ac 153 ad900018           if_z          jmp     #cmp1                  ' same, then compare magnitude
                   
022b0 154 f6007416                         mov     t1, r0               ' check for +0 or -0
022b4 155 f5407417                         or      t1, r1
022b8 156 f5387432                         andn    t1, Bit31 wcz
022bc 157 ad9ffc3c           if_z          jmp     #returni
                   
022c0 158 f7d02c32                         test    r0, Bit31 wc         ' compare signs
022c4 159 fd9ffc34                         jmp     #returni
                   
022c8 15a f7c82c32 cmp1                    test    r0, Bit31 wz         ' check signs
022cc 15b 5d900008           if_nz         jmp     #cmp2
022d0 15c f2182c17                         cmp     r0, r1 wcz
022d4 15d fd9ffc24                         jmp     #returni
022d8 15e f2182e16 cmp2                    cmp     r1, r0 wcz           ' reverse test if negative
022dc 15f fd9ffc1c                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' input:   r0        32-bit floating point value
                   '          r1        32-bit floating point value
                   ' output:  flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   '          flagB        r1 flag bits (Nan, Infinity, Zero, Sign)
                   '          expB         r1 exponent (no bias)
                   '          manB         r1 mantissa (aligned to bit 29)
                   '          C flag       set if r0 or r1 is NaN
                   '          Z flag       set if r1 is zero
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1
                   '------------------------------------------------------------------------------
                   
022e0 160 f6007416 _Unpack2                mov     t1, r0               ' save A
022e4 161 f6002c17                         mov     r0, r1               ' unpack B to A
022e8 162 fdb00024                         call    #_Unpack
                   
022ec 163 f6002e16                         mov     r1, r0               ' save B variables
022f0 164 f60357a8                         mov     flagB, flagA
022f4 165 f60359a9                         mov     expB, expA
022f8 166 f6035baa                         mov     manB, manA
                   
022fc 167 f6002c3a                         mov     r0, t1               ' unpack A
02300 168 fdb0000c                         call    #_Unpack
02304 169 37cf5608           if_nc         test    flagB, #NanFlag wz
02308 16a 1d75e06f           if_nc_and_nz  modc    _set wc
0230c 16b 020f5a00           _ret_         cmp     manB, #0 wz          ' set Z flag
                   
                   '------------------------------------------------------------------------------
                   ' input:   r0        32-bit floating point value
                   ' output:  flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   '          C flag       set if r0 is NaN
                   '          Z flag       set if r0 is zero
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
02310 16c f6035016 _Unpack                 mov     flagA, r0            ' get sign
02314 16d f047501f                         shr     flagA, #31
02318 16e f6035416                         mov     manA, r0             ' get mantissa
0231c 16f f50355a6                         and     manA, Mask23
02320 170 f6035216                         mov     expA, r0             ' get exponent
02324 171 f0675201                         shl     expA, #1
02328 172 f04f5218                         shr     expA, #24 wz
0232c 173 ad900014           if_z          jmp     #zeroSubnormal         ' check for zero or subnormal
02330 174 f20f52ff                         cmp     expA, #255 wz           ' check if finite
02334 175 5d90003c           if_nz         jmp     #finite
02338 176 f6002da3                         mov     r0, NaN              ' no, then return NaN
0233c 177 f5475008                         or      flagA, #NaNFlag
02340 178 fd90003c                         jmp     #U_exit2
                   
02344 179 f6007baa zeroSubnormal           mov     t4, manA
02348 17a f5487ba9                         or      t4, expA wz             ' check for zero
0234c 17b 5d90000c           if_nz         jmp     #subnorm
02350 17c f5475002                         or      flagA, #ZeroFlag        ' yes, then set zero flag
02354 17d f6675296                         neg     expA, #150              ' set exponent and exit
02358 17e fd900024                         jmp     #U_exit2
                   
0235c 17f f0675407 subnorm                 shl     manA, #7                ' fix justification for subnormals
02360 180 f7cb55a7 subnorm2                test    manA, Bit29 wz
02364 181 5d900014           if_nz         jmp     #U_exit1
02368 182 f0675401                         shl     manA, #1
0236c 183 f1875201                         sub     expA, #1
02370 184 fd9fffec                         jmp     #subnorm2
                   
02374 185 f0675406 finite                  shl     manA, #6                ' justify mantissa to bit 29
02378 186 f54355a7                         or      manA, Bit29             ' add leading one bit
                   
0237c 187 f187527f U_exit1                 sub     expA, #127              ' remove bias from exponent
02380 188 f7d75008 U_exit2                 test    flagA, #NaNFlag wc      ' set C flag
02384 189 020f5400           _ret_         cmp     manA, #0 wz             ' set Z flag
                   
                   '------------------------------------------------------------------------------
                   ' input:   flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   ' output:  r0        32-bit floating point value
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
02388 18a f20f5400 _Pack                   cmp     manA, #0 wz             ' check for zero
0238c 18b a6075200           if_z          mov     expA, #0
02390 18c ad900040           if_z          jmp     #P_exit3
                   
02394 18d f0775401 normalize_2             shl     manA, #1 wc             ' normalize the mantissa
02398 18e 31875201           if_nc         sub     expA, #1                ' adjust exponent
0239c 18f 3d9ffff4           if_nc         jmp     #normalize_2
                   
023a0 190 f1075202                         add     expA, #2                ' adjust exponent
023a4 191 f1175500                         add     manA, #$100 wc          ' round up by 1/2 lsb
023a8 192 c1075201           if_c          add     expA, #1
                   
023ac 193 f107527f                         add     expA, #127              ' add bias to exponent
023b0 194 f34353a5                         fges    expA, Minus23
023b4 195 f36752ff                         fles    expA, #255
                   
023b8 196 f2575201                         cmps    expA, #1 wc             ' check for subnormals
023bc 197 3d900014           if_nc         jmp     #P_exit3
                   
023c0 198 f5475401 subnormal               or      manA, #1                ' adjust mantissa
023c4 199 f0075401                         ror     manA, #1
                   
023c8 19a f66353a9                         neg     expA, expA
023cc 19b f04355a9                         shr     manA, expA
023d0 19c f6075200                         mov     expA, #0                ' biased exponent = 0
                   
023d4 19d f6002daa P_exit3                 mov     r0, manA             ' bits 22:0 mantissa
023d8 19e f0442c09                         shr     r0, #9
023dc 19f f0675217                         shl     expA, #23
023e0 1a0 f5402da9                         or      r0, expA
023e4 1a1 f067501f                         shl     flagA, #31
023e8 1a2 05402da8           _ret_          or      r0, flagA            ' bit 31 sign
                   
023ec 1a3 7fffffff NaN                     long    $7FFF_FFFF
023f0 1a4 7f800000 Inf                     long    $7F80_0000
023f4 1a5 ffffffe9 Minus23                 long    -23
