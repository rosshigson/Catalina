01fe0 0a0 fd604224        stalli               ' disable interrupts
01fe4 0a1 fb07ed00        rdlong PA,PTRA       ' read the PC
01fe8 0a2 f107f008        add    PTRA,#8       ' increment the SP (PTRA)
01fec 0a3 fd9fff0c        jmp    #returni
                   '
                   ' f_call - call the routine at the address pointed to by the PC
                   ' f_cali - call the routine whose address is in RI
                   '
01ff0 0a4          f_call
01ff0 0a4 fd604224        stalli               ' disable interrupts
01ff4 0a5 fb0029f6        rdlong RI,PA         ' get the address to call
01ff8 0a6 f107ec04        add    PA,#4         ' increment the PC (this is the return address)
01ffc 0a7          f_cali
01ffc 0a7 fd604224        stalli               ' disable interrupts
02000 0a8 f187f008        sub    PTRA,#8       ' decrement the SP (PTRA)
02004 0a9 fc67ed00        wrlong PA,PTRA       ' save current PC to stack
02008 0aa fd604024        allowi               ' enable interrupts
0200c 0ab fd60282c        jmp    RI            ' execute next instruction
                   
                   'fd_32s - Signed 32 bit division
                   '         Divisor --> r1
                   '         Dividend--> r0
                   '         Result --> Quotient in r0
                   '                    Remainder in r1
                   
02010 0ac          f_d32s
02010 0ac fd604224        stalli               ' disable interrupts
02014 0ad fda00303        call   #\signed_d32  ' perform signed division
02018 0ae fd9ffee0        jmp    #returni
                   
                   ' plugin - call a plugin
                   ' On entry:
                   '       R3 = code:
                   '            - cog id if >= 128 (i.e. $80 + cog id)
                   '            - plugin type if < 128 (i.e. 0 .. 127)
                   '            - service id if < 0
                   '       R2 = data (optional pointer)
                   '
                   ' NOTES: Locks are currently only supported when invoking via a service id.
                   '        When using service id, the data should only use the lower 24 bits.
                   '
                   ' On exit:
                   '       R0 = result
                   
0201c 0af          plugin
0201c 0af fd604224        stalli               ' disable interrupts
02020 0b0 fda0030d        call   #\do_plugin   ' do_plugin does all the work
02024 0b1 fd9ffed4        jmp    #returni
                   
                   '-------------------------- Multi-Threading Support ----------------------------
                   
02028 0b2          NMM_isr
02028 0b2 fd604224         stalli
0202c 0b3 f6047a01         mov     t4,#1           ' flag to update ct3 before returning
02030 0b4 f43bd5e9         bith    lockbits,lock wcz    ' have we acquired ...
02034 0b5 5d73d206  if_nz  locktry lock wc              ' ... both intra-cog and inter-cog locks?
02038 0b6 1403d5e9  if_nc_and_nz  bitl lockbits,lock    ' true = if_c_and_nz, false = if_nc_or_z
0203c 0b7 bd900084  if_nc_or_z  jmp #NMM_resume    ' no - cannot switch - restore C & Z and resume
02040 0b8 fb0877e8         rdlong  t2, TP wz       ' yes - is there a next thread block pointer?
02044 0b9 ad900074  if_z   jmp     #NMM_unlock     ' no - unlock and resume
02048 0ba fb087438         rdlong  t1, req wz      ' yes - is there an affinity request oustanding?
0204c 0bb 5d9000a0  if_nz  jmp     #NMM_affine     ' yes - service it
02050 0bc f20877e8         cmp     t2, TP wz       ' no - is there only one thread executing?
02054 0bd ad900064  if_z   jmp     #NMM_unlock     ' yes - unlock and resume
02058 0be          NMM_switch
02058 0be f600783b         mov     t3, t2          ' no - get ...
0205c 0bf f1047885         add     t3, #33*4+1     ' ... affinity byte
02060 0c0 fac0743c         rdbyte  t1, t3          ' ... of proposed next thread
02064 0c1 f7cc74e0         test    t1, #%11100000 wz ' affinity stop, or thread terminated or completed?
02068 0c2 ad900010   if_z  jmp     #:next          ' no - switch to next thread
0206c 0c3 f5447480         or      t1, #%10000000  ' yes - make sure ...
02070 0c4 fc40743c         wrbyte  t1, t3          ' ... thread terminated bit of next thread is set
02074 0c5 fb00763b         rdlong  t2, t2          ' remove next thread ...
02078 0c6 fc6077e8         wrlong  t2, TP          ' ... from the executing thread list
0207c 0c7 f60075e8 :next   mov     t1, TP          ' point to ...
02080 0c8 f1047404         add     t1, #4          ' ... current thread register save area
02084 0c9 f6005df1         mov     Save_PC,iret3   ' Save PC and flags
02088 0ca f60063f6         mov     Save_PA,PA      ' Save PA
0208c 0cb f6005ff9         mov     Save_FP,FP      ' Save FP
02090 0cc f60061f8         mov     Save_SP,SP      ' Save SP
02094 0cd fd643a28         setq    #30-1           ' save 30 registers ...
02098 0ce fc60283a         wrlong  RI,t1           ' ... to register save area
0209c 0cf f603d03b         mov     TP, t2          ' set TP to next thread block
020a0 0d0 f1047604         add     t2, #4          ' point to that thread's register save area
020a4 0d1 fd643a28         setq    #30-1           ' load 30 registers ...
020a8 0d2 fb00283b         rdlong  RI,t2           ' ... from register save area
020ac 0d3 f603f030         mov     SP,Save_SP      ' restore SP
020b0 0d4 f603f22f         mov     FP,Save_FP      ' restore FP
020b4 0d5 f603ec31         mov     PA,Save_PA      ' restore PA
020b8 0d6 f603e22e         mov     iret3,Save_PC   ' restore PC and flags
020bc 0d7          NMM_unlock
020bc 0d7 fd63d207         lockrel lock                 ' release inter-cog lock
020c0 0d8 f403d5e9         bitl    lockbits,lock        ' release intra-cog lock
020c4 0d9          NMM_resume
020c4 0d9 fb947a08         tjz     t4,#NMM_resume2
020c8 0da f60075e8         mov     t1,TP           ' up date ticks ...
020cc 0db f1047486         add     t1,#33*4+2      ' ... with ticks ...
020d0 0dc fae3ce3a         rdword  ticks,t1        ' ... for current thread ...
020d4 0dd ff00001f         and     t1,##%11111111111111
020d8 0de f50475ff 
020dc 0df f107ce01         add     ticks,#1
020e0 0e0 f067ce0e         shl     ticks,#14       ' ... corrected for faster 1 !
020e4 0e1 fa7081e7         addct3  ct3,ticks       ' update ct3 target for next interrupt
020e8 0e2          NMM_resume2
020e8 0e2 fd604024         allowi
020ec 0e3 fb3bfff1         reti3                   ' resume execution
020f0 0e4          NMM_affine
020f0 0e4 f20877e8         cmp     t2, TP wz       ' is there only one thread executing?
020f4 0e5 5b00783b  if_nz  rdlong  t3, t2          ' no - get next thread of next thread ...
020f8 0e6 5c60783a  if_nz  wrlong  t3, t1          ' no - ... and make it next thread of new thread
020fc 0e7 ac60763a  if_z   wrlong  t2, t1          ' yes - make new thread next thread of current thread
02100 0e8 fc60743b         wrlong  t1, t2          ' make current thread next thread of new thread
02104 0e9 f6047885         mov     t3, #33*4+1     ' update ...
02108 0ea f100783a         add     t3, t1          ' ...
0210c 0eb fac07a3c         rdbyte  t4, t3          ' ...
02110 0ec fd607401         cogid   t1              ' ...
02114 0ed f5247a07         andn    t4, #%111       ' ...
02118 0ee f5407a3a         or      t4, t1          ' ...
0211c 0ef fc407a3c         wrbyte  t4, t3          ' ... thread affinity
02120 0f0 f6047800         mov     t3, #0          ' zero ...
02124 0f1 fc607838         wrlong  t3, req         ' ... request block
02128 0f2 fd9fff2c         jmp     #NMM_switch     ' now switch to next thread
0212c 0f3          NMM_force
0212c 0f3 fd604224         stalli
02130 0f4 f6047a00         mov     t4,#0           ' flag to not update ct3
02134 0f5 f603e3f6         mov     iret3,PA        ' set up return address as if from interrupt
02138 0f6 fb0077e8         rdlong  t2, TP          ' load next thread pointer
0213c 0f7 fb087438         rdlong  t1, req wz      ' is there an affinity request oustanding?
02140 0f8 5d9fffac  if_nz  jmp     #NMM_affine     ' yes - service it
02144 0f9 f20877e8         cmp     t2, TP wz       ' is there only one thread executing?
02148 0fa 5d9fff0c  if_nz  jmp     #NMM_switch     ' no - perform context switch
0214c 0fb fd9fff6c         jmp     #NMM_unlock     ' yes - unlock, restore C & Z amd resume
                   
                   '--------------------- End of NMM Kernel --------------------------------------
                   
                   '--------------------- Start of Float32 Components ----------------------------
                   
