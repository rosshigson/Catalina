                   ' do_plugin - call a plugin
                   '
                   ' On entry:
                   '       r3 = code:
                   '            - cog id if >= 128 (i.e. $80 + cog id)
                   '            - plugin type if < 128 (i.e. 0 .. 127)
                   '            - service id if < 0
                   '       r2 = data (optional pointer)
                   '
                   ' NOTES: Locks are currently only supported when invoking via a service id.
                   '        When using service id, the data should only use the lower 24 bits.
                   '
                   ' On exit:
                   '       R0 = result
                   
007f4 30d          do_plugin
007f4 30d f6045408         mov     t4,#8           ' t4 stores lock - default to none required
007f8 30e f6100003         mov     r0,r3 wc        ' get plugin type or cog id or service id
007fc 30f cd90003c  if_b   jmp     #psvc           ' if < 0, code is a service id
00800 310 f7cc0080         test    r0,#$80 wz      ' if bit 7 set ...
00804 311 5d900074  if_nz  jmp     #pcog           ' code is a cog id ...
00808 312          ptype                           ' ... otherwize it's a plugin type
00808 312 f6004e55         mov     t1,reg          ' point to registry
0080c 313 f6045000         mov     t2,#0           ' start at cog id 0
00810 314          plgt1
00810 314 f21c5008         cmp     t2,#8 wcz       ' run out of cogs?
00814 315 3d9000a0  if_ae  jmp     #plugerr        ' yes - no such plugin
00818 316 fb005227         rdlong  t3,t1           ' no - check cog's plugin type
0081c 317 f0445218         shr     t3,#24          ' is it ...
00820 318 f2085200         cmp     t3,r0 wz        ' ... the plugin type what we wanted?
00824 319 ad90000c  if_z   jmp     #plgt2          ' yes - invoke plugin at this cog id
00828 31a 51045001  if_nz  add     t2,#1           ' no - try ...
0082c 31b 51044e04  if_nz  add     t1,#4           ' ... next ...
00830 31c 5d9fffdc  if_nz  jmp     #plgt1          ' ... cog id
00834 31d          plgt2
00834 31d f6000028         mov     r0,t2           ' use the cog where we found the plugin
00838 31e fd900040         jmp     #pcog           ' invoke plugin (via the cog id)
0083c 31f          psvc
0083c 31f f0640001         shl     r0,#1           ' read entry ...
00840 320 f1000055         add     r0,reg          ' ... from ...
00844 321 fae00000         rdword  r0,r0           ' ... the service registry
00848 322 f6004e00         mov     t1,r0           ' save in t1 and extract ...
0084c 323 f044000c         shr     r0,#12          ' ... cog number to r0
00850 324 f6005027         mov     t2,t1           ' save in t2 and extract ...
00854 325 f06c4e18         shl     t1,#24 wz       ' ... request code to t1 (top 8 bits) ...
00858 326 ad90005c  if_z   jmp     #plugerr        ' ... or throw error if request code is zero
0085c 327 f6005428         mov     t4,t2           ' extract ...
00860 328 f0445408         shr     t4,#8           ' ... lock number to t4
00864 329 f7cc5408         test    t4,#8 wz        ' are we required to use a lock?
00868 32a 5d900008  if_nz  jmp     #no_lock        ' no - just make the request
0086c 32b          set_lock
0086c 32b fd705406         locktry t4 wc           ' yes - loop ...
00870 32c 3d9ffff8  if_nc  jmp     #set_lock       ' ... until we have set the lock
00874 32d          no_lock
00874 32d f5200422         andn    r2,top8         ' combine data ...
00878 32e f5400427         or      r2,t1           ' ... with request code
0087c 32f          pcog
0087c 32f f5040007         and     r0,#7           ' mask off cog id to 0 .. 7
00880 330 f0640002         shl     r0,#2           ' point to ...
00884 331 f1000055         add     r0,reg          ' ... registry entry for the cog
00888 332 fb000000         rdlong  r0,r0           ' get request block from registry
0088c 333 f7c80022         test    r0,top8 wz      ' is a plugin registered in this cog?
00890 334 ad900024  if_z   jmp     #plugerr        ' no - throw error
00894 335 f5200022         andn    r0,top8         ' yes - write ...
00898 336 fc600400         wrlong  r2,r0           ' ... request
0089c 337          ploop
