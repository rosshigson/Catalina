                   SignFlag      = $1
                   ZeroFlag      = $2
                   NaNFlag       = $8
                   
                   ' CogStore constants
                   
                   MAX_LONGS  = 300                ' store up to 300 LONGS (1200 chars)
                   
                   CMD_READ   = $1000_0000         ' copy Hub to Cog (address in lower 24 bits)
                                                   ' COGSTORE set to zero when complete
                   
                   CMD_WRITE  = $2000_0000         ' copy Cog to Hub (address in lower 24 bits)
