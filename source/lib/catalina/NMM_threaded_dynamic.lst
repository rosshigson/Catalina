                   '------------------------------------------------------------------------------
                   ' Float32 Assembly language routines
                   '------------------------------------------------------------------------------
                   ' flt_add   r0 = r0 + r1
                   ' flt_sub   r0 = r0 - r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1
                   '------------------------------------------------------------------------------
                   
003ec 0fb f5602e32 flt_sub                 xor     r1, Bit31               ' negate B
003f0 0fc fd604224 flt_add                 stalli
003f4 0fd fdb00184                         call    #_Unpack2               ' unpack two variables
003f8 0fe ed9ffda0           if_c_or_z     jmp     #returni                ' check for NaN or B = 0
                   
003fc 0ff f7cf4e01                         test    flagA, #SignFlag wz     ' negate A mantissa if negative
00400 100 566353a9           if_nz         neg     manA, manA
00404 101 f7cf5401                         test    flagB, #SignFlag wz     ' negate B mantissa if negative
00408 102 566359ac           if_nz         neg     manB, manB
                   
0040c 103 f60075a8                         mov     t1, expA                ' align mantissas
00410 104 f18075ab                         sub     t1, expB
00414 105 f640743a                         abs     t1, t1
00418 106 f324741f                         fle     t1, #31
0041c 107 f25b51ab                         cmps    expA, expB wcz
00420 108 10c3583a           if_nz_and_nc  sar     manB, t1
00424 109 40c3523a           if_nz_and_c   sar     manA, t1
00428 10a 460351ab           if_nz_and_c   mov     expA, expB
                   
0042c 10b f10353ac                         add     manA, manB              ' add the two mantissas
00430 10c f2575200                         cmps    manA, #0 wc             ' set sign of result
00434 10d c5474e01           if_c          or      flagA, #SignFlag
00438 10e 35274e01           if_nc         andn    flagA, #SignFlag
0043c 10f f64353a9                         abs     manA, manA              ' pack result and exit
00440 110 fdb001e0 pack_rtni               call    #_Pack
00444 111 fd9ffd54                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' flt_mul  r0 = r0 * r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
00448 112 fd604224 flt_mul                 stalli
0044c 113 fdb0012c                         call    #_Unpack2               ' unpack two variables
00450 114 3d900024           if_nc         jmp     #flt_mul2               ' multiply if neither is NaN
00454 115 f20f50ff                         cmp     expA, #255 wz           ' NaN, so check for r0 = Inf
00458 116 ad900008           if_z          jmp     #flt_mul1               ' yes - return Inf
0045c 117 f20f56ff                         cmp     expB, #255 wz           ' no - check for r1 = Inf
00460 118 5d9ffd38           if_nz         jmp     #returni                ' no - return NaN
00464 119 f6002da3 flt_mul1                mov     r0, Inf                 ' yes, r0 or r1 is Inf, so return Inf
00468 11a f5634faa                         xor     flagA, flagB            '
0046c 11b f7cf4e01                         test    flagA, #SignFlag wz
00470 11c 55402c32           if_nz         or      r0, Bit31
00474 11d fd9ffd24                         jmp     #returni
00478 11e f5634faa flt_mul2                xor     flagA, flagB            ' get sign of result
0047c 11f f10351ab                         add     expA, expB              ' add exponents
00480 120 fd0353ac                         qmul    manA, manB
00484 121 fd607419                         getqy   t1
00488 122 f0647403                         shl     t1, #3                  ' justify result and exit
0048c 123 f603523a                         mov     manA, t1
00490 124 fd9fffac                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' flt_div  r0 = r0 / r1
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1, t2
                   '------------------------------------------------------------------------------
                   
00494 125 fd604224 flt_div                 stalli
00498 126 fdb000e0                         call    #_Unpack2               ' unpack two variables
0049c 127 e6002da2           if_c_or_z     mov     r0, NaN                 ' check for NaN or divide by 0
004a0 128 ed9ffcf8           if_c_or_z     jmp     #returni
                   
004a4 129 f5634faa                         xor     flagA, flagB            ' get sign of result
004a8 12a f18351ab                         sub     expA, expB              ' subtract exponents
                   
004ac 12b f0475201                         shr     manA, #1
004b0 12c fd635228                         setq    manA
004b4 12d fd1801ac                         qdiv    #0, manB
004b8 12e fd635218                         getqx   manA
004bc 12f f0475202                         shr     manA, #2
004c0 130 fd9fff7c                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
                   ' flt_int  r0 = float(r0)
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
004c4 131 fd604224 flt_int                 stalli
004c8 132 f6034e16                         mov     flagA, r0               ' get integer value
004cc 133 f6042c00                         mov     r0, #0                  ' set initial result to zero
004d0 134 f64b53a7                         abs     manA, flagA wz          ' get absolute value of integer
004d4 135 ad9ffcc4           if_z          jmp     #returni                ' if zero, exit
004d8 136 f0474e1f                         shr     flagA, #31              ' set sign flag
004dc 137 f607501f                         mov     expA, #31               ' set initial value for exponent
004e0 138 f0775201 normalize_1             shl     manA, #1 wc             ' normalize the mantissa
004e4 139 31875001           if_nc         sub     expA, #1                ' adjust exponent
004e8 13a 3d9ffff4           if_nc         jmp     #normalize_1
004ec 13b f0875201                         rcr     manA, #1                ' justify mantissa
004f0 13c f0475202                         shr     manA, #2
004f4 13d fd9fff48                         jmp     #pack_rtni
                   
                   '------------------------------------------------------------------------------
