003e0 0f8 f20877e8         cmp     t2, TP wz       ' is there only one thread executing?
003e4 0f9 5d9fff0c  if_nz  jmp     #NMM_switch     ' no - perform context switch
003e8 0fa fd9fff88         jmp     #NMM_unlock     ' yes - unlock, restore C & Z amd resume
                   
