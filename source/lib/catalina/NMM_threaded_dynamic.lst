004f8 13e fd604224 int_flt                 stalli
004fc 13f f6047400                         mov     t1, #0                  ' set for no rounding
                   '                        jmp     #fix
                   
                   'rnd_flt                 mov     t1, #1                  ' set for rounding
                   
00500 140 fdb000a8 fix                     call    #_Unpack                ' unpack floating point value
00504 141 cd9ffc94           if_c          jmp     #returni                ' check for NaN
00508 142 f0675202                         shl     manA, #2                ' left justify mantissa
0050c 143 f6042c00                         mov     r0, #0                  ' initialize result to zero
00510 144 f66351a8                         neg     expA, expA              ' adjust for exponent value
00514 145 f10f501e                         add     expA, #30 wz
00518 146 f2575020                         cmps    expA, #32 wc
0051c 147 bd9ffc7c           if_nc_or_z    jmp     #returni
00520 148 f04353a8                         shr     manA, expA
                   
00524 149 f103523a                         add     manA, t1                ' round up 1/2 lsb
00528 14a f0475201                         shr     manA, #1
                   
0052c 14b f7cf4e01                         test    flagA, #signFlag wz     ' check sign and exit
00530 14c f3e02da9                         sumnz   r0, manA
00534 14d fd9ffc64                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' flt_cmp   set Z and C flags for r0 - r1
                   ' changes: status, t1
                   '------------------------------------------------------------------------------
                   
00538 14e fd604224 flt_cmp                 stalli
0053c 14f f6007416                         mov     t1, r0               ' compare signs
00540 150 f5607417                         xor     t1, r1
00544 151 f5087432                         and     t1, Bit31 wz
00548 152 ad900018           if_z          jmp     #cmp1                  ' same, then compare magnitude
                   
0054c 153 f6007416                         mov     t1, r0               ' check for +0 or -0
00550 154 f5407417                         or      t1, r1
00554 155 f5387432                         andn    t1, Bit31 wcz
00558 156 ad9ffc40           if_z          jmp     #returni
                   
0055c 157 f7d02c32                         test    r0, Bit31 wc         ' compare signs
00560 158 fd9ffc38                         jmp     #returni
                   
00564 159 f7c82c32 cmp1                    test    r0, Bit31 wz         ' check signs
00568 15a 5d900008           if_nz         jmp     #cmp2
0056c 15b f2182c17                         cmp     r0, r1 wcz
00570 15c fd9ffc28                         jmp     #returni
00574 15d f2182e16 cmp2                    cmp     r1, r0 wcz           ' reverse test if negative
00578 15e fd9ffc20                         jmp     #returni
                   
                   '------------------------------------------------------------------------------
                   ' input:   r0        32-bit floating point value
                   '          r1        32-bit floating point value
                   ' output:  flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   '          flagB        r1 flag bits (Nan, Infinity, Zero, Sign)
                   '          expB         r1 exponent (no bias)
                   '          manB         r1 mantissa (aligned to bit 29)
                   '          C flag       set if r0 or r1 is NaN
                   '          Z flag       set if r1 is zero
                   ' changes: r0, flagA, expA, manA, r1, flagB, expB, manB, t1
                   '------------------------------------------------------------------------------
                   
0057c 15f f6007416 _Unpack2                mov     t1, r0               ' save A
00580 160 f6002c17                         mov     r0, r1               ' unpack B to A
00584 161 fdb00024                         call    #_Unpack
                   
00588 162 f6002e16                         mov     r1, r0               ' save B variables
0058c 163 f60355a7                         mov     flagB, flagA
00590 164 f60357a8                         mov     expB, expA
00594 165 f60359a9                         mov     manB, manA
                   
00598 166 f6002c3a                         mov     r0, t1               ' unpack A
0059c 167 fdb0000c                         call    #_Unpack
005a0 168 37cf5408           if_nc         test    flagB, #NanFlag wz
005a4 169 1d75e06f           if_nc_and_nz  modc    _set wc
005a8 16a 020f5800           _ret_         cmp     manB, #0 wz          ' set Z flag
                   
                   '------------------------------------------------------------------------------
                   ' input:   r0        32-bit floating point value
                   ' output:  flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   '          C flag       set if r0 is NaN
                   '          Z flag       set if r0 is zero
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
005ac 16b f6034e16 _Unpack                 mov     flagA, r0            ' get sign
005b0 16c f0474e1f                         shr     flagA, #31
005b4 16d f6035216                         mov     manA, r0             ' get mantissa
005b8 16e f50353a5                         and     manA, Mask23
005bc 16f f6035016                         mov     expA, r0             ' get exponent
005c0 170 f0675001                         shl     expA, #1
005c4 171 f04f5018                         shr     expA, #24 wz
005c8 172 ad900014           if_z          jmp     #zeroSubnormal         ' check for zero or subnormal
005cc 173 f20f50ff                         cmp     expA, #255 wz           ' check if finite
005d0 174 5d90003c           if_nz         jmp     #finite
005d4 175 f6002da2                         mov     r0, NaN              ' no, then return NaN
005d8 176 f5474e08                         or      flagA, #NaNFlag
005dc 177 fd90003c                         jmp     #U_exit2
                   
005e0 178 f6007ba9 zeroSubnormal           mov     t4, manA
005e4 179 f5487ba8                         or      t4, expA wz             ' check for zero
005e8 17a 5d90000c           if_nz         jmp     #subnorm
005ec 17b f5474e02                         or      flagA, #ZeroFlag        ' yes, then set zero flag
005f0 17c f6675096                         neg     expA, #150              ' set exponent and exit
005f4 17d fd900024                         jmp     #U_exit2
                   
005f8 17e f0675207 subnorm                 shl     manA, #7                ' fix justification for subnormals
005fc 17f f7cb53a6 subnorm2                test    manA, Bit29 wz
00600 180 5d900014           if_nz         jmp     #U_exit1
00604 181 f0675201                         shl     manA, #1
00608 182 f1875001                         sub     expA, #1
0060c 183 fd9fffec                         jmp     #subnorm2
                   
00610 184 f0675206 finite                  shl     manA, #6                ' justify mantissa to bit 29
00614 185 f54353a6                         or      manA, Bit29             ' add leading one bit
                   
00618 186 f187507f U_exit1                 sub     expA, #127              ' remove bias from exponent
0061c 187 f7d74e08 U_exit2                 test    flagA, #NaNFlag wc      ' set C flag
00620 188 020f5200           _ret_         cmp     manA, #0 wz             ' set Z flag
                   
                   '------------------------------------------------------------------------------
                   ' input:   flagA        r0 flag bits (Nan, Infinity, Zero, Sign)
                   '          expA         r0 exponent (no bias)
                   '          manA         r0 mantissa (aligned to bit 29)
                   ' output:  r0        32-bit floating point value
                   ' changes: r0, flagA, expA, manA
                   '------------------------------------------------------------------------------
                   
00624 189 f20f5200 _Pack                   cmp     manA, #0 wz             ' check for zero
00628 18a a6075000           if_z          mov     expA, #0
0062c 18b ad900040           if_z          jmp     #P_exit3
                   
00630 18c f0775201 normalize_2             shl     manA, #1 wc             ' normalize the mantissa
00634 18d 31875001           if_nc         sub     expA, #1                ' adjust exponent
00638 18e 3d9ffff4           if_nc         jmp     #normalize_2
                   
0063c 18f f1075002                         add     expA, #2                ' adjust exponent
00640 190 f1175300                         add     manA, #$100 wc          ' round up by 1/2 lsb
00644 191 c1075001           if_c          add     expA, #1
                   
00648 192 f107507f                         add     expA, #127              ' add bias to exponent
0064c 193 f34351a4                         fges    expA, Minus23
00650 194 f36750ff                         fles    expA, #255
                   
00654 195 f2575001                         cmps    expA, #1 wc             ' check for subnormals
00658 196 3d900014           if_nc         jmp     #P_exit3
                   
0065c 197 f5475201 subnormal               or      manA, #1                ' adjust mantissa
00660 198 f0075201                         ror     manA, #1
                   
00664 199 f66351a8                         neg     expA, expA
00668 19a f04353a8                         shr     manA, expA
0066c 19b f6075000                         mov     expA, #0                ' biased exponent = 0
                   
00670 19c f6002da9 P_exit3                 mov     r0, manA             ' bits 22:0 mantissa
00674 19d f0442c09                         shr     r0, #9
00678 19e f0675017                         shl     expA, #23
0067c 19f f5402da8                         or      r0, expA
00680 1a0 f0674e1f                         shl     flagA, #31
00684 1a1 05402da7           _ret_          or      r0, flagA            ' bit 31 sign
                   
00688 1a2 7fffffff NaN                     long    $7FFF_FFFF
0068c 1a3 7f800000 Inf                     long    $7F80_0000
00690 1a4 ffffffe9 Minus23                 long    -23
00694 1a5 007fffff Mask23                  long    $007F_FFFF
00698 1a6 20000000 Bit29                   long    $2000_0000
                   
0069c 1a7 00000000 flagA                   long    0
006a0 1a8 00000000 expA                    long    0
006a4 1a9 00000000 manA                    long    0
                   
006a8 1aa 00000000 flagB                   long    0
006ac 1ab 00000000 expB                    long    0
006b0 1ac 00000000 manB                    long    0
                   
                   '-------------------- End of Float32 Components -------------------------------
                   
                   '-------------------------- Multi-Threading Support ----------------------------
                   
                   ' These must be in the same place in all the threaded kernels of the
                   ' same 'flavor' (i.e. CMM, LMM, NMM etc).
                   
006b4 1ad                   fit    $1e7
0079c 1e7                   orgf   $1e7
                   
0079c 1e7 00190000 ticks    long   100<<14         ' time between context switches (~10 ms)
007a0 1e8 00000000 TP       long   0               ' current thread pointer
007a4 1e9 00000007 lock     long   7               ' lock to use for context switching (default 7)
007a8 1ea 00000000 lockbits long   0               ' lockbits used to simulate P1-style locks
                   
                   ' last 5 longs are reserved for debug overlay vectors (or debug LED)
                   
007ac 1eb                   fit    $1eb
007ac 1eb                   orgf   $1eb
                   
007ac 1eb          DEBUG_VECTORS
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
                   
007ac 1eb 0007bde8          long   DEBUG_BREAK
007b0 1ec 0007bdec          long   DEBUG_ADDR
007b4 1ed 0007bdf0          long   DEBUG_OUT
007b8 1ee 0007bdf4          long   DEBUG_IN
007bc 1ef 0007bdf8          long   DEBUG_FLAG
                   
007c0 1f0                   fit    $1f0
                   
007c0 1f0                   fit    $1f8
007e0 1f8                   orgf   $1f8
007e0 1f8 00000000 SP       long   $0    ' SP is PTRA
007e4 1f9 00000000 FP       long   $0    ' FP is PTRB
                   
                   '------------------------- END OF KERNEL --------------------------------------
                   
007e8 300                   org $300
                   
                   ' Common Kernel library functions. This code is included only to get the LUT
                   ' offsets correct in the dynamically loaded kernel. The actual LUT code is
                   ' loaded into LUT from elsewhere. There must be a better way to do this, but I
                   ' can't think of one at the moment :(
                   
                   '#line 1 "../../../target_p2/Catalina_kernel_library.inc"
                   ' Catalina kernel library functions ...
                   
                   ' avoid including the kernel library functions twice ...
                   
                   
                   
                   
                   DAT
                   
                   ' unsigned_d32 - 32 bit unsigned division
                   
007e8 300          unsigned_d32
007e8 300 fd102c17          qdiv   r0,r1
007ec 301 fd602c18          getqx  r0
007f0 302 0d602e19   _ret_  getqy  r1
                   
                   ' signed_d32 - 32 bit signed division
                   
007f4 303          signed_d32
007f4 303 f6007817          mov    t3,r1           ' save sign for later
007f8 304 f6007a16          mov    t4,r0
007fc 305 f6402e17          abs    r1,r1
00800 306 f6402c16          abs    r0,r0
00804 307 f560783d          xor    t3,t4
00808 308 fda00300          call   #\unsigned_d32  ' perform unsigned division
0080c 309 f6107a3d          mov    t4,t4 WC        ' get bit #31 into carry
00810 30a f6802e17          negc   r1,r1           ' adjust the sign of the remainder
00814 30b f610783c          mov    t3,t3 WC        ' get bit #31 into carry
00818 30c 06802c16   _ret_  negc   r0,r0           ' adjust the sign of the result
                   
                   ' do_plugin - call a plugin
                   '
                   ' On entry:
                   '       r3 = code:
                   '            - cog id if >= 128 (i.e. $80 + cog id)
                   '            - plugin type if < 128 (i.e. 0 .. 127)
                   '            - service id if < 0
                   '       r2 = data (optional pointer)
                   '
                   ' NOTES: Locks are currently only supported when invoking via a service id.
                   '        When using service id, the data should only use the lower 24 bits.
                   '
                   ' On exit:
                   '       R0 = result
                   
0081c 30d          do_plugin
0081c 30d f6047a08         mov     t4,#8           ' t4 stores lock - default to none required
00820 30e f6102c19         mov     r0,r3 wc        ' get plugin type or cog id or service id
00824 30f cd90003c  if_b   jmp     #psvc           ' if < 0, code is a service id
00828 310 f7cc2c80         test    r0,#$80 wz      ' if bit 7 set ...
0082c 311 5d900074  if_nz  jmp     #pcog           ' code is a cog id ...
00830 312          ptype                           ' ... otherwize it's a plugin type
00830 312 f6007439         mov     t1,reg          ' point to registry
00834 313 f6047600         mov     t2,#0           ' start at cog id 0
00838 314          plgt1
00838 314 f21c7608         cmp     t2,#8 wcz       ' run out of cogs?
0083c 315 3d9000a0  if_ae  jmp     #plugerr        ' yes - no such plugin
00840 316 fb00783a         rdlong  t3,t1           ' no - check cog's plugin type
00844 317 f0447818         shr     t3,#24          ' is it ...
00848 318 f2087816         cmp     t3,r0 wz        ' ... the plugin type what we wanted?
0084c 319 ad90000c  if_z   jmp     #plgt2          ' yes - invoke plugin at this cog id
00850 31a 51047601  if_nz  add     t2,#1           ' no - try ...
00854 31b 51047404  if_nz  add     t1,#4           ' ... next ...
00858 31c 5d9fffdc  if_nz  jmp     #plgt1          ' ... cog id
0085c 31d          plgt2
0085c 31d f6002c3b         mov     r0,t2           ' use the cog where we found the plugin
00860 31e fd900040         jmp     #pcog           ' invoke plugin (via the cog id)
00864 31f          psvc
00864 31f f0642c01         shl     r0,#1           ' read entry ...
00868 320 f1002c39         add     r0,reg          ' ... from ...
0086c 321 fae02c16         rdword  r0,r0           ' ... the service registry
00870 322 f6007416         mov     t1,r0           ' save in t1 and extract ...
00874 323 f0442c0c         shr     r0,#12          ' ... cog number to r0
00878 324 f600763a         mov     t2,t1           ' save in t2 and extract ...
0087c 325 f06c7418         shl     t1,#24 wz       ' ... request code to t1 (top 8 bits) ...
00880 326 ad90005c  if_z   jmp     #plugerr        ' ... or throw error if request code is zero
00884 327 f6007a3b         mov     t4,t2           ' extract ...
00888 328 f0447a08         shr     t4,#8           ' ... lock number to t4
0088c 329 f7cc7a08         test    t4,#8 wz        ' are we required to use a lock?
00890 32a 5d900008  if_nz  jmp     #no_lock        ' no - just make the request
00894 32b          set_lock
00894 32b fd707a06         locktry t4 wc           ' yes - loop ...
00898 32c 3d9ffff8  if_nc  jmp     #set_lock       ' ... until we have set the lock
0089c 32d          no_lock
0089c 32d f5203036         andn    r2,top8         ' combine data ...
008a0 32e f540303a         or      r2,t1           ' ... with request code
008a4 32f          pcog
008a4 32f f5042c07         and     r0,#7           ' mask off cog id to 0 .. 7
008a8 330 f0642c02         shl     r0,#2           ' point to ...
008ac 331 f1002c39         add     r0,reg          ' ... registry entry for the cog
008b0 332 fb002c16         rdlong  r0,r0           ' get request block from registry
008b4 333 f7c82c36         test    r0,top8 wz      ' is a plugin registered in this cog?
008b8 334 ad900024  if_z   jmp     #plugerr        ' no - throw error
008bc 335 f5202c36         andn    r0,top8         ' yes - write ...
008c0 336 fc603016         wrlong  r2,r0           ' ... request
008c4 337          ploop
008c4 337 fb083216         rdlong  r3,r0   wz      ' wait till ...
008c8 338 5d9ffff8  if_nz  jmp     #ploop          ' ... request completed
008cc 339 f1042c04         add     r0,#4           ' get ...
008d0 33a fb002c16         rdlong  r0,r0           ' ... result
008d4 33b          clr_lock
008d4 33b f7cc7a08         test    t4,#8 wz        ' did we set a lock?
008d8 33c ad607a07  if_z   lockrel t4              ' yes - release the lock we set
008dc 33d fd64002d         ret
008e0 33e          plugerr
008e0 33e f6642c01         neg     r0,#1           ' plugin error (e.g. not registered)
008e4 33f fd9fffec         jmp     #clr_lock       ' done - clear lock if required
                   
                   ' do_register - register a plugin
