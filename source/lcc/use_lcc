#
echo ""
echo "setting up variables for using LCC"
echo ""
echo "I hope you used 'source use_lcc' to execute this!"
#
TMP_LCCDIR=$LCCDIR
if [[ "$TMP_LCCDIR" == "" ]] ; then
   TMP_LCCDIR=/opt/catalina
fi
#
if [[ ! -e "$TMP_LCCDIR/bin/catalina_env" ]] ; then
   clear
   echo ""
   echo "ERROR: Catalina does not appear to be installed in $TMP_LCCDIR"
   echo "";
   echo "Set the environment variable LCCDIR to where Catalina is installed.";
   echo "";
   exit
fi

BUILDDIR=$TMP_LCCDIR/source/lcc/build; export BUILDDIR

