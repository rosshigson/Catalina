<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="example" />
		<Option pch_mode="2" />
		<Option compiler="catalina" />
		<Build>
			<Target title="Debug">
				<Option output="bin\Debug\example" prefix_auto="1" extension_auto="0" />
				<Option object_output="obj\Debug\" />
				<Option type="1" />
				<Option compiler="catalina" />
				<Compiler>
					<Add option="-g3" />
				</Compiler>
				<Linker>
					<Add option="-g3" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-CNO_MOUSE" />
			<Add option="-CTINY" />
		</Compiler>
		<Linker>
			<Add option="-CNO_MOUSE" />
			<Add option="-CTINY" />
			<Add option="-lci" />
		</Linker>
		<Unit filename="..\..\demos\debug\debug_functions_1.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\demos\debug\debug_functions_2.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\demos\debug\debug_main.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\demos\debug\debug_test.h" />
		<Extensions>
			<code_completion />
			<debugger />
		</Extensions>
	</Project>
