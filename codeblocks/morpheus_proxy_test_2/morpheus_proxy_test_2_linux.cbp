		<Linker>
			<Add option="-CPROXY_MOUSE" />
			<Add option="-CPROXY_KEYBOARD" />
			<Add option="-CTINY" />
			<Add option="-lc" />
			<Add option="-CCPU_2" />
			<Add option="-CMORPHEUS" />
		</Linker>
		<ExtraCommands>
			<Add after="spinnaker -p -a ../../utilities/Generic_Proxy_Server.spin -I ../../target -o bin/Release/test_2_server_1 -b -D MORPHEUS -D CPU_1 -D NO_MOUSE" />
