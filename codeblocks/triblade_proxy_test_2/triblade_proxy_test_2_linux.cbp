<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="triblade_proxy_test_2" />
		<Option pch_mode="2" />
		<Option compiler="catalina" />
		<Build>
			<Target title="Release">
				<Option output="bin/Release/test_2_client_1" prefix_auto="1" extension_auto="0" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="catalina" />
			</Target>
		</Build>
		<Compiler>
			<Add option="-CNO_FLOAT" />
			<Add option="-CPROXY_SD" />
			<Add option="-CNO_MOUSE" />
			<Add option="-CSMALL" />
			<Add option="-CCPU_1" />
			<Add option="-CTRIBLADEPROP" />
		</Compiler>
		<Linker>
			<Add option="-CNO_FLOAT" />
			<Add option="-CPROXY_SD" />
			<Add option="-CNO_MOUSE" />
			<Add option="-CSMALL" />
			<Add option="-lcx" />
			<Add option="-CCPU_1" />
			<Add option="-CTRIBLADEPROP" />
		</Linker>
		<ExtraCommands>
			<Add after="spinnaker -p -a ../../utilities/Generic_Proxy_Server.spin -I ../../target -o bin/Release/test_2_server_2 -b -D TRIBLADEPROP -D CPU_2 -D NO_SCREEN -D NO_KEYBOARD -D NO_MOUSE" />
		</ExtraCommands>
		<Unit filename="../../demos/test_stdio_fs.c">
			<Option compilerVar="CC" />
		</Unit>
		<Extensions>
			<code_completion />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
