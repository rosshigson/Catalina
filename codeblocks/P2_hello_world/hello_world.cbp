<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="hello_world" />
		<Option pch_mode="2" />
		<Option compiler="catalina" />
		<Build>
			<Target title="Release">
				<Option output="bin/Release/hello_world" prefix_auto="1" extension_auto="0" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="catalina" />
			</Target>
		</Build>
		<Compiler>
			<Add option="-CTTY" />
			<Add option="-CNATIVE" />
			<Add option="-Clibci" />
			<Add option="-CP2_EVAL" />
			<Add option="-p2" />
		</Compiler>
		<Linker>
			<Add option="-CTTY" />
			<Add option="-CNATIVE" />
			<Add option="-lci" />
			<Add option="-CP2_EVAL" />
			<Add option="-p2" />
		</Linker>
		<Unit filename="../../demos/hello_world.c">
			<Option compilerVar="CC" />
		</Unit>
		<Extensions>
			<code_completion />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
