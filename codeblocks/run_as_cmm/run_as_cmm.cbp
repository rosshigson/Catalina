<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="run_as_cmm" />
		<Option pch_mode="2" />
		<Option compiler="catalina" />
		<Build>
			<Target title="default">
				<Option output="run_as_cmm.binary" prefix_auto="1" extension_auto="0" />
				<Option type="1" />
				<Option compiler="catalina" />
			</Target>
		</Build>
		<Compiler>
			<Add option="-b" />
			<Add option="-CTTY" />
			<Add option="-CCOMPACT" />
			<Add option="-Clibci" />
			<Add option="-p1" />
		</Compiler>
		<Linker>
			<Add option="-b" />
			<Add option="-CTTY" />
			<Add option="-CCOMPACT" />
			<Add option="-lci" />
			<Add option="-p1" />
		</Linker>
		<ExtraCommands>
			<Add before="cmd /c copy ..\hello_world_cmm\hello_world_cmm.inc ." />
			<Add before="cmd /c copy ..\hello_world_lmm\hello_world_lmm.inc ." />
		</ExtraCommands>
		<Unit filename="../../demos/multimodel/run_hello_world.c">
			<Option compilerVar="CC" />
		</Unit>
		<Extensions>
			<code_completion />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
