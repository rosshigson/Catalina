<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="jzip" />
		<Option pch_mode="2" />
		<Option compiler="catalina" />
		<Build>
			<Target title="Release">
				<Option output="..\..\catalyst\bin\jzip" prefix_auto="1" extension_auto="0" />
				<Option object_output="obj\Release\" />
				<Option type="1" />
				<Option compiler="catalina" />
			</Target>
			<Environment>
				<Variable name="MEM_SIZE" value="256k" />
			</Environment>
		</Build>
		<Compiler>
			<Add option="-CCLOCK" />
			<Add option="-CNO_MOUSE" />
			<Add option="-CLARGE" />
			<Add option="-DLOUSY_RANDOM" />
		</Compiler>
		<Linker>
			<Add option="-CCLOCK" />
			<Add option="-CNO_MOUSE" />
			<Add option="-M$(MEM_SIZE)" />
			<Add option="-CLARGE" />
			<Add option="-lcx" />
		</Linker>
		<Unit filename="..\..\catalyst\jzip\catalina_jzip.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\control.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\dumbio.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\extern.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\fileio.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\getopt.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\input.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\interpre.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\license.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\math.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\memory.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\object.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\operand.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\osdepend.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\property.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\quetzal.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\screen.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\text.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\variable.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\jzip\ztypes.h" />
		<Extensions>
			<code_completion />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
