<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="READ ME" />
		<Option pch_mode="2" />
		<Option compiler="catalina" />
		<Option show_notes="1">
			<notes>
				<![CDATA[The READ ME project in this workspace exists only to display the following information:

The proxy demos in this folder are specifically designed for the MORPHEUS and TRIBLADEPROP platforms, and they specify the platform in their respective Build Options. 

If you have defined your platform in your Compiler Settings - even if you have defined it to be MORPHEUS or TRIBLADEPROP - then you should undefine it when compiling these demos, otherwise they will not build correctly.]]>
			</notes>
		</Option>
		<Build>
			<Target title="Release">
				<Option output="bin\Release\READ ME" prefix_auto="1" extension_auto="0" />
				<Option object_output="obj\Release\" />
				<Option type="1" />
				<Option compiler="catalina" />
			</Target>
		</Build>
		<Compiler>
			<Add option="-CTINY" />
		</Compiler>
		<Linker>
			<Add option="-lc" />
			<Add option="-CTINY" />
		</Linker>
		<Extensions>
			<code_completion />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
