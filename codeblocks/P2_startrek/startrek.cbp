<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="startrek" />
		<Option pch_mode="2" />
		<Option compiler="catalina" />
		<Build>
			<Target title="Release">
				<Option output="bin/Release/startrek" prefix_auto="1" extension_auto="0" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="catalina" />
				<Linker>
					<Add option="-M$(MEM_SIZE)" />
				</Linker>
				<Environment>
					<Variable name="MEM_SIZE" value="128k" />
				</Environment>
			</Target>
		</Build>
		<Compiler>
			<Add option="-CSD" />
			<Add option="-CTTY" />
			<Add option="-CNATIVE" />
			<Add option="-Clibm" />
			<Add option="-Clibcx" />
			<Add option="-CP2_EVAL" />
			<Add option="-p2" />
		</Compiler>
		<Linker>
			<Add option="-CSD" />
			<Add option="-CTTY" />
			<Add option="-CNATIVE" />
			<Add option="-lm" />
			<Add option="-lcx" />
			<Add option="-CP2_EVAL" />
			<Add option="-p2" />
		</Linker>
		<Unit filename="../../demos/startrek.c">
			<Option compilerVar="CC" />
		</Unit>
		<Extensions>
			<code_completion />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
