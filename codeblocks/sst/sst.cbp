<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="sst" />
		<Option pch_mode="2" />
		<Option compiler="catalina" />
		<Build>
			<Target title="Release">
				<Option output="..\..\catalyst\bin\sst" prefix_auto="1" extension_auto="0" />
				<Option object_output="obj\Release\" />
				<Option type="1" />
				<Option compiler="catalina" />
			</Target>
			<Environment>
				<Variable name="MEM_SIZE" value="512k" />
			</Environment>
		</Build>
		<Compiler>
			<Add option="-CCLOCK" />
			<Add option="-CNO_MOUSE" />
			<Add option="-CLARGE" />
		</Compiler>
		<Linker>
			<Add option="-CCLOCK" />
			<Add option="-CNO_MOUSE" />
			<Add option="-M$(MEM_SIZE)" />
			<Add option="-CLARGE" />
			<Add option="-lma" />
			<Add option="-lcx" />
		</Linker>
		<Unit filename="..\..\catalyst\sst\ai.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\sst\battle.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\sst\catalina.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\sst\events.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\sst\finish.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\sst\moving.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\sst\planets.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\sst\reports.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\sst\setup.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\sst\sst.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="..\..\catalyst\sst\sst.h" />
		<Extensions>
			<code_completion />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
